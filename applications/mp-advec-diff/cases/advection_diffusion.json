{
  "$schema": "../parameters.schema.json",
  "base": {
    "case name": "advection_diffusion",
    "dimension": 2,
    "global refinements": 5,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 1.5707963267948966,
    "time step size": 0.01
  },
  "output": {
    "paraview": {
      "filename": "solution_advection_diffusion",
      "enable": true
    }
  },
  "advection diffusion": {
    "linear solver": {
      "do matrix free": true
    },
    "diffusivity": 0.0,
    "time integration": {
      "type": "implicit_euler"
    }
  }
}
