{
  "$schema": "../parameters.schema.json",
  "base": {
    "case name": "advection_diffusion",
    "dimension": 2,
    "global refinements": 5,
    "do print parameters": false,
    "fe": {
      "degree": 1
    }
  },
  "adaptive meshing": {
    "do amr": true,
    "upper perc to refine": 0.1,
    "lower perc to coarsen": 0.0,
    "max grid refinement level": 7
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 1.5707963267948966,
    "time step size": 0.01
  },
  "output": {
    "paraview": {
      "enable": true
    }
  },
  "advection diffusion": {
    "linear solver": {
      "do matrix free": true
    },
    "diffusivity": 0.0,
    "implementation": "adaflo",
    "time integration": {
      "type": "crank_nicolson"
    }
  }
}
