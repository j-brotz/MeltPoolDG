{
  "$schema": "../../parameters.schema.json",
  "base": {
    "case name": "advection_diffusion",
    "dimension": 2,
    "global refinements": 5,
    "do print parameters": false,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.05,
    "time step size": 0.01
  },
  "output": {
    "paraview": {
      "enable": false
    }
  },
  "advection diffusion": {
    "linear solver": {
      "do matrix free": true
    }
  },
  "case specific": {
    "inflow outflow bc": true
  }
}
