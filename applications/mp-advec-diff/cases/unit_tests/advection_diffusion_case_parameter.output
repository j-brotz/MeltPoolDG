{
    "adaptive meshing":
    {
        "do amr": "false",
        "do not modify boundary cells": "false",
        "every n step": "1",
        "lower perc to coarsen": "0",
        "max grid refinement level": "12",
        "min grid refinement level": "-1",
        "n initial refinement cycles": "0",
        "upper perc to refine": "0"
    },
    "advection diffusion":
    {
        "diffusivity": "0",
        "enable time dependent bc": "false",
        "implementation": "meltpooldg",
        "convection stabilization":
        {
            "coefficient": "-1",
            "type": "none"
        },
        "fe":
        {
            "degree": "-1",
            "type": "not_initialized"
        },
        "linear solver":
        {
            "abs tolerance": "1e-20",
            "do matrix free": "true",
            "max iterations": "10000",
            "monitor type": "none",
            "preconditioner type": "Diagonal",
            "rel tolerance": "1e-12",
            "solver type": "GMRES"
        },
        "predictor":
        {
            "n old solutions": "2",
            "type": "none"
        },
        "time integration":
        {
            "preconditioner update frequency": "100",
            "type": "crank_nicolson",
            "linear solver":
            {
                "abs tolerance": "1e-20",
                "do matrix free": "true",
                "max iterations": "10000",
                "monitor type": "none",
                "preconditioner type": "Identity",
                "rel tolerance": "1e-12",
                "solver type": "GMRES"
            },
            "nlsolve":
            {
                "field correction tolerance": "1e-10",
                "field correction tolerance alt": "1e-09",
                "max nonlinear iterations": "10",
                "max nonlinear iterations alt": "0",
                "residual tolerance": "1e-09",
                "residual tolerance alt": "1e-08",
                "verbosity level": "-1"
            }
        }
    },
    "base":
    {
        "case name": "not_initialized",
        "dimension": "2",
        "do print parameters": "true",
        "global refinements": "1",
        "number": "double",
        "verbosity level": "1",
        "fe":
        {
            "degree": "1",
            "type": "FE_Q"
        }
    },
    "output":
    {
        "directory": ".\/",
        "do user defined postprocessing": "false",
        "output variables": "all",
        "write frequency": "1",
        "write time step size": "1.79769e+308",
        "paraview":
        {
            "enable": "false",
            "filename": "solution",
            "n digits timestep": "4",
            "n groups": "1",
            "n patches": "0",
            "output material id": "false",
            "output subdomains": "false",
            "print boundary id": "false",
            "write higher order cells": "true"
        }
    },
    "profiling":
    {
        "enable": "false",
        "time type": "real",
        "write time step size": "10"
    },
    "time stepping":
    {
        "end time": "1",
        "max n steps": "10000000",
        "start time": "0",
        "time step size": "0.01",
        "time step size function": "0.0*t"
    }
}
