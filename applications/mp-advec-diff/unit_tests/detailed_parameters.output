{
    "base":
    {
        "case name":
        {
            "value": "not_initialized",
            "default_value": "not_initialized",
            "documentation": "Sets the base name for the application that will be fed to the problem type.",
            "pattern": "0",
            "pattern_description": "[Anything]",
            "actions": "0"
        },
        "dimension":
        {
            "value": "2",
            "default_value": "2",
            "documentation": "Defines the dimension of the problem",
            "pattern": "1",
            "pattern_description": "[Integer]",
            "actions": "1"
        },
        "number":
        {
            "value": "double",
            "default_value": "double",
            "documentation": "Floating point number format. Currently, only 'double' is explicitely instantiated.",
            "pattern": "2",
            "pattern_description": "[Selection double ]",
            "actions": "2"
        },
        "global refinements":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Defines the number of initial global refinements",
            "pattern": "3",
            "pattern_description": "[Integer]",
            "actions": "3"
        },
        "do print parameters":
        {
            "value": "true",
            "default_value": "true",
            "documentation": "Set this parameter to true to list parameters in output",
            "pattern": "4",
            "pattern_description": "[Bool]",
            "actions": "4"
        },
        "verbosity level":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Sets the verbosity level of the console output: 0: silent: for non-robust tests and benchmark runs; 1: minimal: for robust tests; 2: detailed; 3: full",
            "pattern": "5",
            "pattern_description": "[Integer]",
            "actions": "5"
        },
        "fe":
        {
            "type":
            {
                "value": "FE_Q",
                "default_value": "FE_Q",
                "documentation": "Finite Element.FE_Q: hexahedral continuous finite element with polynomial degree p; FE_SimplexP: tetrahedral continuous finite element with polynomial degree p; FE_Q_iso_Q1: hexahedral continuous finite element with p subdivisions containing linear elements; FE_DGQ: hexahedral discontinuous finite element with polynomial degree p",
                "pattern": "6",
                "pattern_description": "[Selection not_initialized|FE_Q|FE_SimplexP|FE_Q_iso_Q1|FE_DGQ ]",
                "actions": "6"
            },
            "degree":
            {
                "value": "1",
                "default_value": "1",
                "documentation": "Defines the degree p of the finite element type. If \"type\" is \"FE_Q_iso_Q1\" this parameter defines the number of subdivisions.",
                "pattern": "7",
                "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                "actions": "7"
            }
        }
    },
    "time stepping":
    {
        "start time":
        {
            "value": "0",
            "default_value": "0",
            "documentation": "Defines the start time for the solution of the levelset problem",
            "pattern": "8",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "8"
        },
        "end time":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Sets the end time for the solution of the levelset problem",
            "pattern": "9",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "9"
        },
        "time step size":
        {
            "value": "0.01",
            "default_value": "0.01",
            "documentation": "Sets the step size for time stepping. For non-uniform time stepping, this parameter determines the size of the first time step.",
            "pattern": "10",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "10"
        },
        "max n steps":
        {
            "value": "10000000",
            "default_value": "10000000",
            "documentation": "Sets the maximum number of melt_pool steps",
            "pattern": "11",
            "pattern_description": "[Integer]",
            "actions": "11"
        },
        "time step size function":
        {
            "value": "0.0*t",
            "default_value": "0.0*t",
            "documentation": "Set an analytical function to determine the time step size. For the prediction of the new time increment, the old time is used.",
            "pattern": "12",
            "pattern_description": "[Anything]",
            "actions": "12"
        }
    },
    "adaptive meshing":
    {
        "do amr":
        {
            "value": "false",
            "default_value": "false",
            "documentation": "Set this parameter to true to activate adaptive meshing",
            "pattern": "13",
            "pattern_description": "[Bool]",
            "actions": "13"
        },
        "do not modify boundary cells":
        {
            "value": "false",
            "default_value": "false",
            "documentation": "Set this parameter to true to not refine\/coarsen along boundaries.",
            "pattern": "14",
            "pattern_description": "[Bool]",
            "actions": "14"
        },
        "upper perc to refine":
        {
            "value": "0",
            "default_value": "0",
            "documentation": "Defines the (upper) percentage of elements that should be refined",
            "pattern": "15",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "15"
        },
        "lower perc to coarsen":
        {
            "value": "0",
            "default_value": "0",
            "documentation": "Defines the (lower) percentage of elements that should be coarsened",
            "pattern": "16",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "16"
        },
        "max grid refinement level":
        {
            "value": "12",
            "default_value": "12",
            "documentation": "Defines the number of maximum refinement steps one grid cell will be undergone.",
            "pattern": "17",
            "pattern_description": "[Integer]",
            "actions": "17"
        },
        "min grid refinement level":
        {
            "value": "-1",
            "default_value": "-1",
            "documentation": "Defines the number of minimum refinement steps one grid cell will be undergone.",
            "pattern": "18",
            "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
            "actions": "18"
        },
        "n initial refinement cycles":
        {
            "value": "0",
            "default_value": "0",
            "documentation": "Defines the number of initial refinements.",
            "pattern": "19",
            "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
            "actions": "19"
        },
        "every n step":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Defines at every nth step the amr should be performed.",
            "pattern": "20",
            "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
            "actions": "20"
        },
        "min cells marked to refine":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Minimum number of cells that must be marked for refinement\/coarsening before the mesh is updated.",
            "pattern": "21",
            "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
            "actions": "21"
        },
        "min indicator threshold to refine cell":
        {
            "value": "0",
            "default_value": "0",
            "documentation": "Minimum indicator value required for a cell to be considered for refinement.",
            "pattern": "22",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "22"
        },
        "solution transfer average values":
        {
            "value": "false",
            "default_value": "false",
            "documentation": "Set this parameter to true to average the contribututions to the same DoF coming from different cells during solution transfer.",
            "pattern": "23",
            "pattern_description": "[Bool]",
            "actions": "23"
        }
    },
    "advection diffusion":
    {
        "fe":
        {
            "type":
            {
                "value": "not_initialized",
                "default_value": "not_initialized",
                "documentation": "Finite Element.FE_Q: hexahedral continuous finite element with polynomial degree p; FE_SimplexP: tetrahedral continuous finite element with polynomial degree p; FE_Q_iso_Q1: hexahedral continuous finite element with p subdivisions containing linear elements; FE_DGQ: hexahedral discontinuous finite element with polynomial degree p",
                "pattern": "24",
                "pattern_description": "[Selection not_initialized|FE_Q|FE_SimplexP|FE_Q_iso_Q1|FE_DGQ ]",
                "actions": "24"
            },
            "degree":
            {
                "value": "-1",
                "default_value": "-1",
                "documentation": "Defines the degree p of the finite element type. If \"type\" is \"FE_Q_iso_Q1\" this parameter defines the number of subdivisions.",
                "pattern": "25",
                "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                "actions": "25"
            }
        },
        "convection stabilization":
        {
            "type":
            {
                "value": "none",
                "default_value": "none",
                "documentation": "Defines the type for convection stabilization.",
                "pattern": "26",
                "pattern_description": "[Selection none|SUPG ]",
                "actions": "26"
            },
            "coefficient":
            {
                "value": "-1",
                "default_value": "-1",
                "documentation": "Defines the stabilization coefficient for convection. (default velocity-dependent).",
                "pattern": "27",
                "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                "actions": "27"
            }
        },
        "diffusivity":
        {
            "value": "0",
            "default_value": "0",
            "documentation": "Defines the diffusivity for the advection diffusion equation ",
            "pattern": "28",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "28"
        },
        "implementation":
        {
            "value": "meltpooldg",
            "default_value": "meltpooldg",
            "documentation": "Choose the corresponding implementation of the advection diffusion operation.",
            "pattern": "29",
            "pattern_description": "[Selection meltpooldg|adaflo ]",
            "actions": "29"
        },
        "enable time dependent bc":
        {
            "value": "false",
            "default_value": "false",
            "documentation": "Set this parameter to true to enable time-dependent bc.",
            "pattern": "30",
            "pattern_description": "[Bool]",
            "actions": "30"
        },
        "predictor":
        {
            "type":
            {
                "value": "none",
                "default_value": "none",
                "documentation": "Choose a predictor type: none: use old value as initial guess; zero: se zeros as initial guess; linear_extrapolation: calculate the predictor by a linear combination from the two old solution vectors; least_squares_projection: least squares projection (WIP)",
                "pattern": "31",
                "pattern_description": "[Selection none|zero|linear_extrapolation|least_squares_projection ]",
                "actions": "31"
            },
            "n old solutions":
            {
                "value": "2",
                "default_value": "2",
                "documentation": "Choose the number of old solution vectors considered.This parameter is only relevant for least squares projection.For all other predictors, this parameter will be set appropriately.",
                "pattern": "32",
                "pattern_description": "[Integer]",
                "actions": "32"
            }
        },
        "linear solver":
        {
            "solver type":
            {
                "value": "GMRES",
                "default_value": "GMRES",
                "documentation": "Set this parameter for choosing an iterative linear solver type.",
                "pattern": "33",
                "pattern_description": "[Selection CG|GMRES ]",
                "actions": "33"
            },
            "preconditioner type":
            {
                "value": "Diagonal",
                "default_value": "Diagonal",
                "documentation": "Set this parameter for choosing a preconditioner type.",
                "pattern": "34",
                "pattern_description": "[Selection Identity|AMG|ILU|Diagonal ]",
                "actions": "34"
            },
            "max iterations":
            {
                "value": "10000",
                "default_value": "10000",
                "documentation": "Set the maximum number of iterations for solving the linear system of equations.",
                "pattern": "35",
                "pattern_description": "[Integer]",
                "actions": "35"
            },
            "rel tolerance":
            {
                "value": "1e-12",
                "default_value": "1e-12",
                "documentation": "Set the relative tolerance for a successful solution of the linear system of equations.",
                "pattern": "36",
                "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                "actions": "36"
            },
            "abs tolerance":
            {
                "value": "1e-20",
                "default_value": "1e-20",
                "documentation": "Set the absolute tolerance for a successful solution of the linear system of equations.",
                "pattern": "37",
                "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                "actions": "37"
            },
            "do matrix free":
            {
                "value": "true",
                "default_value": "true",
                "documentation": "Set this parameter if a matrix free solution procedure should be performed.",
                "pattern": "38",
                "pattern_description": "[Bool]",
                "actions": "38"
            },
            "monitor type":
            {
                "value": "none",
                "default_value": "none",
                "documentation": "Set the monitor type of the linear solver.",
                "pattern": "39",
                "pattern_description": "[Selection none|reduced|all ]",
                "actions": "39"
            }
        },
        "time integration":
        {
            "type":
            {
                "value": "crank_nicolson",
                "default_value": "crank_nicolson",
                "documentation": "Name of the time integration scheme.",
                "pattern": "40",
                "pattern_description": "[Selection not_initialized|LSRK_stage_1_order_1|LSRK_stage_3_order_3|LSRK_stage_5_order_4|LSRK_stage_7_order_4|LSRK_stage_9_order_5|implicit_euler|explicit_euler|crank_nicolson|bdf_1|bdf_2|bdf_3|bdf_4|bdf_5|bdf_6|imex ]",
                "actions": "40"
            },
            "preconditioner update frequency":
            {
                "value": "100",
                "default_value": "100",
                "documentation": "Frequency at which the preconditioner gets updated.",
                "pattern": "41",
                "pattern_description": "[Integer]",
                "actions": "41"
            },
            "nlsolve":
            {
                "max nonlinear iterations":
                {
                    "value": "10",
                    "default_value": "10",
                    "documentation": "Set the number of maximum nonlinear iterations with standard tolerances.",
                    "pattern": "42",
                    "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                    "actions": "42"
                },
                "field correction tolerance":
                {
                    "value": "1e-10",
                    "default_value": "1e-10",
                    "documentation": "Set the tolerance for the maximum allowed correction of the unknown field.",
                    "pattern": "43",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "43"
                },
                "residual tolerance":
                {
                    "value": "1e-09",
                    "default_value": "1e-09",
                    "documentation": "Set the tolerance for the maximum allowed residual of the nonlinear system.",
                    "pattern": "44",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "44"
                },
                "max nonlinear iterations alt":
                {
                    "value": "0",
                    "default_value": "0",
                    "documentation": "Set the number of maximum nonlinear iterations with alternative tolerances.",
                    "pattern": "45",
                    "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                    "actions": "45"
                },
                "field correction tolerance alt":
                {
                    "value": "1e-09",
                    "default_value": "1e-09",
                    "documentation": "Set the alternative tolerance for the maximum allowed correction of the unknown field.",
                    "pattern": "46",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "46"
                },
                "residual tolerance alt":
                {
                    "value": "1e-08",
                    "default_value": "1e-08",
                    "documentation": "Set the alternative tolerance for the maximum allowed residual of the nonlinear system.",
                    "pattern": "47",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "47"
                },
                "verbosity level":
                {
                    "value": "-1",
                    "default_value": "-1",
                    "documentation": "Set to one for detailed solver output.",
                    "pattern": "48",
                    "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                    "actions": "48"
                }
            },
            "linear solver":
            {
                "solver type":
                {
                    "value": "GMRES",
                    "default_value": "GMRES",
                    "documentation": "Set this parameter for choosing an iterative linear solver type.",
                    "pattern": "49",
                    "pattern_description": "[Selection CG|GMRES ]",
                    "actions": "49"
                },
                "preconditioner type":
                {
                    "value": "Identity",
                    "default_value": "Identity",
                    "documentation": "Set this parameter for choosing a preconditioner type.",
                    "pattern": "50",
                    "pattern_description": "[Selection Identity|AMG|ILU|Diagonal ]",
                    "actions": "50"
                },
                "max iterations":
                {
                    "value": "10000",
                    "default_value": "10000",
                    "documentation": "Set the maximum number of iterations for solving the linear system of equations.",
                    "pattern": "51",
                    "pattern_description": "[Integer]",
                    "actions": "51"
                },
                "rel tolerance":
                {
                    "value": "1e-12",
                    "default_value": "1e-12",
                    "documentation": "Set the relative tolerance for a successful solution of the linear system of equations.",
                    "pattern": "52",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "52"
                },
                "abs tolerance":
                {
                    "value": "1e-20",
                    "default_value": "1e-20",
                    "documentation": "Set the absolute tolerance for a successful solution of the linear system of equations.",
                    "pattern": "53",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "53"
                },
                "do matrix free":
                {
                    "value": "true",
                    "default_value": "true",
                    "documentation": "Set this parameter if a matrix free solution procedure should be performed.",
                    "pattern": "54",
                    "pattern_description": "[Bool]",
                    "actions": "54"
                },
                "monitor type":
                {
                    "value": "none",
                    "default_value": "none",
                    "documentation": "Set the monitor type of the linear solver.",
                    "pattern": "55",
                    "pattern_description": "[Selection none|reduced|all ]",
                    "actions": "55"
                }
            }
        }
    },
    "output":
    {
        "directory":
        {
            "value": ".\/",
            "default_value": ".\/",
            "documentation": "Sets the base directory for all output.",
            "pattern": "56",
            "pattern_description": "[Anything]",
            "actions": "56"
        },
        "write frequency":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Every n timestep that should be written",
            "pattern": "57",
            "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
            "actions": "57"
        },
        "write time step size":
        {
            "value": "1.79769e+308",
            "default_value": "1.79769e+308",
            "documentation": "Write output output every given time step. If this parameter is set, the output write frequency is deactivated.",
            "pattern": "58",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "58"
        },
        "output variables":
        {
            "value": "all",
            "default_value": "all",
            "documentation": "Specify variables that you request to output.",
            "pattern": "59",
            "pattern_description": "[List of <[Anything]> of length 0...4294967295 (inclusive)]",
            "actions": "59"
        },
        "do user defined postprocessing":
        {
            "value": "false",
            "default_value": "false",
            "documentation": "Set this parameter to true to enable user defined postprocessing.",
            "pattern": "60",
            "pattern_description": "[Bool]",
            "actions": "60"
        },
        "paraview":
        {
            "enable":
            {
                "value": "false",
                "default_value": "false",
                "documentation": "Set this parameter to true to activate paraview output.",
                "pattern": "61",
                "pattern_description": "[Bool]",
                "actions": "61"
            },
            "filename":
            {
                "value": "solution",
                "default_value": "solution",
                "documentation": "Sets the base name for paraview output files.",
                "pattern": "62",
                "pattern_description": "[Anything]",
                "actions": "62"
            },
            "n digits timestep":
            {
                "value": "4",
                "default_value": "4",
                "documentation": "Number of digits for the frame number of the vtu-file.",
                "pattern": "63",
                "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                "actions": "63"
            },
            "print boundary id":
            {
                "value": "false",
                "default_value": "false",
                "documentation": "Set this parameter to true to output a vtu-file with the boundary id.",
                "pattern": "64",
                "pattern_description": "[Bool]",
                "actions": "64"
            },
            "output subdomains":
            {
                "value": "false",
                "default_value": "false",
                "documentation": "Set this parameter to true to output the subdomain ranks.",
                "pattern": "65",
                "pattern_description": "[Bool]",
                "actions": "65"
            },
            "output material id":
            {
                "value": "false",
                "default_value": "false",
                "documentation": "Set to true to output the material id.",
                "pattern": "66",
                "pattern_description": "[Bool]",
                "actions": "66"
            },
            "write higher order cells":
            {
                "value": "true",
                "default_value": "true",
                "documentation": "Set this parameter to false to write bi- or trilinear data only. Set this parameter to true to write higher order cell data. Note: higher order cell data can only be written for hexahedron meshes and 2 or 3 dimensions.",
                "pattern": "67",
                "pattern_description": "[Bool]",
                "actions": "67"
            },
            "n groups":
            {
                "value": "1",
                "default_value": "1",
                "documentation": "Number of parallel written vtu-files.",
                "pattern": "68",
                "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                "actions": "68"
            },
            "n patches":
            {
                "value": "0",
                "default_value": "0",
                "documentation": "Control number of patches to enable high-order.",
                "pattern": "69",
                "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                "actions": "69"
            }
        },
        "particles":
        {
            "enable":
            {
                "value": "false",
                "default_value": "false",
                "documentation": "Set this parameter to true to activate particle paraview output.",
                "pattern": "70",
                "pattern_description": "[Bool]",
                "actions": "70"
            },
            "filename":
            {
                "value": "particle",
                "default_value": "particle",
                "documentation": "Sets the base name for particle output files.",
                "pattern": "71",
                "pattern_description": "[Anything]",
                "actions": "71"
            }
        }
    },
    "profiling":
    {
        "enable":
        {
            "value": "false",
            "default_value": "false",
            "documentation": "Set this parameter to true if profiling should be enabled. It will be automaticallyenabled for verbosity level >=1.",
            "pattern": "72",
            "pattern_description": "[Bool]",
            "actions": "72"
        },
        "write time step size":
        {
            "value": "10",
            "default_value": "10",
            "documentation": "Write profiling output every given time step size. If this parameter is set, the specified parameter for write frequency is overwritten.",
            "pattern": "73",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "73"
        },
        "time type":
        {
            "value": "real",
            "default_value": "real",
            "documentation": "Choose the type of time measure to write profiling information.",
            "pattern": "74",
            "pattern_description": "[Selection real|simulation ]",
            "actions": "74"
        }
    }
}
