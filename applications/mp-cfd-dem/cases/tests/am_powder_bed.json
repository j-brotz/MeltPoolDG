{
  "$schema": "../../parameters.schema.json",
  "base": {
    "case name": "am_powder_bed",
    "dimension": 3,
    "do print parameters": false,
    "verbosity level": 1,
    "global refinements": 2
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 4e-10,
    "time step size": 1e-10
  },
  "output": {
    "write frequency": 1,
    "do user defined postprocessing": true
  },
  "case specific": {
    "ambient temperature": 273,
    "ambient density": 1.784,
    "domain size": "0.0008, 0.0003, 0.0004",
    "domain discretization": "6, 3, 3",
    "jet hole diameter": 8e-05,
    "jet hole center": "0.0001, 0.0001, 0.0",
    "jet peak velocity": 10,
    "free jet profile": "constant"
  },
  "material": {
    "equation of state": {
      "type": "ideal_gas"
    },
    "spacific isobaric heat": 872,
    "dynamic viscosity": 2.1e-05,
    "gamma": 1.67,
    "specific gas constant": 203.13,
    "reference density": 1.784,
    "thermal conducitivity": 0.015
  },
  "compressible navier stokes": {
    "numerical flux type": "lax_friedrichs_modified",
    "use cfl criteria": false,
    "courant number": 0.001,
    "gravity constant": 0,
    "time integration": {
      "type": "LSRK_stage_5_order_4"
    },
    "fe": {
      "degree": 2,
      "type": "FE_DGQ"
    }
  },
  "fluid structure interaction": {
    "coupling method": "brinkman_penalization",
    "brinkman penalization": {
      "mask type": "discontinuous",
      "permeability": 1e-10
    }
  },
  "obstacles": {
    "stationary": true,
    "obstacle state input file": "../../particles_in_domain.csv",
    "cohesive forces": {
      "cut off relative decline van der waals": 1e-06,
      "hamaker constant": 4e-19,
      "surface energy": 1e-05
    },
    "spherical particle contact force": {
      "restitution coefficient": 0.6,
      "rolling resistance coefficient": 0.4,
      "sliding friction coefficient": 0.5,
      "particle-particle contact": {
        "poisson ratio": 0.8,
        "youngs modulus": 2000000000.0
      }
    }
  }
}
