{
  "application": {
    "amr strategies": "indicator"
  },
  "base": {
    "case name": "generic_hyper_rectangle_domain",
    "dimension": 2,
    "do print parameters": false,
    "verbosity level": 1,
    "global refinements": 1
  },
  "case setup": {
    "boundary x min": {
      "type": "inflow",
      "density": 0.4,
      "velocity": "150; 0",
      "energy": 750450,
      "inflow velocity ramp-up duration": 1e-08,
      "inflow velocity ramp-up type": "linear"
    },
    "boundary x max": {
      "type": "subsonic_outflow_fixed_energy",
      "energy": 295680
    },
    "boundary y min": {
      "type": "slip_wall"
    },
    "boundary y max": {
      "type": "slip_wall"
    },
    "initial conditions": {
      "density": 0.4,
      "velocity": "0.0; 0.0",
      "energy": 739200
    },
    "domain": {
      "size": "80e-6, 40e-6",
      "base grid resolution": "12, 6"
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 4e-11,
    "time step size": 5e-12
  },
  "output": {
    "write frequency": 1,
    "do user defined postprocessing": true
  },
  "compressible navier stokes": {
    "numerical flux type": "lax_friedrichs_modified",
    "use cfl criteria": false,
    "reference density": 0.04,
    "courant number": 0.001,
    "gravity constant": 0,
    "dynamic viscosity": 0.00011,
    "gamma": 1.6666666666,
    "specific gas constant": 160,
    "time integration": {
      "type": "LSRK_stage_5_order_4"
    },
    "fe": {
      "degree": 1,
      "type": "FE_DGQ"
    }
  },
  "fluid structure interaction": {
    "coupling method": "brinkman_penalization",
    "brinkman penalization": {
      "mask type": "discontinuous",
      "permeability": 1e-12
    }
  },
  "obstacles": {
    "stationary": true,
    "obstacle state input file": "../../stationary_particle_2d.csv"
  },
  "adaptive meshing": {
    "do amr": true,
    "max grid refinement level": 2,
    "min grid refinement level": 1,
    "upper perc to refine": 0.8,
    "lower perc to coarsen": 0,
    "every n step": 1,
    "min indicator threshold to refine cell": 0.001
  }
}
