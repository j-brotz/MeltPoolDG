{
  "$schema": "../../parameters.schema.json",
  "application": {
    "amr strategies": "obstacle_surface"
  },
  "base": {
    "case name": "generic_hyper_rectangle_domain",
    "dimension": 2,
    "do print parameters": false,
    "global refinements": 2,
    "verbosity level": 1
  },
  "case setup": {
    "boundary x min": {
      "type": "inflow",
      "density": 0.4,
      "velocity": "150; 0",
      "energy": 750450,
      "inflow velocity ramp-up duration": 1e-08,
      "inflow velocity ramp-up type": "linear"
    },
    "boundary x max": {
      "type": "subsonic_outflow_fixed_energy",
      "energy": 295680
    },
    "boundary y min": {
      "type": "slip_wall"
    },
    "boundary y max": {
      "type": "slip_wall"
    },
    "initial conditions": {
      "density": 0.4,
      "velocity": "0.0; 0.0",
      "energy": 739200
    },
    "domain": {
      "size": "80e-6, 40e-6",
      "base grid resolution": "6, 3"
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 1e-10
  },
  "output": {
    "write frequency": 1,
    "do user defined postprocessing": true,
    "paraview": {
      "enable": false
    },
    "particles": {
      "enable": false
    }
  },
  "material": {
    "equation of state": {
      "type": "ideal_gas"
    },
    "spacific isobaric heat": 872,
    "dynamic viscosity": 2.1e-05,
    "gamma": 1.67,
    "specific gas constant": 203.13,
    "reference density": 1.784,
    "thermal conducitivity": 0.015
  },
  "compressible navier stokes": {
    "numerical flux type": "lax_friedrichs_modified",
    "linearization jump convective flux": "lambda_fd",
    "use cfl criteria": true,
    "courant number": 0.05,
    "viscous courant number": 0.05,
    "gravity constant": 0,
    "jacobian type": "exact",
    "time integration": {
      "type": "imex",
      "linear solver": {
        "preconditioner type": "Diagonal",
        "rel tolerance": 1e-12,
        "abs tolerance": 1e-14
      },
      "nlsolve": {
        "max nonlinear iterations": 10,
        "residual tolerance": 1e-09,
        "field correction tolerance": 1e-07,
        "verbosity level": 1
      }
    },
    "fe": {
      "degree": 2,
      "type": "FE_DGQ"
    }
  },
  "fluid structure interaction": {
    "coupling method": "brinkman_penalization",
    "brinkman penalization": {
      "mask type": "discontinuous",
      "permeability": 1e-12
    }
  },
  "obstacles": {
    "stationary": true,
    "obstacle state input file": "../../stationary_particle_2d.csv",
    "amr": {
      "do refine": true,
      "inner surface distance": 0.3,
      "outer surface distance": 1
    }
  },
  "adaptive meshing": {
    "do amr": true,
    "max grid refinement level": 3,
    "min grid refinement level": 1,
    "every n step": 1
  }
}
