{
    "adaptive meshing":
    {
        "do amr": "false",
        "do not modify boundary cells": "false",
        "every n step": "1",
        "lower perc to coarsen": "0",
        "max grid refinement level": "12",
        "min cells marked to refine": "1",
        "min grid refinement level": "-1",
        "min indicator threshold to refine cell": "0",
        "n initial refinement cycles": "0",
        "solution transfer average values": "false",
        "upper perc to refine": "0"
    },
    "application":
    {
        "amr strategies": ""
    },
    "base":
    {
        "case name": "not_initialized",
        "dimension": "2",
        "do print parameters": "true",
        "global refinements": "1",
        "number": "double",
        "verbosity level": "1",
        "fe":
        {
            "degree": "1",
            "type": "FE_Q"
        }
    },
    "compressible navier stokes":
    {
        "courant number": "0.15",
        "domain representation type": "fitted",
        "gravity constant": "0",
        "jacobian type": "exact",
        "linearization jump convective flux": "complete_fd",
        "numerical flux type": "lax_friedrichs_modified",
        "output types": "conserved_variables",
        "use cfl criteria": "false",
        "verbosity level": "-1",
        "viscous courant number": "1",
        "fe":
        {
            "degree": "-1",
            "type": "not_initialized"
        },
        "time integration":
        {
            "preconditioner update frequency": "100",
            "type": "not_initialized",
            "linear solver":
            {
                "abs tolerance": "1e-20",
                "do matrix free": "true",
                "max iterations": "10000",
                "monitor type": "none",
                "preconditioner type": "Identity",
                "rel tolerance": "1e-12",
                "solver type": "GMRES"
            },
            "nlsolve":
            {
                "field correction tolerance": "1e-10",
                "field correction tolerance alt": "1e-09",
                "max nonlinear iterations": "10",
                "max nonlinear iterations alt": "0",
                "residual tolerance": "1e-09",
                "residual tolerance alt": "1e-08",
                "verbosity level": "-1"
            }
        }
    },
    "fluid structure interaction":
    {
        "coupling method": "brinkman_penalization",
        "brinkman penalization":
        {
            "mask type": "discontinuous",
            "permeability": "0"
        }
    },
    "material":
    {
        "gas":
        {
            "dynamic viscosity": "0.000625",
            "gamma": "1.4",
            "reference density": "1",
            "specific gas constant": "287.1",
            "specific isobaric heat": "1000",
            "thermal conductivity": "1.79769e+308",
            "equation of state":
            {
                "b": "1.79769e+308",
                "p inf": "1.79769e+308",
                "q": "2.22507e-308",
                "type": "ideal_gas"
            }
        }
    },
    "obstacles":
    {
        "obstacle state input file": "",
        "stationary": "false",
        "amr":
        {
            "do refine": "false",
            "inner surface distance": "1",
            "outer surface distance": "1"
        },
        "cohesive forces":
        {
            "cut off relative decline van der waals": "0",
            "hamaker constant": "0",
            "surface energy": "0"
        },
        "spherical particle contact force":
        {
            "restitution coefficient": "0",
            "rolling resistance coefficient": "0",
            "sliding friction coefficient": "0",
            "particle-particle contact":
            {
                "poisson ratio": "0",
                "youngs modulus": "0"
            }
        }
    },
    "output":
    {
        "directory": ".\/",
        "do user defined postprocessing": "false",
        "output variables": "all",
        "write frequency": "1",
        "write time step size": "1.79769e+308",
        "paraview":
        {
            "enable": "false",
            "filename": "solution",
            "n digits timestep": "4",
            "n groups": "1",
            "n patches": "0",
            "output material id": "false",
            "output subdomains": "false",
            "print boundary id": "false",
            "write higher order cells": "true"
        },
        "particles":
        {
            "enable": "false",
            "filename": "particle"
        }
    },
    "profiling":
    {
        "enable": "false",
        "time type": "real",
        "write time step size": "10"
    },
    "restart":
    {
        "directory": "",
        "load": "-1",
        "prefix": "restart",
        "save": "-1",
        "time type": "real",
        "write time step size": "0"
    },
    "time stepping":
    {
        "end time": "1",
        "max n steps": "10000000",
        "start time": "0",
        "time step size": "0.01",
        "time step size function": "0.0*t"
    }
}
