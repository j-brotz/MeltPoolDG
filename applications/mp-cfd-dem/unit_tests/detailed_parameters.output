            "actions": "47"
        },
        "verbosity level":
        {
            "value": "-1",
            "default_value": "-1",
            "documentation": "Verbosity level for output.",
            "pattern": "48",
            "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
            "actions": "48"
        },
        "limiter":
