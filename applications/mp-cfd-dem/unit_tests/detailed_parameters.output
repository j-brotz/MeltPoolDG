{
    "adaptive meshing":
    {
        "do amr":
        {
            "value": "false",
            "default_value": "false",
            "documentation": "Set this parameter to true to activate adaptive meshing",
            "pattern": "0",
            "pattern_description": "[Bool]",
            "actions": "0"
        },
        "do not modify boundary cells":
        {
            "value": "false",
            "default_value": "false",
            "documentation": "Set this parameter to true to not refine\/coarsen along boundaries.",
            "pattern": "1",
            "pattern_description": "[Bool]",
            "actions": "1"
        },
        "upper perc to refine":
        {
            "value": "0",
            "default_value": "0",
            "documentation": "Defines the (upper) percentage of elements that should be refined",
            "pattern": "2",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "2"
        },
        "lower perc to coarsen":
        {
            "value": "0",
            "default_value": "0",
            "documentation": "Defines the (lower) percentage of elements that should be coarsened",
            "pattern": "3",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "3"
        },
        "max grid refinement level":
        {
            "value": "12",
            "default_value": "12",
            "documentation": "Defines the number of maximum refinement steps one grid cell will be undergone.",
            "pattern": "4",
            "pattern_description": "[Integer]",
            "actions": "4"
        },
        "min grid refinement level":
        {
            "value": "-1",
            "default_value": "-1",
            "documentation": "Defines the number of minimum refinement steps one grid cell will be undergone.",
            "pattern": "5",
            "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
            "actions": "5"
        },
        "n initial refinement cycles":
        {
            "value": "0",
            "default_value": "0",
            "documentation": "Defines the number of initial refinements.",
            "pattern": "6",
            "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
            "actions": "6"
        },
        "every n step":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Defines at every nth step the amr should be performed.",
            "pattern": "7",
            "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
            "actions": "7"
        },
        "min cells marked to refine":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Minimum number of cells that must be marked for refinement\/coarsening before the mesh is updated.",
            "pattern": "8",
            "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
            "actions": "8"
        },
        "min indicator threshold to refine cell":
        {
            "value": "0",
            "default_value": "0",
            "documentation": "Minimum indicator value required for a cell to be considered for refinement.",
            "pattern": "9",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "9"
        },
        "solution transfer average values":
        {
            "value": "false",
            "default_value": "false",
            "documentation": "Set this parameter to true to average the contribututions to the same DoF coming from different cells during solution transfer.",
            "pattern": "10",
            "pattern_description": "[Bool]",
            "actions": "10"
        }
    },
    "base":
    {
        "case name":
        {
            "value": "not_initialized",
            "default_value": "not_initialized",
            "documentation": "Sets the base name for the application that will be fed to the problem type.",
            "pattern": "11",
            "pattern_description": "[Anything]",
            "actions": "11"
        },
        "dimension":
        {
            "value": "2",
            "default_value": "2",
            "documentation": "Defines the dimension of the problem",
            "pattern": "12",
            "pattern_description": "[Integer]",
            "actions": "12"
        },
        "number":
        {
            "value": "double",
            "default_value": "double",
            "documentation": "Floating point number format. Currently, only 'double' is explicitely instantiated.",
            "pattern": "13",
            "pattern_description": "[Selection double ]",
            "actions": "13"
        },
        "global refinements":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Defines the number of initial global refinements",
            "pattern": "14",
            "pattern_description": "[Integer]",
            "actions": "14"
        },
        "do print parameters":
        {
            "value": "true",
            "default_value": "true",
            "documentation": "Set this parameter to true to list parameters in output",
            "pattern": "15",
            "pattern_description": "[Bool]",
            "actions": "15"
        },
        "verbosity level":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Sets the verbosity level of the console output: 0: silent: for non-robust tests and benchmark runs; 1: minimal: for robust tests; 2: detailed; 3: full",
            "pattern": "16",
            "pattern_description": "[Integer]",
            "actions": "16"
        },
        "fe":
        {
            "type":
            {
                "value": "FE_Q",
                "default_value": "FE_Q",
                "documentation": "Finite Element.FE_Q: hexahedral continuous finite element with polynomial degree p; FE_SimplexP: tetrahedral continuous finite element with polynomial degree p; FE_Q_iso_Q1: hexahedral continuous finite element with p subdivisions containing linear elements; FE_DGQ: hexahedral discontinuous finite element with polynomial degree p",
                "pattern": "17",
                "pattern_description": "[Selection not_initialized|FE_Q|FE_SimplexP|FE_Q_iso_Q1|FE_DGQ ]",
                "actions": "17"
            },
            "degree":
            {
                "value": "1",
                "default_value": "1",
                "documentation": "Defines the degree p of the finite element type. If \"type\" is \"FE_Q_iso_Q1\" this parameter defines the number of subdivisions.",
                "pattern": "18",
                "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                "actions": "18"
            }
        }
    },
    "fluid structure interaction":
    {
        "coupling method":
        {
            "value": "brinkman_penalization",
            "default_value": "brinkman_penalization",
            "documentation": "Type of FSI coupling method. Available options are 'brinkman_penalization' and 'stokes_law'.",
            "pattern": "19",
            "pattern_description": "[Selection brinkman_penalization|stokes_law ]",
            "actions": "19"
        },
        "brinkman penalization":
        {
            "permeability":
            {
                "value": "0",
                "default_value": "0",
                "documentation": "Permeability used in the Brinkman penalization term.",
                "pattern": "20",
                "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                "actions": "20"
            },
            "mask type":
            {
                "value": "discontinuous",
                "default_value": "discontinuous",
                "documentation": "Type of mask function used for Brinkman penalization. Available options are 'discontinuous'.",
                "pattern": "21",
                "pattern_description": "[Selection discontinuous ]",
                "actions": "21"
            }
        }
    },
    "compressible navier stokes":
    {
        "fe":
        {
            "type":
            {
                "value": "not_initialized",
                "default_value": "not_initialized",
                "documentation": "Finite Element.FE_Q: hexahedral continuous finite element with polynomial degree p; FE_SimplexP: tetrahedral continuous finite element with polynomial degree p; FE_Q_iso_Q1: hexahedral continuous finite element with p subdivisions containing linear elements; FE_DGQ: hexahedral discontinuous finite element with polynomial degree p",
                "pattern": "22",
                "pattern_description": "[Selection not_initialized|FE_Q|FE_SimplexP|FE_Q_iso_Q1|FE_DGQ ]",
                "actions": "22"
            },
            "degree":
            {
                "value": "-1",
                "default_value": "-1",
                "documentation": "Defines the degree p of the finite element type. If \"type\" is \"FE_Q_iso_Q1\" this parameter defines the number of subdivisions.",
                "pattern": "23",
                "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                "actions": "23"
            }
        },
        "time integration":
        {
            "type":
            {
                "value": "not_initialized",
                "default_value": "not_initialized",
                "documentation": "Name of the time integration scheme.",
                "pattern": "24",
                "pattern_description": "[Selection not_initialized|LSRK_stage_1_order_1|LSRK_stage_3_order_3|LSRK_stage_5_order_4|LSRK_stage_7_order_4|LSRK_stage_9_order_5|implicit_euler|explicit_euler|crank_nicolson|bdf_1|bdf_2|bdf_3|bdf_4|bdf_5|bdf_6|imex ]",
                "actions": "24"
            },
            "preconditioner update frequency":
            {
                "value": "100",
                "default_value": "100",
                "documentation": "Frequency at which the preconditioner gets updated.",
                "pattern": "25",
                "pattern_description": "[Integer]",
                "actions": "25"
            },
            "nlsolve":
            {
                "max nonlinear iterations":
                {
                    "value": "10",
                    "default_value": "10",
                    "documentation": "Set the number of maximum nonlinear iterations with standard tolerances.",
                    "pattern": "26",
                    "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                    "actions": "26"
                },
                "field correction tolerance":
                {
                    "value": "1e-10",
                    "default_value": "1e-10",
                    "documentation": "Set the tolerance for the maximum allowed correction of the unknown field.",
                    "pattern": "27",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "27"
                },
                "residual tolerance":
                {
                    "value": "1e-09",
                    "default_value": "1e-09",
                    "documentation": "Set the tolerance for the maximum allowed residual of the nonlinear system.",
                    "pattern": "28",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "28"
                },
                "max nonlinear iterations alt":
                {
                    "value": "0",
                    "default_value": "0",
                    "documentation": "Set the number of maximum nonlinear iterations with alternative tolerances.",
                    "pattern": "29",
                    "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                    "actions": "29"
                },
                "field correction tolerance alt":
                {
                    "value": "1e-09",
                    "default_value": "1e-09",
                    "documentation": "Set the alternative tolerance for the maximum allowed correction of the unknown field.",
                    "pattern": "30",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "30"
                },
                "residual tolerance alt":
                {
                    "value": "1e-08",
                    "default_value": "1e-08",
                    "documentation": "Set the alternative tolerance for the maximum allowed residual of the nonlinear system.",
                    "pattern": "31",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "31"
                },
                "verbosity level":
                {
                    "value": "-1",
                    "default_value": "-1",
                    "documentation": "Set to one for detailed solver output.",
                    "pattern": "32",
                    "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                    "actions": "32"
                }
            },
            "linear solver":
            {
                "solver type":
                {
                    "value": "GMRES",
                    "default_value": "GMRES",
                    "documentation": "Set this parameter for choosing an iterative linear solver type.",
                    "pattern": "33",
                    "pattern_description": "[Selection CG|GMRES ]",
                    "actions": "33"
                },
                "preconditioner type":
                {
                    "value": "Identity",
                    "default_value": "Identity",
                    "documentation": "Set this parameter for choosing a preconditioner type.",
                    "pattern": "34",
                    "pattern_description": "[Selection Identity|AMG|ILU|Diagonal ]",
                    "actions": "34"
                },
                "max iterations":
                {
                    "value": "10000",
                    "default_value": "10000",
                    "documentation": "Set the maximum number of iterations for solving the linear system of equations.",
                    "pattern": "35",
                    "pattern_description": "[Integer]",
                    "actions": "35"
                },
                "rel tolerance":
                {
                    "value": "1e-12",
                    "default_value": "1e-12",
                    "documentation": "Set the relative tolerance for a successful solution of the linear system of equations.",
                    "pattern": "36",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "36"
                },
                "abs tolerance":
                {
                    "value": "1e-20",
                    "default_value": "1e-20",
                    "documentation": "Set the absolute tolerance for a successful solution of the linear system of equations.",
                    "pattern": "37",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "37"
                },
                "do matrix free":
                {
                    "value": "true",
                    "default_value": "true",
                    "documentation": "Set this parameter if a matrix free solution procedure should be performed.",
                    "pattern": "38",
                    "pattern_description": "[Bool]",
                    "actions": "38"
                },
                "monitor type":
                {
                    "value": "none",
                    "default_value": "none",
                    "documentation": "Set the monitor type of the linear solver.",
                    "pattern": "39",
                    "pattern_description": "[Selection none|reduced|all ]",
                    "actions": "39"
                }
            }
        },
        "linearization jump convective flux":
        {
            "value": "complete_fd",
            "default_value": "complete_fd",
            "documentation": "Calculation method of the linearized jump operator in the convective numerical flux (required for implicit time stepping). The options are \"analytic\", \"complete_fd\" and \"lambda_fd\".",
