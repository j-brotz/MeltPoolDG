    "material":
    {
        "gas":
        {
            "number of species":
            {
                "value": "1",
                "default_value": "1",
                "documentation": "Number of different species in the fluid phase.",
                "pattern": "53",
                "pattern_description": "[Integer range 1...2 (inclusive)]",
                "actions": "53"
