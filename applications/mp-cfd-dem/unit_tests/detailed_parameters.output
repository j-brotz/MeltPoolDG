            "eos type":
            {
                "value": "ideal_gas",
                "default_value": "ideal_gas",
                "documentation": "Type of equation of state. The options are \"ideal_gas\", \"stiffened_gas\" and \"noble_abel_stiffened_gas\".",
                "pattern": "54",
                "pattern_description": "[Selection ideal_gas|stiffened_gas|noble_abel_stiffened_gas ]",
                "actions": "54"
            },
            "reference density":
            {
                "value": "1",
                "default_value": "1",
                "documentation": "Reference density for computing the interior penalty factor. A good first guess is to choose a value in the order of the fluid density. If instabilities occur, the reference density can be decreased, so that the symmetric interior penalization is increased.",
                "pattern": "55",
                "pattern_description": "[Double 0...MAX_DOUBLE (inclusive)]",
                "actions": "55"
            },
            "reference dynamic viscosity":
            {
                "value": "0.000625",
                "default_value": "0.000625",
                "documentation": "Reference dynamic viscosity for computing the interior penalty factor. A good first guess is to choose a value in the order of the fluid dynamic viscosity. If instabilities occur, the reference dynamic viscosity can be increased, so that the symmetric interior penalization is increased.",
                "pattern": "56",
                "pattern_description": "[Double 0...MAX_DOUBLE (inclusive)]",
                "actions": "56"
            },
            "species 1":
            {
                "name":
                {
                    "value": "species",
                    "default_value": "species",
                    "documentation": "Name of the species used for output purposes.",
                    "pattern": "57",
                    "pattern_description": "[Anything]",
                    "actions": "57"
                },
                "specific isobaric heat":
                {
                    "value": "1000",
                    "default_value": "1000",
                    "documentation": "Specific isobaric heat.",
                    "pattern": "58",
                    "pattern_description": "[Double 0...MAX_DOUBLE (inclusive)]",
                    "actions": "58"
                },
                "dynamic viscosity":
                {
                    "value": "0.000625",
                    "default_value": "0.000625",
                    "documentation": "Dynamic viscosity.",
                    "pattern": "59",
                    "pattern_description": "[Double 0...MAX_DOUBLE (inclusive)]",
                    "actions": "59"
                },
                "gamma":
                {
                    "value": "1.4",
                    "default_value": "1.4",
                    "documentation": "Isentropic exponent, i.e., ratio of specific heat (c_p\/c_v).",
                    "pattern": "60",
                    "pattern_description": "[Double 0...MAX_DOUBLE (inclusive)]",
                    "actions": "60"
                },
                "specific gas constant":
                {
                    "value": "287.1",
