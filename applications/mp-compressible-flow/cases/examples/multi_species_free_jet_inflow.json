        "density": 1.5,
        "inner energy": 732000,
        "mass fractions": 0.0
      }
    },
    "boundary y max": {
      "type": "subsonic_outflow_fixed_energy",
      "energy": 1244400
    },
    "initial conditions": {
      "density": 1.7,
      "velocity": "0.0; 0.0",
      "energy": 732000,
      "species mass fractions": 1.0
