{
  "base": {
    "problem name": "compressible_flow",
    "case name": "generic_hyper_rectangle_domain",
    "dimension": 2,
    "do print parameters": false,
    "verbosity level": 1,
    "global refinements": 1
  },
  "case setup": {
    "boundary x min": {
