{
  "base": {
    "case name": "cut_flow_over_cylinder",
    "dimension": 2,
    "verbosity level": 1,
    "do print parameters": false,
    "global refinements": 2
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.0005
  },
  "output": {
    "write frequency": 1,
    "do user defined postprocessing": true,
    "paraview": {
      "filename": "solution_cut_flow_over_cylinder_N2",
      "enable": false
    }
  },
  "compressible navier stokes": {
    "numerical flux type": "lax_friedrichs_modified",
    "courant number": 0.2,
    "viscous courant number": 0.05,
    "use cfl criteria": true,
    "gravity constant": 0.0,
    "domain representation type": "cut",
    "time integration": {
      "linear solver": {
        "preconditioner type": "Identity",
        "solver type": "CG",
        "max iterations": 10000,
        "rel tolerance": 1e-07,
        "abs tolerance": 1e-20
      }
    },
    "fe": {
      "degree": 2,
      "type": "FE_DGQ"
    }
  },
  "material": {
    "gas": {
      "dynamic viscosity": 0.1,
      "reference density": 0.7,
      "equation of state": {
        "type": "ideal_gas"
      }
    }
  },
  "cut": {
    "unfitted flow boundary condition": "no_slip_wall",
    "stabilization": {
      "ghost-penalty": {
        "gamma M degree 0": 1.0,
        "gamma M degree 1": 0.1,
        "gamma M degree 2": 0.01
      }
    }
  }
}
