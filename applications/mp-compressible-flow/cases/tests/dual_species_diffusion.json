{
  "$schema": "../../parameters.schema.json",
  "base": {
    "case name": "generic_hyper_rectangle_domain",
    "dimension": 1,
    "do print parameters": false,
    "verbosity level": 1,
    "global refinements": 0,
    "fe": {
      "degree": 1,
      "type": "FE_DGQ"
    }
  },
  "case specific": {
    "initial conditions": {
      "density": 0.406,
      "velocity": 0,
      "energy": 50591.7,
      "species mass fractions": "1.0 - exp(-(x-0.0025)^2/0.0005^2)"
    },
    "domain": {
      "size": 0.005,
      "base grid resolution": 200,
      "periodic boundary conditions": true
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 2e-07
  },
  "output": {
    "write frequency": 1,
    "do user defined postprocessing": true,
    "paraview": {
      "enable": false
    }
  },
  "compressible navier stokes": {
    "numerical flux type": "lax_friedrichs_modified",
    "use cfl criteria": true,
    "courant number": 0.5,
    "viscous courant number": 0.03,
    "gravity constant": 0,
    "time integration": {
      "type": "LSRK_stage_5_order_4"
    },
    "fe": {
      "degree": 1,
      "type": "FE_DGQ"
    }
  },
  "material": {
    "gas": {
      "number of species": 2,
      "eos type": "ideal_gas",
      "reference density": 0.5,
      "reference dynamic viscosity": 1.7e-05,
      "species 1": {
        "name": "Y1",
        "dynamic viscosity": 1.7e-05,
        "gamma": 5.9,
        "specific gas constant": 831.0,
        "specific isobaric heat": 1000.0,
        "thermal conductivity": 0.02,
        "molar mass": 0.01
      },
      "species 2": {
        "name": "Y2",
        "dynamic viscosity": 2.8e-05,
        "gamma": 2.4,
        "specific gas constant": 400,
        "specific isobaric heat": 500.0,
        "thermal conductivity": 0.04,
        "molar mass": 0.03
      },
      "species interactions": {
        "interaction pair 1": {
          "species 1": 1,
          "species 2": 2,
          "diffusion coefficient": 5.9e-05
        }
      }
    }
  }
}
