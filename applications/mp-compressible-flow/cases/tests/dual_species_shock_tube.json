{
  "$schema": "../../parameters.schema.json",
  "base": {
    "case name": "generic_hyper_rectangle_domain",
    "dimension": 1,
    "do print parameters": false,
    "verbosity level": 1,
    "global refinements": 0,
    "fe": {
      "degree": 1,
      "type": "FE_DGQ"
    }
  },
  "case specific": {
    "boundary x min": {
      "type": "inflow",
      "density": 1.0,
      "velocity": 0,
      "energy": 2.5,
      "species mass fractions": 1.0,
      "inflow ramp-up type": "none"
    },
    "boundary x max": {
      "type": "inflow",
      "density": 0.125,
      "velocity": 0,
      "energy": 4.0,
      "species mass fractions": 0.0,
      "inflow ramp-up type": "none"
    },
    "initial conditions": {
      "density": "1.0 * (x < 0.5) + 0.125 * (x >= 0.5)",
      "velocity": 0,
      "energy": "2.5 * (x < 0.5) + 4.0 * (x >= 0.5)",
      "species mass fractions": "1.0 * (x < 0.5) + 0.0 * (x >= 0.5)"
    },
    "domain": {
      "size": 1,
      "base grid resolution": 2000
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.001
  },
  "output": {
    "write frequency": 1,
    "do user defined postprocessing": true,
    "paraview": {
      "enable": false
    }
  },
  "compressible navier stokes": {
    "numerical flux type": "lax_friedrichs_modified",
    "use cfl criteria": true,
    "courant number": 0.3,
    "viscous courant number": 1.0,
    "gravity constant": 0,
    "time integration": {
      "type": "LSRK_stage_5_order_4"
    },
    "fe": {
      "degree": 1,
      "type": "FE_DGQ"
    }
  },
  "material": {
    "gas": {
      "number of species": 2,
      "eos type": "ideal_gas",
      "reference density": 1.0,
      "reference dynamic viscosity": 0.0,
      "species 1": {
        "name": "Y1",
        "dynamic viscosity": 0.0,
        "gamma": 1.4,
        "specific gas constant": 1,
        "specific isobaric heat": 3.5,
        "molar mass": 8.3144
      },
      "species 2": {
        "name": "Y2",
        "dynamic viscosity": 0.0,
        "gamma": 1.2,
        "specific gas constant": 0.7,
        "specific isobaric heat": 5.95,
        "molar mass": 11.8778
      },
      "species interactions": {
        "interaction pair 1": {
          "species 1": 1,
          "species 2": 2,
          "diffusion coefficient": 0.0
        }
      }
    }
  }
}
