{
  "$schema": "../../parameters.schema.json",
  "base": {
    "case name": "isentropic_vortex",
    "dimension": 2,
    "verbosity level": 1,
    "global refinements": 3,
    "do print parameters": false
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 1.0,
    "time step size": 0.1
  },
  "output": {
    "write frequency": 1,
    "do user defined postprocessing": true,
    "paraview": {
      "enable": false
    }
  },
  "compressible navier stokes": {
    "numerical flux type": "lax_friedrichs_modified",
    "jacobian type": "exact",
    "time integration": {
      "type": "bdf_6",
      "linear solver": {
        "rel tolerance": 1e-05,
        "abs tolerance": 1e-15
      },
      "nlsolve": {
        "residual tolerance": 1e-10
      }
    },
    "fe": {
      "degree": 2,
      "type": "FE_DGQ"
    }
  },
  "material": {
    "gas": {
      "dynamic viscosity": 0.0,
      "equation of state": {
        "type": "ideal_gas"
      }
    }
  }
}
