{
  "base": {
    "problem name": "compressible_flow",
    "case name": "channel_particle_flow",
    "dimension": "2",
    "global refinements": "1",
    "do print parameters": "false"
  },
  "time stepping": {
    "start time": "0.0",
    "end time": "0.02"
  },
  "output": {
    "write frequency": "1",
    "do user defined postprocessing": "true",
    "paraview": {
      "enable": "false"
    }
  },
  "compressible navier stokes": {
    "numerical flux type": "lax_friedrichs_exact",
    "linearization jump convective flux": "lambda_fd",
    "use cfl criteria": "true",
    "courant number": 0.9,
    "jacobian type": "exact",
    "gravity": 0.5,
    "time integration": {
      "type": "imex",
      "linear solver": {
        "rel tolerance": 1e-10,
        "abs tolerance": 1e-14
      },
      "nlsolve": {
        "residual tolerance": 1e-12
      }
    },
    "material data gas phase": {
      "equation of state": "ideal_gas"
    },
    "fe": {
      "degree": "2",
      "type": "FE_DGQ"
    }
  }
}