{
  "$schema": "../../parameters.schema.json",
  "base": {
    "case name": "channel_particle_flow",
    "dimension": 2,
    "global refinements": 0,
    "do print parameters": false
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.01,
    "time step size": 0.001
  },
  "output": {
    "write frequency": 1,
    "do user defined postprocessing": true,
    "paraview": {
      "enable": false
    }
  },
  "compressible navier stokes": {
    "numerical flux type": "lax_friedrichs_exact",
    "linearization jump convective flux": "lambda_fd",
    "use cfl criteria": false,
    "jacobian type": "exact",
    "gravity": 0.5,
    "time integration": {
      "preconditioner update frequency": 1,
      "type": "bdf_4",
      "linear solver": {
        "rel tolerance": 1e-10,
        "abs tolerance": 1e-12,
        "preconditioner type": "Diagonal"
      },
      "nlsolve": {
        "residual tolerance": 1e-10,
        "verbosity level": 1
      }
    },
    "fe": {
      "degree": 2,
      "type": "FE_DGQ"
    }
  },
  "material": {
    "gas": {
      "equation of state": {
        "type": "ideal_gas"
      }
    }
  }
}
