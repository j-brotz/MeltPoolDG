        "type": "ideal_gas"
      }
    },
    "liquid": {
      "dynamic viscosity": 0.0035,
      "specific isobaric heat": 1126.0,
      "reference density": 3622.0,
      "gamma": 1.4355,
      "equation of state": {
        "type": "noble_abel_stiffened_gas",
        "p inf": 11587000000.0,
        "b": 0.00018759,
        "q": -607968.8
      }
    }
  },
  "cut": {
    "two phase": true,
    "stabilization": {
      "ghost-penalty": {
