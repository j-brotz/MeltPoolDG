{
  "$schema": "../parameters.schema.json",
  "base": {
    "case name": "two_phase",
    "dimension": 1,
    "verbosity level": 1,
    "do print parameters": false,
    "global refinements": 0
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 1e-05
  },
  "output": {
