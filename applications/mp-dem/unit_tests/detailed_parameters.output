{
    "base":
    {
        "case name":
        {
            "value": "not_initialized",
            "default_value": "not_initialized",
            "documentation": "Sets the base name for the application that will be fed to the problem type.",
            "pattern": "0",
            "pattern_description": "[Anything]",
            "actions": "0"
        },
        "dimension":
        {
            "value": "2",
            "default_value": "2",
            "documentation": "Defines the dimension of the problem",
            "pattern": "1",
            "pattern_description": "[Integer]",
            "actions": "1"
        },
        "number":
        {
            "value": "double",
            "default_value": "double",
            "documentation": "Floating point number format. Currently, only 'double' is explicitely instantiated.",
            "pattern": "2",
            "pattern_description": "[Selection double ]",
            "actions": "2"
        },
        "global refinements":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Defines the number of initial global refinements",
            "pattern": "3",
            "pattern_description": "[Integer]",
            "actions": "3"
        },
        "do print parameters":
        {
            "value": "true",
            "default_value": "true",
            "documentation": "Set this parameter to true to list parameters in output",
            "pattern": "4",
            "pattern_description": "[Bool]",
            "actions": "4"
        },
        "verbosity level":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Sets the verbosity level of the console output: 0: silent: for non-robust tests and benchmark runs; 1: minimal: for robust tests; 2: detailed; 3: full",
            "pattern": "5",
            "pattern_description": "[Integer]",
            "actions": "5"
        },
        "fe":
        {
            "type":
            {
                "value": "FE_Q",
                "default_value": "FE_Q",
                "documentation": "Finite Element.FE_Q: hexahedral continuous finite element with polynomial degree p; FE_SimplexP: tetrahedral continuous finite element with polynomial degree p; FE_Q_iso_Q1: hexahedral continuous finite element with p subdivisions containing linear elements; FE_DGQ: hexahedral discontinuous finite element with polynomial degree p",
                "pattern": "6",
                "pattern_description": "[Selection not_initialized|FE_Q|FE_SimplexP|FE_Q_iso_Q1|FE_DGQ ]",
                "actions": "6"
            },
            "degree":
            {
                "value": "1",
                "default_value": "1",
                "documentation": "Defines the degree p of the finite element type. If \"type\" is \"FE_Q_iso_Q1\" this parameter defines the number of subdivisions.",
                "pattern": "7",
                "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                "actions": "7"
            }
        }
    },
    "time stepping":
    {
        "start time":
        {
            "value": "0",
            "default_value": "0",
            "documentation": "Defines the start time for the solution of the levelset problem",
            "pattern": "8",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "8"
        },
        "end time":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Sets the end time for the solution of the levelset problem",
            "pattern": "9",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "9"
        },
        "time step size":
        {
            "value": "0.01",
            "default_value": "0.01",
            "documentation": "Sets the step size for time stepping. For non-uniform time stepping, this parameter determines the size of the first time step.",
            "pattern": "10",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "10"
        },
        "max n steps":
        {
            "value": "10000000",
            "default_value": "10000000",
            "documentation": "Sets the maximum number of melt_pool steps",
            "pattern": "11",
            "pattern_description": "[Integer]",
            "actions": "11"
        },
        "time step size function":
        {
            "value": "0.0*t",
            "default_value": "0.0*t",
            "documentation": "Set an analytical function to determine the time step size. For the prediction of the new time increment, the old time is used.",
            "pattern": "12",
            "pattern_description": "[Anything]",
            "actions": "12"
        }
    },
    "obstacles":
    {
        "stationary":
        {
            "value": "false",
            "default_value": "false",
            "documentation": "Set to true if obstacles shall be stationary.",
            "pattern": "13",
            "pattern_description": "[Bool]",
            "actions": "13"
        },
        "obstacle state input file":
        {
            "value": "",
            "default_value": "",
            "documentation": "File in which the obstacle initial state data is stored.",
            "pattern": "14",
            "pattern_description": "[Anything]",
            "actions": "14"
        },
        "gravity constant":
        {
            "value": "9.81",
            "default_value": "9.81",
            "documentation": "Gravitational acceleration constant used for computing the gravitational force acting on the obstacles.",
            "pattern": "15",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "15"
        },
        "amr":
        {
            "do refine":
            {
                "value": "false",
                "default_value": "false",
                "documentation": "If true and AMR is enabled, regions around obstacles are adaptively refined according to the specified refinement parameters.",
                "pattern": "16",
                "pattern_description": "[Bool]",
                "actions": "16"
            },
            "inner surface distance":
            {
                "value": "1",
                "default_value": "1",
                "documentation": "Fraction of a reference length (e.g., particle radius) used to determine the distance from the obstacle surface within which cells inside the obstacles are refined.",
                "pattern": "17",
                "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                "actions": "17"
            },
            "outer surface distance":
            {
                "value": "1",
                "default_value": "1",
                "documentation": "Fraction of a reference length (e.g., particle radius) used to determine the distance from the obstacle surface within which cells outside the obstacles are refined.",
                "pattern": "18",
                "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                "actions": "18"
            }
        },
        "cohesive forces":
        {
            "hamaker constant":
            {
                "value": "0",
                "default_value": "0",
                "documentation": "Hamaker constant used in the van der Waals force calculation for all particles.",
                "pattern": "19",
                "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                "actions": "19"
            },
            "surface energy":
            {
                "value": "0",
                "default_value": "0",
                "documentation": "Surface energy used in the pull-off force calculation for all particles.",
                "pattern": "20",
                "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                "actions": "20"
            },
            "cut off relative decline van der waals":
            {
                "value": "0",
                "default_value": "0",
                "documentation": "Cut-off relative decline for the van der Waals force calculation at which the force is set to zero.",
                "pattern": "21",
                "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                "actions": "21"
            }
        },
        "spherical particle contact force":
        {
            "restitution coefficient":
            {
                "value": "0",
                "default_value": "0",
                "documentation": "",
                "pattern": "22",
                "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                "actions": "22"
            },
            "sliding friction coefficient":
            {
                "value": "0",
                "default_value": "0",
                "documentation": "",
                "pattern": "23",
                "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                "actions": "23"
            },
            "rolling resistance coefficient":
            {
                "value": "0",
                "default_value": "0",
                "documentation": "",
                "pattern": "24",
                "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                "actions": "24"
            },
            "particle-particle contact":
            {
                "youngs modulus":
                {
                    "value": "0",
                    "default_value": "0",
                    "documentation": "",
                    "pattern": "25",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "25"
                },
                "poisson ratio":
                {
                    "value": "0",
                    "default_value": "0",
                    "documentation": "",
                    "pattern": "26",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "26"
                }
            }
        }
    },
    "output":
    {
        "directory":
        {
            "value": ".\/",
            "default_value": ".\/",
            "documentation": "Sets the base directory for all output.",
            "pattern": "27",
            "pattern_description": "[Anything]",
            "actions": "27"
        },
        "write frequency":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Every n timestep that should be written",
            "pattern": "28",
            "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
            "actions": "28"
        },
        "write time step size":
        {
            "value": "1.79769e+308",
            "default_value": "1.79769e+308",
            "documentation": "Write output output every given time step. If this parameter is set, the output write frequency is deactivated.",
            "pattern": "29",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "29"
        },
        "output variables":
        {
            "value": "all",
            "default_value": "all",
            "documentation": "Specify variables that you request to output.",
            "pattern": "30",
            "pattern_description": "[List of <[Anything]> of length 0...4294967295 (inclusive)]",
            "actions": "30"
        },
        "do user defined postprocessing":
        {
            "value": "false",
            "default_value": "false",
            "documentation": "Set this parameter to true to enable user defined postprocessing.",
            "pattern": "31",
            "pattern_description": "[Bool]",
            "actions": "31"
        },
        "paraview":
        {
            "enable":
            {
                "value": "false",
                "default_value": "false",
                "documentation": "Set this parameter to true to activate paraview output.",
                "pattern": "32",
                "pattern_description": "[Bool]",
                "actions": "32"
            },
            "filename":
            {
                "value": "solution",
                "default_value": "solution",
                "documentation": "Sets the base name for paraview output files.",
                "pattern": "33",
                "pattern_description": "[Anything]",
                "actions": "33"
            },
            "n digits timestep":
            {
                "value": "4",
                "default_value": "4",
                "documentation": "Number of digits for the frame number of the vtu-file.",
                "pattern": "34",
                "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                "actions": "34"
            },
            "print boundary id":
            {
                "value": "false",
                "default_value": "false",
                "documentation": "Set this parameter to true to output a vtu-file with the boundary id.",
                "pattern": "35",
                "pattern_description": "[Bool]",
                "actions": "35"
            },
            "output subdomains":
            {
                "value": "false",
                "default_value": "false",
                "documentation": "Set this parameter to true to output the subdomain ranks.",
                "pattern": "36",
                "pattern_description": "[Bool]",
                "actions": "36"
            },
            "output material id":
            {
                "value": "false",
                "default_value": "false",
                "documentation": "Set to true to output the material id.",
                "pattern": "37",
                "pattern_description": "[Bool]",
                "actions": "37"
            },
            "write higher order cells":
            {
                "value": "true",
                "default_value": "true",
                "documentation": "Set this parameter to false to write bi- or trilinear data only. Set this parameter to true to write higher order cell data. Note: higher order cell data can only be written for hexahedron meshes and 2 or 3 dimensions.",
                "pattern": "38",
                "pattern_description": "[Bool]",
                "actions": "38"
            },
            "n groups":
            {
                "value": "1",
                "default_value": "1",
                "documentation": "Number of parallel written vtu-files.",
                "pattern": "39",
                "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                "actions": "39"
            },
            "n patches":
            {
                "value": "0",
                "default_value": "0",
                "documentation": "Control number of patches to enable high-order.",
                "pattern": "40",
                "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                "actions": "40"
            }
        },
        "particles":
        {
            "enable":
            {
                "value": "false",
                "default_value": "false",
                "documentation": "Set this parameter to true to activate particle paraview output.",
                "pattern": "41",
                "pattern_description": "[Bool]",
                "actions": "41"
            },
            "filename":
            {
                "value": "particle",
                "default_value": "particle",
                "documentation": "Sets the base name for particle output files.",
                "pattern": "42",
                "pattern_description": "[Anything]",
                "actions": "42"
            }
        }
    },
    "profiling":
    {
        "enable":
        {
            "value": "false",
            "default_value": "false",
            "documentation": "Set this parameter to true if profiling should be enabled. It will be automaticallyenabled for verbosity level >=1.",
            "pattern": "43",
            "pattern_description": "[Bool]",
            "actions": "43"
        },
        "write time step size":
        {
            "value": "10",
            "default_value": "10",
            "documentation": "Write profiling output every given time step size. If this parameter is set, the specified parameter for write frequency is overwritten.",
            "pattern": "44",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "44"
        },
        "time type":
        {
            "value": "real",
            "default_value": "real",
            "documentation": "Choose the type of time measure to write profiling information.",
            "pattern": "45",
            "pattern_description": "[Selection real|simulation ]",
            "actions": "45"
        }
    },
    "restart":
    {
        "save":
        {
            "value": "-1",
            "default_value": "-1",
            "documentation": "Set this parameter to any number >= 0 to specify how many restart files should be kept. -1 means no restart save.",
            "pattern": "46",
            "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
            "actions": "46"
        },
        "load":
        {
            "value": "-1",
            "default_value": "-1",
            "documentation": "Set this parameter to any number >= 0 to specify which restart file should be loaded. -1 means no restart load.",
            "pattern": "47",
            "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
            "actions": "47"
        },
        "write time step size":
        {
            "value": "0",
            "default_value": "0",
            "documentation": "Write restart output every given time step size. If this parameter is set, the specified parameter for write frequency is overwritten.",
            "pattern": "48",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "48"
        },
        "time type":
        {
            "value": "real",
            "default_value": "real",
            "documentation": "Choose the type of time measure to write ",
            "pattern": "49",
            "pattern_description": "[Selection real|simulation ]",
            "actions": "49"
        },
        "directory":
        {
            "value": "",
            "default_value": "",
            "documentation": "Write restart directory",
            "pattern": "50",
            "pattern_description": "[Anything]",
            "actions": "50"
        },
        "prefix":
        {
            "value": "restart",
            "default_value": "restart",
            "documentation": "Write restart prefix",
            "pattern": "51",
            "pattern_description": "[Anything]",
            "actions": "51"
        }
    }
}