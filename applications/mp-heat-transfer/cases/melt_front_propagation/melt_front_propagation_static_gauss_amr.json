{
  "time stepping": {
    "start time": 0.0,
    "time step size": 1e-05,
    "end time": 0.005,
    "max n steps": 500
  },
  "base": {
    "case name": "melt_front_propagation",
    "dimension": 2,
    "do print parameters": false,
    "global refinements": 4,
    "verbosity level": 2,
    "fe": {
      "degree": 1
    }
  },
  "simulation specific parameters": {
    "domain x min": 0.0,
