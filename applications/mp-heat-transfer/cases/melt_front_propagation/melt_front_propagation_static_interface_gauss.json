{
  "$schema": "../../parameters.schema.json",
  "time stepping": {
    "start time": 0.0,
    "time step size": 0.0001,
    "end time": 0.015,
    "max n steps": 150
  },
  "base": {
    "case name": "melt_front_propagation",
    "dimension": 2,
    "do print parameters": false,
    "global refinements": 5,
    "verbosity level": 2,
    "fe": {
      "degree": 1
    }
  },
  "simulation specific parameters": {
    "domain x min": 0.0,
    "domain x max": 0.0006,
    "domain z min": -0.0002,
    "domain z max": 0.0002,
    "initial temperature": 1000.0,
    "do two phase": true
  },
  "heat": {
    "linear solver": {
      "rel tolerance": 1e-12,
      "preconditioner type": "ILU"
    },
    "nlsolve": {
      "residual tolerance": 1e-08
    }
  },
  "application specific": {
    "do two phase": true,
    "do convection": false,
    "do solidification": true
  },
  "laser": {
    "starting position": "0.0,0.0",
    "model": "interface_projection_regularized",
    "intensity profile": "Gauss",
    "power": 10,
    "absorptivity gas": 0.5,
    "absorptivity liquid": 0.5,
    "radius": 6e-05
  },
  "material": {
    "gas": {
      "thermal conductivity": 10,
      "specific heat capacity": 0,
      "density": 74.3
    },
    "liquid": {
      "thermal conductivity": 55.563,
      "specific heat capacity": 460.0,
      "density": 7850.0
    },
    "solid": {
      "thermal conductivity": 17.0,
      "specific heat capacity": 700.0,
      "density": 7850.0
    },
    "solidus temperature": 1966.0,
    "liquidus temperature": 1974.0
  },
  "output": {
    "directory": "output",
    "paraview": {
      "filename": "melt_front_propagation_static_surface_gauss",
      "enable": true
    }
  }
}
