{
  "base": {
    "case name": "melt_front_propagation",
    "dimension": 2,
    "do print parameters": false,
    "global refinements": 5,
    "verbosity level": 1,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "time step size": 0.0001,
    "end time": 0.015,
    "max n steps": 5
  },
  "simulation specific parameters": {
    "domain x min": 0.0,
    "domain x max": 0.0006,
    "domain z min": -0.0002,
    "domain z max": 0.0002,
    "initial temperature": 1000.0,
    "do two phase": true
  },
  "heat": {
