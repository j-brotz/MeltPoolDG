{
  "$schema": "../../../parameters.schema.json",
  "base": {
    "case name": "unidirectional_heat_transfer",
    "dimension": 2,
    "do print parameters": false,
    "global refinements": 4,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "time step size": 0.2,
    "end time": 10.0,
    "max n steps": 5
  },
  "heat": {
    "operator type": "cut",
    "cut": {
      "two phase": false,
      "stabilization": {
        "nitsche parameter": 500,
        "ghost-penalty": {
          "gamma A degree 1": 1.5,
          "gamma M degree 1": 0.75
        }
      }
    },
    "linear solver": {
      "preconditioner type": "Diagonal",
      "rel tolerance": 1e-12,
      "abs tolerance": 1e-10
    },
    "nlsolve": {
      "residual tolerance": 1e-09
    }
  },
  "simulation specific": {
    "do solidification": false,
    "do two phase": true
  },
  "application specific": {
    "do solidification": false
  },
  "material": {
    "liquid": {
      "thermal conductivity": 80.0,
      "specific heat capacity": 460,
      "density": 7850
    },
    "boiling temperature": 2000.0,
    "latent heat of evaporation": 100000.0,
    "molar mass": 0.05224130936,
    "specific enthalpy reference temperature": 1990.0
  },
  "evaporation": {
    "evaporative mass flux model": "recoil_pressure",
    "recoil pressure": {
      "type": "phenomenological",
      "temperature constant": 10000,
      "pressure coefficient": 0.0987166831194472,
      "enable": true,
      "sticking constant": 1
    },
    "evaporative cooling": {
      "enable": true,
      "consider enthalpy transport vapor mass flux": true
    }
  },
  "output": {
    "paraview": {
      "enable": false
    }
  }
}
