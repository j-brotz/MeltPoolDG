                        "pattern": "32",
                        "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                        "actions": "32"
                    },
                    "gamma M degree 2":
                    {
                        "value": "1",
                        "default_value": "1",
                        "documentation": "Mass matrix ghost-penalty parameter for degree 2.",
                        "pattern": "33",
                        "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                        "actions": "33"
                    },
                    "gamma A degree 0":
                    {
                        "value": "1",
                        "default_value": "1",
                        "documentation": "Stiffness matrix ghost-penalty parameter for degree 0.",
                        "pattern": "34",
                        "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                        "actions": "34"
