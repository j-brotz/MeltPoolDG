{
  "$schema": "../parameters.schema.json",
  "base": {
    "case name": "rotating_bubble",
    "dimension": 2,
    "global refinements": 6,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 1.5707963267948966,
    "time step size": 0.01
  },
  "output": {
    "paraview": {
      "print boundary id": true,
      "n patches": 3,
      "enable": true
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 5
        }
      }
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 0.5
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    }
  }
}
