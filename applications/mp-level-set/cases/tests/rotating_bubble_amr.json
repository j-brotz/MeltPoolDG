{
  "$schema": "../../parameters.schema.json",
  "base": {
    "case name": "rotating_bubble",
    "dimension": 2,
    "global refinements": 6,
    "do print parameters": false,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.05,
    "time step size": 0.01
  },
  "adaptive meshing": {
    "do amr": true,
    "upper perc to refine": 0.1,
    "lower perc to coarsen": 0.0,
    "max grid refinement level": 9
  },
  "output": {
    "paraview": {
      "filename": "solution_rotating_bubble",
      "enable": false
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "solver type": "CG",
        "preconditioner type": "Identity",
        "do matrix free": false
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 5
        }
      },
      "interface thickness parameter": {
        "type": "absolute_value",
        "val": 0.01
      }
    },
    "curvature": {
      "linear solver": {
        "do matrix free": false
      },
      "filter parameter": 4
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": false
      },
      "filter parameter": 0.5
    },
    "advection diffusion": {
      "linear solver": {
        "preconditioner type": "ILU",
        "do matrix free": false
      }
    }
  }
}
