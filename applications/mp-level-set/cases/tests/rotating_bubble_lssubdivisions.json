{
  "base": {
    "case name": "rotating_bubble",
    "dimension": 2,
    "global refinements": 6,
    "do print parameters": false,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.05,
    "time step size": 0.01
  },
  "output": {
    "paraview": {
      "enable": false
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "interface thickness parameter": {
          "type": "proportional_to_cell_size",
          "val": 2
        },
        "pseudo time stepping": {
          "max n steps": 2
        }
      }
    },
    "curvature": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 16
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 4
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    },
    "fe": {
      "type": "FE_Q_iso_Q1",
      "degree": 2
    }
  }
}
