{
  "$schema": "../parameters.schema.json",
  "base": {
    "case name": "vortex_bubble",
    "dimension": 2,
    "global refinements": 5,
    "do print parameters": false,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.05,
    "time step size": 0.01
  },
  "output": {
    "paraview": {
      "enable": false
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true,
        "solver type": "GMRES",
        "preconditioner type": "AMG"
      },
      "enable": true,
      "type": "elliptic",
      "elliptic": {
        "penalty parameter": 10000000000.0,
        "fixed point iteration": {
          "max n steps": 10,
          "tolerance": 1e-05
        }
      }
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 0.5
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    }
  }
}
