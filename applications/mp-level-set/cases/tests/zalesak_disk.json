{
  "$schema": "../../parameters.schema.json",
  "base": {
    "case name": "zalesak_disk",
    "dimension": 2,
    "global refinements": 5,
    "do print parameters": false,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.03,
    "time step size": 0.01
  },
  "output": {
    "paraview": {
      "enable": false
    }
  },
  "level set": {
    "reinitialization": {
      "enable": true,
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 2
        }
      },
      "interface thickness parameter": {
        "type": "proportional_to_cell_size",
        "val": 1
      }
    },
    "curvature": {
      "filter parameter": 0.0
    },
    "normal vector": {
      "filter parameter": 2
    }
  }
}
