{
  "$schema": "../parameters.schema.json",
  "base": {
    "case name": "zalesak_disk",
    "dimension": 2,
    "global refinements": 8,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 1,
    "time step size": 0.01
  },
  "output": {
    "directory": "output",
    "paraview": {
      "enable": true
    }
  },
  "level set": {
    "reinitialization": {
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 5
        }
      },
      "interface thickness parameter": {
        "type": "proportional_to_cell_size",
        "val": 1
      }
    },
    "curvature": {
      "filter parameter": 0.0
    },
    "normal vector": {
      "filter parameter": 0.5
    }
  }
}
