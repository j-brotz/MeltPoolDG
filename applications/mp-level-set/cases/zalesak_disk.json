{
  "$schema": "../parameters.schema.json",
  "base": {
    "case name": "zalesak_disk",
    "dimension": 2,
    "global refinements": 8,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 1,
    "time step size": 0.01
  },
  "output": {
    "directory": "output",
    "paraview": {
      "enable": true
    }
  },
  "level set": {
    "reinitialization": {
      "reinit constant epsilon": -1,
      "reinit scale factor epsilon": 2,
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 5
        }
      }
    },
    "normal vector": {
      "filter parameter": 0.5
    }
  }
}
