{
  "$schema": "../../parameters.schema.json",
  "base": {
    "case name": "evaporating_droplet",
    "global refinements": 4,
    "dimension": 2,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 1.0,
    "time step size": 0.005
  },
  "material": {
    "gas": {
      "density": 0.01,
      "dynamic viscosity": 0.001
    },
    "liquid": {
      "density": 1,
      "dynamic viscosity": 0.01
    },
    "two phase fluid properties transition type": "consistent_with_evaporation"
  },
  "evaporation": {
    "analytical": {
      "function": 0.001
    },
    "evaporative cooling": {
      "enable": false
    },
    "evaporative dilation rate": {
      "enable": true
    }
  },
  "application specific": {
    "do heat transfer": true
  },
  "output": {
    "paraview": {
      "enable": true
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 10
        }
      },
      "interface thickness parameter": {
        "type": "proportional_to_cell_size",
        "val": 1.707
      }
    },
    "curvature": {
      "linear solver": {
        "do matrix free": true
      }
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": true
      },
      "implementation": "adaflo"
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "formulation convective term momentum balance": "convective",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin max iterations": 30,
          "lin tolerance": 0.0001,
          "lin velocity preconditioner": "ilu",
          "lin its before inner solvers": 50
        }
      },
      "Output options": {
        "output verbosity": 1,
        "output walltimes": 0
      },
      "Time stepping": {
        "scheme": "bdf_2"
      }
    },
    "gravity": 0.0,
    "surface tension": {
      "surface tension coefficient": 0.0
    }
  }
}
