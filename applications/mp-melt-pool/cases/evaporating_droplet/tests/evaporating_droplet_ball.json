{
  "$schema": "../../../parameters.schema.json",
  "base": {
    "case name": "evaporating_droplet",
    "global refinements": 5,
    "dimension": 2,
    "do print parameters": false,
    "fe": {
      "degree": 1
    }
  },
  "simulation specific": {
    "domain length": 0.0001,
    "droplet radius": 2e-05,
    "domain type": "ball"
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.005,
    "time step size": 0.001
  },
  "material": {
    "material template": "Ti64",
    "two phase fluid properties transition type": "consistent_with_evaporation"
  },
  "evaporation": {
    "analytical": {
      "function": 1e-06
    },
    "evaporative cooling": {
      "enable": false
    },
    "evaporative dilation rate": {
      "enable": true
    }
  },
  "application specific": {
    "do heat transfer": true
  },
  "output": {
    "paraview": {
      "enable": false
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 2
        }
      },
      "interface thickness parameter": {
        "type": "proportional_to_cell_size",
        "val": 1.0
      }
    },
    "curvature": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 5
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 4
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "formulation convective term momentum balance": "convective",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin max iterations": 30,
          "lin tolerance": 0.0001,
          "lin velocity preconditioner": "ilu",
          "lin its before inner solvers": 50
        }
      },
      "Output options": {
        "output verbosity": 0,
        "output wall times": false
      },
      "Time stepping": {
        "scheme": "bdf_2"
      }
    },
    "gravity": 0.0,
    "surface tension": {
      "surface tension coefficient": 0.0
    }
  }
}
