{
  "base": {
    "case name": "evaporating_droplet_with_heat",
    "global refinements": 3,
    "dimension": 2,
    "verbosity level": 1,
    "do print parameters": false,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.03,
    "time step size": 0.001
  },
  "material": {
    "gas": {
      "thermal conductivity": 1,
      "specific heat capacity": 200,
      "density": 5,
      "dynamic viscosity": 0.005
    },
    "liquid": {
      "thermal conductivity": 40,
      "specific heat capacity": 400,
      "density": 200,
      "dynamic viscosity": 0.1
    },
    "boiling temperature": 1,
    "latent heat of evaporation": 1000.0,
    "molar mass": 0.01801528,
    "two phase fluid properties transition type": "consistent_with_evaporation"
  },
  "heat": {
    "linear solver": {
      "rel tolerance": 1e-12,
      "preconditioner type": "AMG"
    },
    "nlsolve": {
      "max nonlinear iterations": 15,
      "field correction tolerance": 1e-07,
      "residual tolerance": 1e-06
    }
  },
  "evaporation": {
    "analytical": {
      "function": 0.0
    },
    "evaporative mass flux model": "hardt_wondra",
    "hardt wondra": {
      "coefficient": 0.01
    },
    "formulation source term level set": "interface_velocity_sharp",
    "evaporative cooling": {
      "enable": true
    },
    "evaporative dilation rate": {
      "enable": true
    }
  },
  "application specific": {
    "do heat transfer": true
  },
  "output": {
    "paraview": {
      "enable": false
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 2
        }
      },
      "interface thickness parameter": {
        "type": "proportional_to_cell_size",
        "val": 1.707
      }
    },
    "curvature": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 4
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 4
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "formulation convective term momentum balance": "convective",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin max iterations": 30,
          "lin tolerance": 0.0001,
          "lin velocity preconditioner": "ilu",
          "lin its before inner solvers": 50
        }
      },
      "Output options": {
        "output verbosity": 0,
        "output walltimes": 0
      },
      "Time stepping": {
        "scheme": "bdf_2"
      }
    },
    "gravity": 0.0,
    "surface tension": {
      "surface tension coefficient": 0.1
    }
  }
}
