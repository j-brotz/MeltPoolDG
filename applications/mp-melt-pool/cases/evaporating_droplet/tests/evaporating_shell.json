{
  "$schema": "../../../parameters.schema.json",
  "base": {
    "case name": "evaporating_shell",
    "global refinements": 4,
    "dimension": 2,
    "do print parameters": false,
    "verbosity level": 1,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.01,
    "time step size": 0.0001,
    "max n steps": 10
  },
  "material": {
    "gas": {
      "density": 1.0,
      "dynamic viscosity": 0.001
    }
  },
  "case specific": {
    "velocity": 0.001
  },
  "application specific": {
    "do heat transfer": false
  },
  "output": {
    "do user defined postprocessing": true,
    "paraview": {
      "enable": false
    }
  },
  "evaporation": {
    "evaporative dilation rate": {
      "enable": false
    }
  },
  "level set": {
    "curvature": {
      "verbosity level": 2
    },
    "normal vector": {
      "verbosity level": 2
    },
    "reinitialization": {
      "enable": false
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "formulation convective term momentum balance": "convective",
        "constitutive type": "newtonian incompressible",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-12,
          "lin max iterations": 30,
          "lin tolerance": 1e-05,
          "lin velocity preconditioner": "ilu",
          "lin its before inner solvers": 50
        }
      },
      "Output options": {
        "output verbosity": 0,
        "output wall times": false
      },
      "Time stepping": {
        "scheme": "bdf_2"
      }
    },
    "gravity": 0.0
  }
}
