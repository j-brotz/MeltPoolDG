{
  "$schema": "../../parameters.schema.json",
  "base": {
    "case name": "flow_past_cylinder",
    "dimension": 2,
    "fe": {
      "degree": 2
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 2.0,
    "time step size": 0.02
  },
  "output": {
    "directory": "output_flow_past_cylinder",
    "write frequency": 1,
    "output variables": "all",
    "paraview": {
      "enable": true
    }
  },
  "material": {
    "gas": {
      "density": 0.005,
      "dynamic viscosity": 0.001
    },
    "liquid": {
      "density": 0.005,
      "dynamic viscosity": 0.001
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 5
        }
      }
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin max iterations": 30,
          "lin tolerance": 1e-05,
          "lin relative tolerance": true,
          "lin velocity preconditioner": "ilu scalar",
          "lin pressure mass preconditioner": "ilu",
          "lin its before inner solvers": 30
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      }
    },
    "surface tension": {
      "surface tension coefficient": 0.01
    }
  }
}
