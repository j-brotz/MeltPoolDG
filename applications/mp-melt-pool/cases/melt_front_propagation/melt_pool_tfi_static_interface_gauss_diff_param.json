{
  "$schema": "../../parameters.schema.json",
  "base": {
    "case name": "melt_front_propagation",
    "dimension": 2,
    "do print parameters": false,
    "global refinements": 5,
    "verbosity level": 2,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "time step size": 1e-05,
    "end time": 0.015,
    "max n steps": 20
  },
  "laser": {
    "starting position": "0.0,0.0",
    "model": "interface_projection_regularized",
    "intensity profile": "Gauss",
    "power": 10,
    "power end time": 0.0001,
    "absorptivity gas": 0.5,
    "absorptivity liquid": 0.5,
    "radius": 6e-05
  },
  "case specific": {
    "domain x min": 0.0,
    "domain x max": 0.0006,
    "domain z min": -0.0002,
    "domain z max": 0.0002,
    "initial temperature": 0.0
  },
  "melt front propagation": {
    "set velocity to zero in solid": false
  },
  "material": {
    "gas": {
      "thermal conductivity": 10,
      "specific heat capacity": 0,
      "density": 100,
      "dynamic viscosity": 0.001
    },
    "liquid": {
      "thermal conductivity": 50,
      "specific heat capacity": 500.0,
      "density": 1000.0,
      "dynamic viscosity": 0.01
    },
    "solid": {
      "thermal conductivity": 20.0,
      "specific heat capacity": 700.0,
      "density": 1100.0,
      "dynamic viscosity": 0.1
    },
    "solidus temperature": 100.0,
    "liquidus temperature": 200.0,
    "two phase fluid properties transition type": "smooth"
  },
  "heat": {
    "linear solver": {
      "rel tolerance": 1e-12,
      "preconditioner type": "ILU"
    },
    "nlsolve": {
      "residual tolerance": 1e-08
    }
  },
  "application specific": {
    "do heat transfer": true,
    "do solidification": true
  },
  "output": {
    "directory": "output",
    "paraview": {
      "filename": "melt_pool_tfi_static_interface_gauss_diff_param",
      "enable": true
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 2
        }
      },
      "interface thickness parameter": {
        "type": "proportional_to_cell_size",
        "val": 1.5
      }
    },
    "curvature": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 0.5
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 0.5
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin max iterations": 30,
          "lin tolerance": 0.0001,
          "lin relative tolerance": true,
          "lin velocity preconditioner": "ilu scalar",
          "lin pressure mass preconditioner": "ilu",
          "lin its before inner solvers": 50
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": 0,
        "output wall times": false
      }
    }
  }
}
