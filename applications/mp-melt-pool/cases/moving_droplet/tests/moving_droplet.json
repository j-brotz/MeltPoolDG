{
  "$schema": "../../../parameters.schema.json",
  "base": {
    "case name": "moving_droplet",
    "dimension": 2,
    "do print parameters": false,
    "global refinements": 6,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 1.0,
    "time step size": 1e-05,
    "max n steps": 3
  },
  "material": {
    "gas": {
      "density": 10,
      "dynamic viscosity": 1e-06
    },
    "liquid": {
      "density": 1000,
      "dynamic viscosity": 0.0001
    },
    "two phase fluid properties transition type": "smooth"
  },
  "adaptive meshing": {
    "do amr": false,
    "do not modify boundary cells": false,
    "upper perc to refine": 0.2,
    "lower perc to coarsen": 0.2,
    "max grid refinement level": 7,
    "n initial refinement cycles": 5
  },
  "application specific": {
    "amr": {
      "strategy": "adaflo",
      "do refine all interface cells": true,
      "do auto detect frequency": true,
      "automatic grid refinement type": "fixed_fraction"
    }
  },
  "simulation specific": {
    "radius": 0.25,
    "side length": 2.0,
    "velocity": 0.01
  },
  "output": {
    "paraview": {
      "enable": false
    }
  },
  "level set": {
    "reinitialization": {
      "enable": true,
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 5,
          "tolerance": 0.01
        }
      },
      "interface thickness parameter": {
        "type": "absolute_value",
        "val": 0.02
      }
    },
    "curvature": {
      "verbosity level": 2
    },
    "normal vector": {
      "filter parameter": 4
    },
    "fe": {
      "type": "FE_Q_iso_Q1",
      "degree": 2
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-10,
          "lin max iterations": 30,
          "lin tolerance": 0.0001,
          "lin relative tolerance": 1,
          "lin velocity preconditioner": "ilu",
          "lin its before inner solvers": 50
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": 0,
        "output walltimes": 0
      }
    },
    "gravity": 0.0
  }
}
