{
  "$schema": "../../../parameters.schema.json",
  "base": {
    "case name": "oscillating_droplet",
    "dimension": 2,
    "do print parameters": false,
    "global refinements": 6,
    "fe": {
      "degree": 1
    }
  },
  "simulation specific parameters": {
    "side length": 0.0004,
    "reference radius": 0.0001,
    "elliptical deviation": 1.5
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.0006,
    "time step size": 5e-08,
    "max n steps": 2
  },
  "material": {
    "gas": {
      "density": 7.43,
      "dynamic viscosity": 6e-06
    },
    "liquid": {
      "density": 7430,
      "dynamic viscosity": 0.006
    },
    "two phase fluid properties transition type": "smooth"
  },
  "application specific": {
    "do heat transfer": false,
    "do solidification": false
  },
  "output": {
    "paraview": {
      "enable": false
    }
  },
  "evaporation": {
    "recoil pressure": {
      "enable": false
    }
  },
  "level set": {
    "nearest point": {
      "narrow band threshold": 2e-05
    },
    "reinitialization": {
      "enable": true,
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 5
        }
      },
      "interface thickness parameter": {
        "type": "proportional_to_cell_size",
        "val": 1.5
      }
    },
    "curvature": {
      "filter parameter": 8,
      "verbosity level": 0,
      "do curvature correction": true
    },
    "normal vector": {
      "filter parameter": 4
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-10,
          "lin max iterations": 30,
          "lin tolerance": 1e-10,
          "lin relative tolerance": true,
          "lin velocity preconditioner": "ilu scalar",
          "lin pressure mass preconditioner": "ilu",
          "lin its before inner solvers": 50
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": 0,
        "output wall times": false
      }
    },
    "gravity": 0.0,
    "surface tension": {
      "surface tension coefficient": 1.8
    }
  }
}
