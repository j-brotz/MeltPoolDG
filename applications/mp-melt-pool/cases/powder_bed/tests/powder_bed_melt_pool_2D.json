{
  "base": {
    "case name": "powder_bed",
    "dimension": 2,
    "do print parameters": false,
    "global refinements": 3,
    "verbosity level": 1,
    "fe": {
      "degree": 1
    }
  },
  "simulation specific parameters": {
    "domain x min": -0.0001,
    "domain x max": 0.0001,
    "domain y min": -5e-05,
    "domain y max": 0.0001,
    "cell repetitions": "4,3",
    "initial temperature": 500.0,
    "powder bed": {
      "particle list file": "applications/mp-heat-transfer/cases/powder_bed/particles_in_domain.csv",
      "substrate level": 0.0,
      "slice location": 5e-05
    }
  },
  "application specific": {
    "do heat transfer": true,
    "do solidification": false,
    "amr": {
      "strategy": "generic"
    }
  },
  "adaptive meshing": {
    "do amr": true,
    "max grid refinement level": 5,
    "upper perc to refine": 0.4,
    "lower perc to coarsen": 0.1,
    "every n step": 10,
    "n initial refinement cycles": 3
  },
  "time stepping": {
    "max n steps": 2,
    "time step size": 1e-06
  },
  "heat": {
    "operator type": "cut",
    "cut": {
      "two phase": false,
      "stabilization": {
        "nitsche parameter": 50,
        "ghost-penalty": {
          "gamma A degree 1": 1.5,
          "gamma M degree 1": 0.75
        }
      }
    }
  },
  "laser": {
    "starting position": "0.0,0.0",
    "model": "interface_projection_sharp",
    "intensity profile": "Gauss",
    "power": 100,
    "radius": 7e-05
  },
  "evaporation": {
    "evaporative mass flux model": "saturated_vapor_pressure",
    "evaporative cooling": {
      "enable": true
    },
    "recoil pressure": {
      "enable": true,
      "type": "phenomenological",
      "interface distributed flux type": "interface_value",
      "pressure coefficient": 0.54,
      "temperature constant": 50700.0,
      "ambient gas pressure": 100000.0,
      "dirac delta function approximation": {
        "auto weights": true,
        "type": "heaviside_phase_weighted"
      }
    }
  },
  "material": {
    "material template": "Ti64",
    "gas": {
      "density": 4.087
    },
    "two phase fluid properties transition type": "smooth"
  },
  "flow": {
    "surface tension": {
      "interface temperature evaluation type": "interface_value",
      "surface tension coefficient": 1.493
    },
    "adaflo": {
      "Navier-Stokes": {
        "Solver": {
          "NL max iterations": 15,
          "NL tolerance": 1e-08,
          "lin its before inner solvers": 50,
          "lin max iterations": 50,
          "lin pressure mass preconditioner": "ilu",
          "lin relative tolerance": 1,
          "lin tolerance": 0.0001,
          "lin velocity preconditioner": "ilu scalar",
          "linearization scheme": "coupled implicit Newton"
        },
        "dimension": 2,
        "formulation convective term momentum balance": "convective",
        "global refinements": 0,
        "physical type": "incompressible",
        "velocity degree": 2
      },
      "Output options": {
        "output verbosity": 0,
        "output walltimes": 0
      },
      "Time stepping": {
        "scheme": "bdf_2"
      }
    }
  },
  "level set": {
    "reinitialization": {
      "hyperbolic": {
        "interface thickness parameter": {
          "type": "absolute_value",
          "val": 1e-05
        },
        "pseudo time stepping": {
          "n initial steps": 1,
          "max n steps": 0
        }
      }
    },
    "nearest point": {
      "type": "nearest_point"
    }
  },
  "output": {
    "paraview": {
      "enable": false
    }
  }
}
