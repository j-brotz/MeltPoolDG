{
  "$schema": "../../parameters.schema.json",
  "base": {
    "case name": "recoil_pressure",
    "global refinements": 5,
    "dimension": 2,
    "do print parameters": true,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.0006,
    "time step size": 1e-06
  },
  "material": {
    "gas": {
      "thermal conductivity": 10,
      "specific heat capacity": 0,
      "density": 74.3,
      "dynamic viscosity": 0.0006
    },
    "liquid": {
      "thermal conductivity": 35.95,
      "specific heat capacity": 965,
      "density": 7074.3,
      "dynamic viscosity": 0.006
    },
    "boiling temperature": 3000
  },
  "laser": {
    "starting position": "0.0,0.00004",
    "absorptivity liquid": 0.5,
    "absorptivity gas": 0,
    "analytical": {
      "ambient temperature": 300
    },
    "model": "analytical_temperature",
    "power": 10,
    "scan speed": 0.003
  },
  "case specific": {
    "domain x min": -0.0002,
    "domain x max": 0.0002,
    "domain y min": -0.0001,
    "domain y max": 0.0002
  },
  "application specific": {
    "do heat transfer": true,
    "do solidification": true
  },
  "output": {
    "write frequency": 1,
    "paraview": {
      "filename": "solution_recoil_pressure",
      "enable": true
    }
  },
  "evaporation": {
    "recoil pressure": {
      "temperature constant": 10000,
      "pressure coefficient": 0.0987166831194472
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 10
        }
      },
      "interface thickness parameter": {
        "type": "proportional_to_cell_size",
        "val": 0.7107
      }
    },
    "curvature": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 0.5
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 0.5
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin max iterations": 30,
          "lin tolerance": 0.0001,
          "lin relative tolerance": true,
          "lin velocity preconditioner": "ilu scalar",
          "lin pressure mass preconditioner": "ilu",
          "lin its before inner solvers": 50
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": 2,
        "output wall times": false
      }
    },
    "gravity": 0.0,
    "surface tension": {
      "surface tension coefficient": 1.8
    }
  }
}
