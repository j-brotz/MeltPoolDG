{
  "$schema": "../../../parameters.schema.json",
  "base": {
    "case name": "recoil_pressure",
    "dimension": 2,
    "do print parameters": false,
    "global refinements": 4,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "end time": 2e-06,
    "start time": 0.0,
    "time step size": 1e-06
  },
  "material": {
    "material template": "stainless_steel",
    "gas": {
      "specific heat capacity": 0
    },
    "two phase fluid properties transition type": "sharp"
  },
  "laser": {
    "starting position": "0.0,0.00004",
    "analytical": {
      "ambient temperature": 500,
      "max temperature": 3500,
      "temperature x to y ratio": 3
    },
    "absorptivity liquid": 0.5,
    "absorptivity gas": 0,
    "model": "analytical_temperature",
    "power": 75,
    "scan speed": 0.003
  },
  "case specific": {
    "domain x min": -0.0002,
    "domain x max": 0.0002,
    "domain y min": -0.0001,
    "domain y max": 0.0002
  },
  "application specific": {
    "do heat transfer": true,
    "do solidification": true
  },
  "output": {
    "paraview": {
      "enable": false
    }
  },
  "evaporation": {
    "recoil pressure": {
      "temperature constant": 10000,
      "pressure coefficient": 0.0987166831194472,
      "enable": true
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 2
        }
      },
      "interface thickness parameter": {
        "type": "proportional_to_cell_size",
        "val": 0.7107
      }
    },
    "curvature": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 4
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 2
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "Solver": {
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin its before inner solvers": 30,
          "lin max iterations": 30,
          "lin tolerance": 1e-05,
          "lin velocity preconditioner": "ilu",
          "linearization scheme": "coupled implicit Newton"
        },
        "dimension": 2,
        "global refinements": 0,
        "physical type": "incompressible",
        "velocity degree": 2
      },
      "Output options": {
        "output verbosity": 0,
        "output wall times": false
      },
      "Time stepping": {
        "scheme": "bdf_2"
      }
    },
    "gravity": 0.981,
    "surface tension": {
      "surface tension coefficient": 1.8,
      "reference temperature": 1700
    }
  }
}
