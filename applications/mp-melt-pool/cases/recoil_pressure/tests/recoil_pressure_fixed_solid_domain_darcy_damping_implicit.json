{
  "$schema": "../../../parameters.schema.json",
  "base": {
    "case name": "recoil_pressure",
    "dimension": 2,
    "do print parameters": false,
    "global refinements": 5,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "end time": 5e-06,
    "start time": 0.0,
    "time step size": "5.e-7"
  },
  "material": {
    "gas": {
      "thermal conductivity": 10,
      "specific heat capacity": 0,
      "density": 74.3,
      "dynamic viscosity": 0.0006
    },
    "liquid": {
      "thermal conductivity": 35.95,
      "specific heat capacity": 965,
      "density": 7430.0,
      "dynamic viscosity": 0.006
    },
    "solid": {
      "thermal conductivity": 35.95,
      "specific heat capacity": 965,
      "density": 7430.0,
      "dynamic viscosity": 0.6
    },
    "solidus temperature": 1200,
    "liquidus temperature": 1700.0,
    "boiling temperature": 3000,
    "two phase fluid properties transition type": "sharp",
    "solid liquid properties transition type": "mushy_zone"
  },
  "laser": {
    "starting position": "0.0,0.00000",
    "absorptivity liquid": 0.5,
    "absorptivity gas": 0,
    "analytical": {
      "max temperature": 3500,
      "ambient temperature": 500,
      "temperature x to y ratio": 3
    },
    "model": "analytical_temperature",
    "power": 75,
    "power over time": "constant",
    "power start time": -0.0001,
    "power end time": 1e-05,
    "scan speed": 0.003
  },
  "melt front propagation": {
    "do not reinitialize in solid": false,
    "set velocity to zero in solid": true
  },
  "simulation specific domain": {
    "domain x max": 0.0001,
    "domain x min": -0.0001,
    "domain y max": 0.0001,
    "domain y min": -7.5e-05
  },
  "application specific": {
    "do heat transfer": true,
    "do solidification": true
  },
  "output": {
    "paraview": {
      "enable": false
    }
  },
  "evaporation": {
    "recoil pressure": {
      "temperature constant": 10000,
      "pressure coefficient": 0.0987166831194472,
      "enable": true
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 2
        }
      },
      "interface thickness parameter": {
        "type": "proportional_to_cell_size",
        "val": 0.7107
      }
    },
    "curvature": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 4
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 4
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "Solver": {
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin its before inner solvers": 50,
          "lin max iterations": 30,
          "lin tolerance": 1e-05,
          "lin velocity preconditioner": "ilu",
          "linearization scheme": "coupled implicit Newton"
        },
        "dimension": 2,
        "global refinements": 0,
        "physical type": "incompressible",
        "velocity degree": 2
      },
      "Output options": {
        "output verbosity": 0,
        "output wall times": false
      },
      "Time stepping": {
        "scheme": "bdf_2"
      }
    },
    "gravity": 0.981,
    "darcy damping": {
      "mushy zone morphology": 100000000.0,
      "avoid div zero constant": 0.001,
      "formulation": "implicit_formulation"
    },
    "surface tension": {
      "surface tension coefficient": 1.8,
      "reference temperature": 1700
    }
  }
}
