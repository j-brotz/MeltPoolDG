{
  "base": {
    "case name": "recoil_pressure",
    "dimension": 2,
    "do print parameters": false,
    "global refinements": 0,
    "verbosity level": 1,
    "fe": {
      "degree": 1
    }
  },
  "simulation specific domain": {
    "domain x max": 1e-05,
    "domain x min": -1e-05,
    "domain y max": 0.0001,
    "domain y min": -0.0001,
    "cell repetitions": "5,50",
    "evaporation boundary": true,
    "periodic boundary": false
  },
  "application specific": {
    "do heat transfer": true,
    "do solidification": false,
    "do advect level set": true,
    "mp heat up": {
      "time step size": 1e-06,
      "max temperature": 700.0
    }
  },
  "time stepping": {
    "start time": 0.0,
    "time step size": 1e-09,
    "max n steps": 4
  },
  "material": {
    "material template": "Ti64",
    "boiling temperature": 700.0,
    "latent heat of evaporation": 1000000.0,
    "two phase fluid properties transition type": "consistent_with_evaporation"
  },
  "heat": {
    "operator type": "cut",
    "cut": {
      "two phase": true,
      "theta": 0.5,
      "do explicit symmetry term": true,
      "stabilization": {
        "nitsche parameter": 500,
        "ghost-penalty": {
          "gamma A degree 1": 1.5,
          "gamma M degree 1": 0.75
        }
      }
    },
    "linear solver": {
      "abs tolerance": 1e-12,
      "rel tolerance": 1e-12,
      "preconditioner type": "Diagonal"
    },
    "nlsolve": {
      "max nonlinear iterations": 10,
      "field correction tolerance": 1e-10,
      "residual tolerance": 1e-10
    }
  },
  "laser": {
    "model": "interface_projection_sharp",
    "intensity profile": "Gauss",
    "power": 1,
    "radius": 0.00012
  },
  "evaporation": {
    "interface temperature evaluation type": "interface_value",
    "formulation source term level set": "interface_velocity_sharp_heavy",
    "evaporative mass flux model": "saturated_vapor_pressure",
    "recoil pressure": {
      "enable": true,
      "interface distributed flux type": "interface_value",
      "type": "hybrid"
    },
    "evaporative cooling": {
      "enable": true,
      "interface temperature evaluation type": "interface_value"
    },
    "evaporative dilation rate": {
      "enable": true
    }
  },
  "output": {
    "paraview": {
      "enable": false
    }
  },
  "level set": {
    "nearest point": {
      "type": "nearest_point"
    },
    "advection diffusion": {
      "linear solver": {
        "abs tolerance": 1e-12,
        "rel tolerance": 1e-12
      }
    },
    "reinitialization": {
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "n initial steps": 0,
          "max n steps": 5
        },
        "Continuous Galerkin": {
          "implementation": "adaflo"
        }
      },
      "interface thickness parameter": {
        "type": "proportional_to_cell_size",
        "val": 2
      }
    },
    "curvature": {
      "filter parameter": 2,
      "do curvature correction": false
    },
    "normal vector": {
      "filter parameter": 2
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "Solver": {
          "NL max iterations": 15,
          "NL tolerance": 1e-08,
          "lin its before inner solvers": 50,
          "lin max iterations": 30,
          "lin pressure mass preconditioner": "ilu",
          "lin relative tolerance": 1,
          "lin tolerance": 0.0001,
          "lin velocity preconditioner": "ilu scalar",
          "linearization scheme": "coupled implicit Newton"
        },
        "dimension": 2,
        "formulation convective term momentum balance": "convective",
        "global refinements": 0,
        "physical type": "incompressible",
        "velocity degree": 2
      },
      "Output options": {
        "output verbosity": 0,
        "output walltimes": 0
      },
      "Time stepping": {
        "scheme": "bdf_2"
      }
    },
    "gravity": 0.0,
    "surface tension": {
      "surface tension coefficient": 0
    }
  }
}
