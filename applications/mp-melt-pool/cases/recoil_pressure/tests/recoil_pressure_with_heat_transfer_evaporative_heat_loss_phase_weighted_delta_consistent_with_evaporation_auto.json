{
  "base": {
    "case name": "recoil_pressure",
    "global refinements": 5,
    "dimension": 2,
    "do print parameters": false,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.0006,
    "time step size": 1e-06,
    "max n steps": 30
  },
  "material": {
    "material template": "Ti64",
    "two phase fluid properties transition type": "consistent_with_evaporation"
  },
  "evaporation": {
    "evaporative mass flux model": "recoil_pressure",
    "recoil pressure": {
      "dirac delta function approximation": {
        "type": "reciprocal_phase_weighted",
        "auto weights": true
      },
      "temperature constant": 10000,
      "pressure coefficient": 0.0987166831194472,
      "enable": true
    },
    "evaporative cooling": {
      "enable": true,
      "dirac delta function approximation": {
        "type": "reciprocal_times_heaviside_phase_weighted",
        "auto weights": true
      }
    },
    "evaporative dilation rate": {
      "enable": false
    }
  },
  "laser": {
    "starting position": "0.0,0.00000",
    "dirac delta function approximation": {
      "type": "reciprocal_times_heaviside_phase_weighted",
      "auto weights": true
    },
    "model": "interface_projection_regularized",
    "intensity profile": "Gauss",
    "power": 156,
    "absorptivity gas": 0.25,
    "absorptivity liquid": 0.25,
    "radius": "70.e-6"
  },
  "melt front propagation": {
    "do not reinitialize in solid": false,
    "set velocity to zero in solid": true
  },
  "simulation specific domain": {
    "domain x min": -0.0002,
    "domain x max": 0.0002,
    "domain y min": -0.0001,
    "domain y max": 0.0002,
    "evaporation boundary": true
  },
  "heat": {
    "linear solver": {
      "rel tolerance": 0.0001,
      "preconditioner type": "Diagonal"
    },
    "nlsolve": {
      "max nonlinear iterations": 20,
      "field correction tolerance": 1e-05,
      "residual tolerance": 1e-07
    }
  },
  "application specific": {
    "do heat transfer": true,
    "do solidification": true
  },
  "output": {
    "paraview": {
      "enable": false
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 10
        }
      },
      "interface thickness parameter": {
        "type": "proportional_to_cell_size",
        "val": 1.5
      }
    },
    "curvature": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 0.5
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 0.5
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "formulation convective term momentum balance": "convective",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin max iterations": 30,
          "lin tolerance": 0.0001,
          "lin relative tolerance": 1,
          "lin velocity preconditioner": "ilu scalar",
          "lin pressure mass preconditioner": "ilu",
          "lin its before inner solvers": 50
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": 0,
        "output walltimes": 0
      }
    },
    "gravity": 0.0,
    "surface tension": {
      "surface tension coefficient": 1.8,
      "dirac delta function approximation": {
        "type": "reciprocal_phase_weighted",
        "auto weights": true
      }
    }
  }
}
