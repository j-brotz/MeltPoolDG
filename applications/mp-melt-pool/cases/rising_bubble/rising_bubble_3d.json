{
  "$schema": "../../parameters.schema.json",
  "base": {
    "case name": "rising_bubble",
    "global refinements": 2,
    "dimension": 3,
    "fe": {
      "degree": 2
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 1.0,
    "time step size": 0.02
  },
  "material": {
    "gas": {
      "density": 1,
      "dynamic viscosity": 0.01
    },
    "liquid": {
      "density": 0.1,
      "dynamic viscosity": 0.001
    }
  },
  "Time stepping": {
    "scheme": "bdf_2"
  },
  "output": {
    "paraview": {
      "enable": true
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 5
        }
      },
      "interface thickness parameter": {
        "type": "proportional_to_cell_size",
        "val": 0.7107
      }
    },
    "curvature": {
      "linear solver": {
        "do matrix free": true
      }
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 0.025
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "viscosity": 0.01,
        "density": 1,
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin max iterations": 30,
          "lin tolerance": 0.0001,
          "lin relative tolerance": true,
          "lin velocity preconditioner": "ilu scalar",
          "lin pressure mass preconditioner": "ilu",
          "lin its before inner solvers": 50
        }
      },
      "Output options": {
        "output verbosity": 2,
        "output wall times": false
      }
    },
    "gravity": 0.98,
    "surface tension": {
      "surface tension coefficient": 0.0245
    }
  }
}
