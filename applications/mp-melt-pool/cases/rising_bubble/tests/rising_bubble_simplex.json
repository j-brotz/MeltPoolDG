{
  "$schema": "../../../parameters.schema.json",
  "base": {
    "case name": "rising_bubble",
    "do print parameters": false,
    "global refinements": 3,
    "dimension": 2,
    "verbosity level": 0,
    "fe": {
      "type": "FE_SimplexP",
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "time step size": 0.02,
    "max n steps": 4
  },
  "material": {
    "gas": {
      "density": 1,
      "dynamic viscosity": 0.04
    },
    "liquid": {
      "density": 0.5,
      "dynamic viscosity": 0.02
    },
    "two phase fluid properties transition type": "smooth"
  },
  "output": {
    "paraview": {
      "enable": false
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": false,
        "preconditioner type": "AMG"
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 2
        }
      },
      "interface thickness parameter": {
        "type": "proportional_to_cell_size",
        "val": 2.0
      }
    },
    "curvature": {
      "filter parameter": 2.0,
      "linear solver": {
        "do matrix free": false
      }
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": false
      },
      "filter parameter": 2.0
    },
    "advection diffusion": {
      "linear solver": {
        "preconditioner type": "ILU",
        "do matrix free": false
      }
    }
  },
  "flow": {
    "adaflo": {
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin max iterations": 30,
          "lin tolerance": 1e-05,
          "lin velocity preconditioner": "ilu",
          "lin its before inner solvers": 30
        }
      },
      "Output options": {
        "output verbosity": 0,
        "output wall times": 0
      }
    },
    "gravity": 0.98,
    "surface tension": {
      "surface tension coefficient": 0.00245
    }
  }
}
