{
  "$schema": "../../parameters.schema.json",
  "base": {
    "case name": "spurious_currents",
    "dimension": 2,
    "global refinements": 7,
    "fe": {
      "degree": 1
    }
  },
  "simulation specific parameters": {
    "droplet shape": "circle"
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.3,
    "time step size": 0.01
  },
  "material": {
    "gas": {
      "density": 1.0,
      "dynamic viscosity": 0.1
    },
    "liquid": {
      "density": 1.0,
      "dynamic viscosity": 0.2
    }
  },
  "output": {
    "directory": "output_circle",
    "paraview": {
      "filename": "sol_spurious_currents",
      "enable": true
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 2
        },
        "Continuous Galerkin": {
          "implementation": "meltpooldg"
        }
      }
    },
    "curvature": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 1.22,
      "implementation": "meltpooldg"
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 4,
      "implementation": "meltpooldg"
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      },
      "implementation": "meltpooldg"
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin max iterations": 30,
          "lin tolerance": 0.0001,
          "lin relative tolerance": true,
          "lin velocity preconditioner": "ilu scalar",
          "lin pressure mass preconditioner": "ilu",
          "lin its before inner solvers": 50
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": 2,
        "output wall times": false
      }
    },
    "gravity": 0.0,
    "surface tension": {
      "surface tension coefficient": 1.0
    }
  }
}
