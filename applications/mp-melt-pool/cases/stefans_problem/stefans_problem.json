{
  "base": {
    "case name": "stefans_problem",
    "dimension": 2,
    "global refinements": 7,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 1.5707963267948966,
    "time step size": 0.002
  },
  "adaptive meshing": {
    "do amr": true,
    "do not modify boundary cells": false,
    "upper perc to refine": 0.1,
    "lower perc to coarsen": 0.1,
    "n initial refinement cycles": 3,
    "max grid refinement level": 7,
    "every n step": 1
  },
  "evaporation": {
    "analytical": {
      "function": 0.0001
    }
  },
  "material": {
    "gas": {
      "density": 0.01
    },
    "liquid": {
      "density": 1
    }
  },
  "output": {
    "directory": "output_down_amr/",
    "paraview": {
      "filename": "solution_evaporation",
      "enable": true
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "interface thickness parameter": {
          "type": "absolute_value",
          "val": 0.01
        },
        "pseudo time stepping": {
          "max n steps": 5
        },
        "Continuous Galerkin": {
          "implementation": "meltpooldg"
        }
      }
    },
    "curvature": {
      "linear solver": {
        "do matrix free": true
      },
      "implementation": "meltpooldg"
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": true
      },
      "implementation": "meltpooldg"
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    }
  }
}
