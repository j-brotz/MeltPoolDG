{
  "base": {
    "case name": "stefans_problem_with_flow",
    "dimension": 2,
    "global refinements": 5,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.0006,
    "time step size": 1e-06
  },
  "material": {
    "gas": {
      "density": 0.01,
      "dynamic viscosity": 0.0006
    },
    "liquid": {
      "density": 1.0,
      "dynamic viscosity": 0.006
    },
    "two phase fluid properties transition type": "consistent_with_evaporation"
  },
  "adaptive meshing": {
    "do amr": true,
    "do not modify boundary cells": false,
    "upper perc to refine": 0.1,
    "lower perc to coarsen": 0.1,
    "n initial refinement cycles": 3,
    "max grid refinement level": 7,
    "every n step": 1
  },
  "evaporation": {
    "analytical": {
      "function": 0.0001
    },
    "evaporative cooling": {
      "enable": false
    },
    "evaporative dilation rate": {
      "enable": true
    }
  },
  "application specific": {
    "do heat transfer": true
  },
  "output": {
    "directory": "stefans_problem_with_flow/",
    "paraview": {
      "filename": "solution_evaporation",
      "enable": true
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "interface thickness parameter": {
          "type": "absolute_value",
          "val": 0.01
        },
        "pseudo time stepping": {
          "max n steps": 5
        },
        "Continuous Galerkin": {
          "implementation": "meltpooldg"
        }
      }
    },
    "curvature": {
      "linear solver": {
        "do matrix free": true
      },
      "implementation": "meltpooldg"
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": true
      },
      "implementation": "meltpooldg"
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "formulation convective term momentum balance": "convective",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin max iterations": 30,
          "lin tolerance": 0.0001,
          "lin relative tolerance": 1,
          "lin velocity preconditioner": "ilu scalar",
          "lin pressure mass preconditioner": "ilu",
          "lin its before inner solvers": 50
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": 2,
        "output walltimes": 0
      }
    },
    "gravity": 0.0,
    "surface tension": {
      "surface tension coefficient": 1.8
    }
  }
}
