{
  "$schema": "../../../parameters.schema.json",
  "base": {
    "case name": "stefans_problem_with_flow",
    "dimension": 1,
    "global refinements": 6,
    "do print parameters": false,
    "verbosity level": 1,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.002,
    "time step size": 0.0005
  },
  "material": {
    "gas": {
      "thermal conductivity": 1e-16,
      "density": 0.01,
      "dynamic viscosity": 1e-06
    },
    "liquid": {
      "thermal conductivity": 1e-16,
      "density": 1.0,
      "dynamic viscosity": 1e-06
    },
    "two phase fluid properties transition type": "consistent_with_evaporation"
  },
  "evaporation": {
    "analytical": {
      "function": 0.01
    },
    "evaporative cooling": {
      "enable": false
    },
    "evaporative dilation rate": {
      "enable": true
    }
  },
  "application specific": {
    "do heat transfer": true,
    "amr": {
      "strategy": "generic",
      "do refine all interface cells": true,
      "do auto detect frequency": true,
      "automatic grid refinement type": "fixed_fraction"
    }
  },
  "adaptive meshing": {
    "do amr": true,
    "lower perc to coarsen": 0.2,
    "max grid refinement level": 9,
    "n initial refinement cycles": 5,
    "upper perc to refine": 0.2
  },
  "output": {
    "do user defined postprocessing": true,
    "paraview": {
      "enable": false
    }
  },
  "level set": {
    "reinitialization": {
      "enable": true,
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 3
        }
      },
      "interface thickness parameter": {
        "type": "absolute_value",
        "val": 0.01
      }
    },
    "curvature": {
      "verbosity level": 2
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "formulation convective term momentum balance": "convective",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin max iterations": 30,
          "lin tolerance": 0.0001,
          "lin velocity preconditioner": "ilu",
          "lin its before inner solvers": 50
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": 0,
        "output wall times": false
      }
    },
    "gravity": 0
  }
}
