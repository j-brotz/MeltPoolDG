{
  "base": {
    "case name": "stefans_problem_with_flow",
    "dimension": 2,
    "global refinements": 5,
    "do print parameters": false,
    "fe": {
      "degree": 1
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.002,
    "time step size": 0.0005
  },
  "material": {
    "gas": {
      "thermal conductivity": 1e-16,
      "density": 0.01,
      "dynamic viscosity": 1e-06
    },
    "liquid": {
      "thermal conductivity": 1e-16,
      "density": 1.0,
      "dynamic viscosity": 1e-06
    },
    "two phase fluid properties transition type": "consistent_with_evaporation"
  },
  "evaporation": {
    "analytical": {
      "function": 0.01
    },
    "formulation source term level set": "rhs",
    "do level set pressure gradient interpolation": true,
    "evaporative cooling": {
      "enable": false
    },
    "evaporative dilation rate": {
      "enable": true
    }
  },
  "application specific": {
    "do heat transfer": true
  },
  "output": {
    "do user defined postprocessing": true,
    "paraview": {
      "enable": false
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 5
        }
      },
      "interface thickness parameter": {
        "type": "absolute_value",
        "val": 0.02
      }
    },
    "curvature": {
      "filter parameter": 0.0,
      "linear solver": {
        "do matrix free": true
      },
      "implementation": "meltpooldg"
    },
    "normal vector": {
      "filter parameter": 0.5,
      "linear solver": {
        "do matrix free": true
      },
      "implementation": "meltpooldg"
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    },
    "fe": {
      "type": "FE_Q_iso_Q1",
      "degree": 2
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "formulation convective term momentum balance": "convective",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin max iterations": 30,
          "lin tolerance": 0.0001,
          "lin velocity preconditioner": "ilu",
          "lin its before inner solvers": 50
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": 0,
        "output walltimes": 0
      }
    },
    "gravity": 0
  }
}
