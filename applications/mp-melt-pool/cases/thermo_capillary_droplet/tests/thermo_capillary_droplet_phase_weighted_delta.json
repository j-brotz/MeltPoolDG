{
  "base": {
    "case name": "thermo_capillary_droplet",
    "dimension": 2,
    "do print parameters": false,
    "global refinements": 6,
    "fe": {
      "degree": 1
    }
  },
  "material": {
    "gas": {
      "thermal conductivity": 2.4e-06,
      "specific heat capacity": 0.0001,
      "density": 500,
      "dynamic viscosity": 0.024
    },
    "liquid": {
      "thermal conductivity": 1.2e-06,
      "specific heat capacity": 5e-05,
      "density": 250,
      "dynamic viscosity": 0.012
    },
    "two phase fluid properties transition type": "sharp"
  },
  "application specific": {
    "do heat transfer": true
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.002,
    "time step size": 0.0005
  },
  "output": {
    "paraview": {
      "enable": false
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "interface thickness parameter": {
          "type": "proportional_to_cell_size",
          "val": 1
        },
        "pseudo time stepping": {
          "max n steps": 5
        },
        "Continuous Galerkin": {
          "implementation": "meltpooldg"
        }
      }
    },
    "curvature": {
      "filter parameter": 0.0,
      "linear solver": {
        "do matrix free": true
      },
      "implementation": "meltpooldg"
    },
    "normal vector": {
      "filter parameter": 0.5,
      "linear solver": {
        "do matrix free": true
      },
      "implementation": "meltpooldg"
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin max iterations": 30,
          "lin tolerance": 0.0001,
          "lin relative tolerance": 1,
          "lin velocity preconditioner": "ilu scalar",
          "lin pressure mass preconditioner": "ilu",
          "lin its before inner solvers": 50
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": 0,
        "output walltimes": 0
      }
    },
    "gravity": 0.0,
    "surface tension": {
      "surface tension coefficient": 0.01,
      "temperature dependent surface tension coefficient": 0.002,
      "reference temperature": 290,
      "dirac delta function approximation": {
        "type": "heaviside_phase_weighted",
        "gas phase weight": 1,
        "heavy phase weight": 100
      }
    }
  }
}
