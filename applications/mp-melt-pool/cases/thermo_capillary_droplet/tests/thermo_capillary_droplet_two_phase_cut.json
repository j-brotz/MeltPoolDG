{
  "$schema": "../../../parameters.schema.json",
  "base": {
    "case name": "thermo_capillary_droplet",
    "dimension": 2,
    "do print parameters": false,
    "global refinements": 5,
    "verbosity level": 1,
    "fe": {
      "degree": 1
    }
  },
  "material": {
    "gas": {
      "thermal conductivity": 2.4e-06,
      "specific heat capacity": 0.0001,
      "density": 500,
      "dynamic viscosity": 0.024
    },
    "liquid": {
      "thermal conductivity": 1.2e-06,
      "specific heat capacity": 5e-05,
      "density": 250,
      "dynamic viscosity": 0.012
    },
    "two phase fluid properties transition type": "smooth"
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 0.012,
    "time step size": 0.002
  },
  "application specific": {
    "do heat transfer": true
  },
  "heat": {
    "operator type": "cut",
    "cut": {
      "do explicit symmetry term": true,
      "theta": 0.5,
      "two phase": true,
      "stabilization": {
        "nitsche parameter": 500,
        "ghost-penalty": {
          "gamma A degree 1": 1.5,
          "gamma M degree 1": 0.75
        }
      }
    },
    "linear solver": {
      "abs tolerance": 1e-12,
      "rel tolerance": 1e-12,
      "preconditioner type": "Diagonal"
    },
    "nlsolve": {
      "max nonlinear iterations": 10,
      "field correction tolerance": 1e-10,
      "residual tolerance": 1e-10
    }
  },
  "output": {
    "paraview": {
      "enable": false
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 2
        },
        "Continuous Galerkin": {
          "implementation": "adaflo"
        }
      },
      "interface thickness parameter": {
        "type": "proportional_to_cell_size",
        "val": 1
      }
    },
    "curvature": {
      "linear solver": {
        "do matrix free": true
      },
      "filter parameter": 2.0,
      "implementation": "meltpooldg"
    },
    "normal vector": {
      "filter parameter": 2.0,
      "linear solver": {
        "do matrix free": true
      },
      "implementation": "meltpooldg"
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 2,
        "global refinements": 0,
        "velocity degree": 2,
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin max iterations": 30,
          "lin tolerance": 0.0001,
          "lin relative tolerance": 1,
          "lin velocity preconditioner": "ilu scalar",
          "lin pressure mass preconditioner": "ilu",
          "lin its before inner solvers": 50
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": 0,
        "output walltimes": 0
      }
    },
    "gravity": 0.0,
    "surface tension": {
      "surface tension coefficient": 0.01,
      "temperature dependent surface tension coefficient": 0.002,
      "reference temperature": 290
    }
  }
}
