{
  "$schema": "../../parameters.schema.json",
  "base": {
    "case name": "thermo_capillary_droplet",
    "dimension": 3,
    "do print parameters": false,
    "global refinements": 4,
    "fe": {
      "degree": 1
    }
  },
  "heat": {
    "linear solver": {
      "rel tolerance": 1e-12,
      "preconditioner type": "AMG"
    },
    "nlsolve": {
      "residual tolerance": 1e-06
    }
  },
  "material": {
    "gas": {
      "thermal conductivity": 2.4e-06,
      "specific heat capacity": 0.0001,
      "density": 500,
      "dynamic viscosity": 0.024
    },
    "liquid": {
      "thermal conductivity": 1.2e-06,
      "specific heat capacity": 5e-05,
      "density": 250,
      "dynamic viscosity": 0.012
    }
  },
  "time stepping": {
    "start time": 0.0,
    "end time": 1.0,
    "time step size": 0.05
  },
  "adaptive meshing": {
    "do amr": true,
    "do not modify boundary cells": false,
    "upper perc to refine": 0.1,
    "lower perc to coarsen": 0.01,
    "n initial refinement cycles": 4,
    "max grid refinement level": 5,
    "every n step": 1
  },
  "application specific": {
    "do heat transfer": true
  },
  "output": {
    "directory": "output/",
    "paraview": {
      "filename": "thermocapillary_droplet",
      "enable": true
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": true
      },
      "enable": true,
      "type": "olsson2007",
      "hyperbolic": {
        "pseudo time stepping": {
          "max n steps": 5
        },
        "Continuous Galerkin": {
          "implementation": "meltpooldg"
        }
      },
      "interface thickness parameter": {
        "type": "proportional_to_cell_size",
        "val": 1
      }
    },
    "curvature": {
      "linear solver": {
        "do matrix free": true
      },
      "implementation": "meltpooldg"
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": true
      },
      "implementation": "meltpooldg"
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": true
      }
    }
  },
  "flow": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": 3,
        "global refinements": 0,
        "velocity degree": 2,
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": 10,
          "NL tolerance": 1e-09,
          "lin max iterations": 30,
          "lin tolerance": 0.0001,
          "lin relative tolerance": 1,
          "lin velocity preconditioner": "ilu scalar",
          "lin pressure mass preconditioner": "ilu",
          "lin its before inner solvers": 50
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": 2,
        "output walltimes": 0
      }
    },
    "gravity": 0.0,
    "surface tension": {
      "surface tension coefficient": 0.01,
      "temperature dependent surface tension coefficient": 0.002
    }
  }
}
