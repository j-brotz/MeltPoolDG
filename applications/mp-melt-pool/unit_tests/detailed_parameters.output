                    "actions": "384"
                },
                "step size":
                {
                    "value": "0.01",
                    "default_value": "0.01",
                    "documentation": "Sets the step size for time stepping. For non-uniform time stepping, this sets the size of the first time step.",
                    "pattern": "384",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "385"
                },
                "CFL number":
                {
                    "value": "0.8",
                    "default_value": "0.8",
                    "documentation": "Limits the time step size in terms of a condition dt <= CFL * dx \/ |u|, where u is a characteristic velocity. For two-phase flow, we typically take the velocity of the bubble",
                    "pattern": "385",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "386"
                },
                "CFL number capillary":
                {
                    "value": "10",
                    "default_value": "10",
                    "documentation": "Limits the time step size in terms of a condition dt <= CFL_cap * sqrt(rho\/sigma) * dx^1.5, i.e., it represents a capillarity time step limit.",
                    "pattern": "386",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "387"
                },
                "tolerance":
                {
                    "value": "0.01",
                    "default_value": "0.01",
                    "documentation": "Sets the tolerance for time step selection in non-uniform time stepping strategies.",
                    "pattern": "387",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "388"
                },
                "max step size":
                {
                    "value": "1",
