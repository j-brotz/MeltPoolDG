            "Time stepping":
            {
                "start time":
                {
                    "value": "0",
                    "default_value": "0",
                    "documentation": "Sets the start time for the simulation",
                    "pattern": "382",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "383"
