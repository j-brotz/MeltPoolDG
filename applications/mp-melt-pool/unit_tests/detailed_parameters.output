                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "342"
                },
                "damping":
                {
                    "value": "0",
                    "default_value": "0",
                    "documentation": "Defines the fluid damping",
                    "pattern": "342",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "343"
                },
                "physical type":
                {
                    "value": "incompressible",
                    "default_value": "incompressible",
                    "documentation": "Sets the type of equations, Navier-Stokes or Stokes. For Navier-Stokes, one can choose between a stationary and a time-dependent variant. The time-dependent Navier-Stokes equations are the default.",
                    "pattern": "343",
                    "pattern_description": "[Selection incompressible|incompressible stationary|stokes ]",
                    "actions": "344"
                },
                "constitutive type":
                {
                    "value": "newtonian incompressible",
                    "default_value": "newtonian incompressible",
                    "documentation": "Sets the type of constitutive equations. The incompressible Newtonian fluid assumption is the default case. Alternatively, a compressible Newtonian fluid formulation exploiting the Stokes hypothesis or a user defined type can be chosen.",
                    "pattern": "344",
                    "pattern_description": "[Selection newtonian incompressible|newtonian compressible stokes hypothesis|user defined ]",
                    "actions": "345"
                },
                "formulation convective term momentum balance":
                {
                    "value": "skew-symmetric",
                    "default_value": "skew-symmetric",
                    "documentation": "Sets the formulation of the convective term in the momentum balance of the Navier-Stokes equations, i.e. ∇·(u x u) =(u·∇)u + βu(∇·u). The parameter β will be set to 1 for the conservative form, to 0 for the convective form and to 0.5 for the skew-symmetric form (default formulation).",
                    "pattern": "345",
                    "pattern_description": "[Selection skew-symmetric|convective|conservative ]",
                    "actions": "346"
                },
                "Solver":
                {
                    "NL max iterations":
                    {
                        "value": "10",
                        "default_value": "10",
                        "documentation": "Defines the maximum number of nonlinear Newton iterations.",
                        "pattern": "346",
                        "pattern_description": "[Integer]",
                        "actions": "347"
                    },
                    "NL tolerance":
                    {
                        "value": "1e-06",
                        "default_value": "1e-06",
                        "documentation": "Defines the tolerance in the residual l2 norm in the nonlinear Newton iteration.",
                        "pattern": "347",
                        "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                        "actions": "348"
                    },
                    "linearization scheme":
                    {
                        "value": "coupled implicit Newton",
                        "default_value": "coupled implicit Newton",
                        "documentation": "Sets how to treat the coupled nonlinear Navier-Stokes system. The 'coupled' variants solve for the full block system, whereas 'projection' applies a fractional-step pressure correction method with the solution of a pressure Poisson matrix. The nonlinear convective term can be treated by afull Newton iteration, a Picard iteration (fixed-point like), a semi-implicit approach with the same term as in the fixed-point like iteration but velocity extrapolated from the old time, and an approach where the complete convective term is treated explicitly. For the projection scheme, only the semi-implicit velocity treatment is implemented because iterating out the nonlinearity makes no sense.",
                        "pattern": "348",
                        "pattern_description": "[Selection coupled implicit Newton|coupled implicit Picard|coupled velocity semi-implicit|coupled velocity explicit|projection ]",
                        "actions": "349"
                    },
                    "tau grad div":
                    {
                        "value": "0",
                        "default_value": "0",
                        "documentation": "Adds the term (div(v), tau div(u))to the weak form the momentum equation, which is consistent with the Navier-Stokes equations but penalizes the divergence more. This term is usually referred to as grad-div stabilization. It simplifies the solution of linear systems if tau is on the order of unity but not too large (as the added term is singular).",
                        "pattern": "349",
                        "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                        "actions": "350"
                    },
                    "lin max iterations":
                    {
                        "value": "500",
                        "default_value": "500",
                        "documentation": "Maximum number of linear iterations",
                        "pattern": "350",
                        "pattern_description": "[Integer]",
                        "actions": "351"
                    },
                    "lin tolerance":
                    {
                        "value": "0.001",
                        "default_value": "0.001",
                        "documentation": "Tolerance for the linear solver",
                        "pattern": "351",
                        "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                        "actions": "352"
                    },
                    "lin relative tolerance":
                    {
                        "value": "1",
                        "default_value": "1",
                        "documentation": "Sets whether the residual for the linear solver should be measured relative to the nonlinear residual (recommended option).",
                        "pattern": "352",
                        "pattern_description": "[Selection 0|1 ]",
                        "actions": "353"
                    },
                    "lin velocity preconditioner":
                    {
                        "value": "amg linear",
                        "default_value": "amg linear",
                        "documentation": "Sets the preconditioner for approximating the inverse of the velocity matrix in the Schur complement preconditioner. 'amg linear' uses a matrix based on subdividing FE_Q into several linear elements to create a matrix hierarchy. This might decrease interpolation quality, but AMG is typically much better for linears, so it is recommended for more complex problems with relatively large time steps or large viscosities, otherwise ILU. The method 'ilu scalar' is a simplified ILU that only constructs the ILU for one velocity block and applies the same operator to all components. It is cheaper to apply but approximates somewhat worse.",
                        "pattern": "353",
                        "pattern_description": "[Selection ilu|ilu scalar|amg linear|amg ]",
                        "actions": "354"
                    },
                    "lin pressure mass preconditioner":
                    {
                        "value": "ilu",
                        "default_value": "ilu",
                        "documentation": "Sets whether the pressure mass matrix in the Schur complement should be represented by the diagonal only or by an ILU based on the full pressure mass matrix.",
                        "pattern": "354",
                        "pattern_description": "[Selection ilu|diagonal ]",
                        "actions": "355"
                    },
                    "lin its before inner solvers":
                    {
                        "value": "50",
                        "default_value": "50",
                        "documentation": "The linear solver comes in two flavors. A simple solver which uses only AMG V-cycles or ILUs as preconditioner components in the Schur complement, or a stronger solver with inner iterations. The variant with inner solves is less efficient when only a few iterations are needed, but much more robust and more efficient for many iterations. This option sets how many linear iterations with the cheap preconditioners should be made before the stronger version with more iterations starts.",
                        "pattern": "355",
                        "pattern_description": "[Integer]",
                        "actions": "356"
                    }
                }
            },
