            "actions": "61"
        },
        "absorptivity gas":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Laser energy absorptivity of the gaseous part of the domain.",
            "pattern": "62",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "62"
        },
        "absorptivity liquid":
        {
            "value": "1",
            "default_value": "1",
