{
  "$schema": "../../parameters.schema.json",
  "base": {
    "case name": "powder_particles",
    "dimension": 2,
    "global refinements": 5,
    "do print parameters": false,
    "verbosity level": 1,
    "fe": {
      "degree": 2,
      "type": "FE_Q_iso_Q1"
    }
  },
  "case specific": {
    "domain x min": -5e-05,
    "domain x max": 5e-05,
    "domain y min": -2.5e-05,
    "domain y max": 2.5e-05,
    "cell repetitions": "2,1",
    "particle distribution case": "two_particles",
    "two particles": {
      "radius": 1.5e-05,
      "distance": 3.5e-05
    },
    "level set type": "tanh"
  },
  "application specific parameters": {
    "do update normal vector": true
  },
  "time stepping": {
    "time step size": 7.8125e-07,
    "max n steps": 100000
  },
  "reinitialization": {
    "enable": true,
    "type": "olsson2007",
    "linear solver": {
      "abs tolerance": 1e-20,
      "rel tolerance": 1e-12,
      "preconditioner type": "Diagonal",
      "do matrix free": true
    },
    "hyperbolic": {
      "pseudo time stepping": {
        "tolerance": 2.22507e-308
      },
      "Continuous Galerkin": {
        "implementation": "meltpooldg",
        "tangential diffusion factor": 0.005
      }
    },
    "interface thickness parameter": {
      "type": "absolute_value",
      "val": 1e-06
    }
  },
  "normal vector": {
    "implementation": "meltpooldg",
    "filter parameter": 2.0,
    "linear solver": {
      "abs tolerance": 1e-20,
      "rel tolerance": 1e-09,
      "preconditioner type": "Diagonal",
      "do matrix free": true
    }
  },
  "profiling": {
    "enable": true,
    "time type": "real",
    "write time step size": 1e+100
  },
  "output": {
    "directory": ".",
    "write frequency": 1000,
    "paraview": {
      "enable": true
    }
  }
}
