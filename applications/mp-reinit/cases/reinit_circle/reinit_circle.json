{
  "$schema": "../../parameters.schema.json",
  "base": {
    "case name": "reinit_circle",
    "dimension": 2,
    "global refinements": 6,
    "fe": {
      "degree": 1
    }
  },
  "simulation specific parameters": {
    "center point": "0., 0.5",
    "radius": 0.25,
    "level set type": "tanh",
    "apply initial jump at interface": true
  },
  "time stepping": {
    "start time": 0.0,
    "time step size": 0.005,
    "max n steps": 30
  },
  "output": {
    "paraview": {
      "filename": "output/reinit_circle/solution_reinitialization",
      "enable": true
    }
  },
  "reinitialization": {
    "linear solver": {
      "do matrix free": true
    },
    "type": "olsson2007"
  },
  "normal vector": {
    "linear solver": {
      "do matrix free": true
    },
    "filter parameter": 0.5
  }
}
