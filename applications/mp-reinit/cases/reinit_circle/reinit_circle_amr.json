    "upper perc to refine": 0.1,
    "lower perc to coarsen": 0.0,
    "max grid refinement level": 8
  },
  "time stepping": {
    "start time": 0.0,
    "time step size": 0.005,
    "max n steps": 30
  },
  "output": {
    "paraview": {
      "filename": "solution_reinitialization",
      "enable": true
    }
  },
  "reinitialization": {
    "linear solver": {
      "do matrix free": true
    },
    "type": "olsson2007",
    "hyperbolic": {
      "interface thickness parameter": {
        "type": "absolute_value",
        "val": 0.05
      }
    }
  },
  "normal vector": {
    "linear solver": {
      "do matrix free": true
    }
  }
