{
  "$schema": "../../../parameters.schema.json",
  "base": {
    "case name": "reinit_circle",
    "dimension": 2,
    "global refinements": 6,
    "do print parameters": false,
    "fe": {
      "degree": 1
    }
  },
  "case specific": {
    "center point": "0., 0.5",
    "radius": 0.25,
    "level set type": "tanh",
    "apply initial jump at interface": true
  },
  "time stepping": {
    "start time": 0.0,
    "time step size": 0.005,
    "max n steps": 5
  },
  "adaptive meshing": {
    "do amr": true,
    "upper perc to refine": 0.1,
    "lower perc to coarsen": 0.0,
    "max grid refinement level": 8
  },
  "output": {
    "paraview": {
      "enable": false
    }
  },
  "reinitialization": {
    "linear solver": {
      "do matrix free": true
    },
    "type": "olsson2007",
    "hyperbolic": {
      "Continuous Galerkin": {
        "implementation": "adaflo"
      }
    },
    "interface thickness parameter": {
      "type": "proportional_to_cell_size",
      "val": 1.5
    }
  }
}
