{
  "$schema": "../../../parameters.schema.json",
  "base": {
    "case name": "reinit_circle",
    "dimension": 2,
    "global refinements": 7,
    "do print parameters": false,
    "fe": {
      "degree": 1
    },
    "verbosity level": 1
  },
  "case specific": {
    "center point": "0., 0.",
    "radius": 0.5,
    "level set type": "signed_distance",
    "apply initial jump at interface": false,
    "distortion factor": 0.8
  },
  "output": {
    "paraview": {
      "enable": false
    }
  },
  "reinitialization": {
    "linear solver": {
      "solver type": "CG",
      "preconditioner type": "AMG",
      "max iterations": 1000,
      "rel tolerance": 1e-08,
      "abs tolerance": 1e-20,
      "monitor type": "none",
      "do matrix free": true
    },
    "type": "elliptic",
    "elliptic": {
      "penalty parameter": 1000.0,
      "fixed point iteration": {
        "max n steps": 10,
        "tolerance": 1e-05
      }
    }
  },
  "time stepping": {
    "start time": 0.0,
    "time step size": 1.0,
    "end time": 1000.0,
    "max n steps": 5,
    "time step size function": "0.0*t"
  }
}
