{
    "adaptive meshing":
    {
        "do amr": "false",
        "do not modify boundary cells": "false",
        "every n step": "1",
        "lower perc to coarsen": "0",
        "max grid refinement level": "12",
        "min cells marked to refine": "1",
        "min grid refinement level": "-1",
        "min indicator threshold to refine cell": "0",
        "n initial refinement cycles": "0",
        "upper perc to refine": "0"
    },
    "base":
    {
        "case name": "not_initialized",
        "dimension": "2",
        "do print parameters": "true",
        "global refinements": "1",
        "number": "double",
        "verbosity level": "1",
        "fe":
        {
            "degree": "1",
            "type": "FE_Q"
        }
    },
    "curvature":
    {
        "do curvature correction": "false",
        "enable": "true",
        "filter parameter": "2",
        "implementation": "meltpooldg",
        "verbosity level": "-1",
        "Discontinous Galerkin":
        {
            "penalty factor": "100"
        },
        "linear solver":
        {
            "abs tolerance": "1e-20",
            "do matrix free": "true",
            "max iterations": "10000",
            "monitor type": "none",
            "preconditioner type": "Diagonal",
            "rel tolerance": "1e-12",
            "solver type": "CG"
        },
        "narrow band":
        {
            "enable": "false",
            "level set threshold": "1"
        },
        "predictor":
        {
            "n old solutions": "2",
            "type": "none"
        }
    },
    "normal vector":
    {
        "compute normalized vector": "false",
        "filter parameter": "2",
        "implementation": "meltpooldg",
        "verbosity level": "-1",
        "Discontinous Galerkin":
        {
            "penalty factor": "100"
        },
        "linear solver":
        {
            "abs tolerance": "1e-20",
            "do matrix free": "true",
            "max iterations": "10000",
            "monitor type": "none",
            "preconditioner type": "Diagonal",
            "rel tolerance": "1e-12",
            "solver type": "CG"
        },
        "narrow band":
        {
            "enable": "false",
            "level set threshold": "1"
        },
        "predictor":
        {
            "n old solutions": "2",
            "type": "none"
        }
    },
    "output":
    {
        "directory": ".\/",
        "do user defined postprocessing": "false",
        "output variables": "all",
        "write frequency": "1",
        "write time step size": "1.79769e+308",
        "paraview":
        {
            "enable": "false",
            "filename": "solution",
            "n digits timestep": "4",
            "n groups": "1",
            "n patches": "0",
            "output material id": "false",
            "output subdomains": "false",
            "print boundary id": "false",
            "write higher order cells": "true"
        },
        "particles":
        {
            "enable": "false",
            "filename": "particle"
        }
    },
    "profiling":
    {
        "enable": "false",
        "time type": "real",
        "write time step size": "10"
    },
    "reinitialization":
    {
        "enable": "true",
        "implementation": "meltpooldg",
        "max n steps": "5",
        "n initial steps": "-1",
        "pseudo time step factor": "1",
        "pseudo time step size": "-1",
        "tangential diffusion factor": "0",
        "tolerance": "2.22507e-308",
        "type": "olsson2007",
        "Discontinous Galerkin":
        {
            "CFL": "1",
            "IMEX integration scheme": "not_initialized",
            "IP diffusion": "100",
            "avoid zero division smoothed signum": "1e-16",
            "do CFL based time stepping": "false",
            "factor diffusivity": "0.25",
            "gradient error time derivative threshold": "1e-16",
            "hyperbolic weighting function_type": "smoothed_signum",
            "signum smoothness paramater": "2",
            "time integration scheme": "LSRK_stage_5_order_4",
            "use const gradient in RI": "false",
            "use directed diffusion stabilization": "false",
            "use interface movement penalization": "false",
            "use spatially constant diffusion": "true"
        },
        "fe":
        {
            "degree": "-1",
            "type": "not_initialized"
        },
        "interface thickness parameter":
        {
            "type": "proportional_to_cell_size",
            "val": "0.5"
        },
        "linear solver":
        {
            "abs tolerance": "1e-20",
            "do matrix free": "true",
            "max iterations": "10000",
            "monitor type": "none",
            "preconditioner type": "Diagonal",
            "rel tolerance": "1e-12",
            "solver type": "CG"
        },
        "predictor":
        {
            "n old solutions": "2",
            "type": "none"
        }
    },
    "time stepping":
    {
        "end time": "1",
        "max n steps": "10000000",
        "start time": "0",
        "time step size": "0.01",
        "time step size function": "0.0*t"
    }
