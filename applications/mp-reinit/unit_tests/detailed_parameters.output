{
    "base":
    {
        "case name":
        {
            "value": "not_initialized",
            "default_value": "not_initialized",
            "documentation": "Sets the base name for the application that will be fed to the problem type.",
            "pattern": "0",
            "pattern_description": "[Anything]",
            "actions": "0"
        },
        "dimension":
        {
            "value": "2",
            "default_value": "2",
            "documentation": "Defines the dimension of the problem",
            "pattern": "1",
            "pattern_description": "[Integer]",
            "actions": "1"
        },
        "number":
        {
            "value": "double",
            "default_value": "double",
            "documentation": "Floating point number format. Currently, only 'double' is explicitely instantiated.",
            "pattern": "2",
            "pattern_description": "[Selection double ]",
            "actions": "2"
        },
        "global refinements":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Defines the number of initial global refinements",
            "pattern": "3",
            "pattern_description": "[Integer]",
            "actions": "3"
        },
        "do print parameters":
        {
            "value": "true",
            "default_value": "true",
            "documentation": "Set this parameter to true to list parameters in output",
            "pattern": "4",
            "pattern_description": "[Bool]",
            "actions": "4"
        },
        "verbosity level":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Sets the verbosity level of the console output: 0: silent: for non-robust tests and benchmark runs; 1: minimal: for robust tests; 2: detailed; 3: full",
            "pattern": "5",
            "pattern_description": "[Integer]",
            "actions": "5"
        },
        "fe":
        {
            "type":
            {
                "value": "FE_Q",
                "default_value": "FE_Q",
                "documentation": "Finite Element.FE_Q: hexahedral continuous finite element with polynomial degree p; FE_SimplexP: tetrahedral continuous finite element with polynomial degree p; FE_Q_iso_Q1: hexahedral continuous finite element with p subdivisions containing linear elements; FE_DGQ: hexahedral discontinuous finite element with polynomial degree p",
                "pattern": "6",
                "pattern_description": "[Selection not_initialized|FE_Q|FE_SimplexP|FE_Q_iso_Q1|FE_DGQ ]",
                "actions": "6"
            },
            "degree":
            {
                "value": "1",
                "default_value": "1",
                "documentation": "Defines the degree p of the finite element type. If \"type\" is \"FE_Q_iso_Q1\" this parameter defines the number of subdivisions.",
                "pattern": "7",
                "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                "actions": "7"
            }
        }
    },
    "time stepping":
    {
        "start time":
        {
            "value": "0",
            "default_value": "0",
            "documentation": "Defines the start time for the solution of the levelset problem",
            "pattern": "8",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "8"
        },
        "end time":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Sets the end time for the solution of the levelset problem",
            "pattern": "9",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "9"
        },
        "time step size":
        {
            "value": "0.01",
            "default_value": "0.01",
            "documentation": "Sets the step size for time stepping. For non-uniform time stepping, this parameter determines the size of the first time step.",
            "pattern": "10",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "10"
        },
        "max n steps":
        {
            "value": "10000000",
            "default_value": "10000000",
            "documentation": "Sets the maximum number of melt_pool steps",
            "pattern": "11",
            "pattern_description": "[Integer]",
            "actions": "11"
        },
        "time step size function":
        {
            "value": "0.0*t",
            "default_value": "0.0*t",
            "documentation": "Set an analytical function to determine the time step size. For the prediction of the new time increment, the old time is used.",
            "pattern": "12",
            "pattern_description": "[Anything]",
            "actions": "12"
        }
    },
    "adaptive meshing":
    {
        "do amr":
        {
            "value": "false",
            "default_value": "false",
            "documentation": "Set this parameter to true to activate adaptive meshing",
            "pattern": "13",
            "pattern_description": "[Bool]",
            "actions": "13"
        },
        "do not modify boundary cells":
        {
            "value": "false",
            "default_value": "false",
            "documentation": "Set this parameter to true to not refine\/coarsen along boundaries.",
            "pattern": "14",
            "pattern_description": "[Bool]",
            "actions": "14"
        },
        "upper perc to refine":
        {
            "value": "0",
            "default_value": "0",
            "documentation": "Defines the (upper) percentage of elements that should be refined",
            "pattern": "15",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "15"
        },
        "lower perc to coarsen":
        {
            "value": "0",
            "default_value": "0",
            "documentation": "Defines the (lower) percentage of elements that should be coarsened",
            "pattern": "16",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "16"
        },
        "max grid refinement level":
        {
            "value": "12",
            "default_value": "12",
            "documentation": "Defines the number of maximum refinement steps one grid cell will be undergone.",
            "pattern": "17",
            "pattern_description": "[Integer]",
            "actions": "17"
        },
        "min grid refinement level":
        {
            "value": "-1",
            "default_value": "-1",
            "documentation": "Defines the number of minimum refinement steps one grid cell will be undergone.",
            "pattern": "18",
            "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
            "actions": "18"
        },
        "n initial refinement cycles":
        {
            "value": "0",
            "default_value": "0",
            "documentation": "Defines the number of initial refinements.",
            "pattern": "19",
            "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
            "actions": "19"
        },
        "every n step":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Defines at every nth step the amr should be performed.",
            "pattern": "20",
            "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
            "actions": "20"
        },
        "min cells marked to refine":
        {
            "value": "1",
            "default_value": "1",
            "documentation": "Minimum number of cells that must be marked for refinement\/coarsening before the mesh is updated.",
            "pattern": "21",
            "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
            "actions": "21"
        },
        "min indicator threshold to refine cell":
        {
            "value": "0",
            "default_value": "0",
            "documentation": "Minimum indicator value required for a cell to be considered for refinement.",
            "pattern": "22",
            "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
            "actions": "22"
        },
        "solution transfer average values":
        {
            "value": "false",
            "default_value": "false",
            "documentation": "Set this parameter to true to average the contribututions to the same DoF coming from different cells during solution transfer.",
            "pattern": "23",
            "pattern_description": "[Bool]",
            "actions": "23"
        }
    },
    "reinitialization":
    {
        "fe":
        {
            "type":
            {
                "value": "not_initialized",
                "default_value": "not_initialized",
                "documentation": "Finite Element.FE_Q: hexahedral continuous finite element with polynomial degree p; FE_SimplexP: tetrahedral continuous finite element with polynomial degree p; FE_Q_iso_Q1: hexahedral continuous finite element with p subdivisions containing linear elements; FE_DGQ: hexahedral discontinuous finite element with polynomial degree p",
                "pattern": "24",
                "pattern_description": "[Selection not_initialized|FE_Q|FE_SimplexP|FE_Q_iso_Q1|FE_DGQ ]",
                "actions": "24"
            },
            "degree":
            {
                "value": "-1",
                "default_value": "-1",
                "documentation": "Defines the degree p of the finite element type. If \"type\" is \"FE_Q_iso_Q1\" this parameter defines the number of subdivisions.",
                "pattern": "25",
                "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                "actions": "25"
            }
        },
        "predictor":
        {
            "type":
            {
                "value": "none",
                "default_value": "none",
                "documentation": "Choose a predictor type: none: use old value as initial guess; zero: se zeros as initial guess; linear_extrapolation: calculate the predictor by a linear combination from the two old solution vectors; least_squares_projection: least squares projection (WIP)",
                "pattern": "26",
                "pattern_description": "[Selection none|zero|linear_extrapolation|least_squares_projection ]",
                "actions": "26"
            },
            "n old solutions":
            {
                "value": "2",
                "default_value": "2",
                "documentation": "Choose the number of old solution vectors considered.This parameter is only relevant for least squares projection.For all other predictors, this parameter will be set appropriately.",
                "pattern": "27",
                "pattern_description": "[Integer]",
                "actions": "27"
            }
        },
        "linear solver":
        {
            "solver type":
            {
                "value": "CG",
                "default_value": "CG",
                "documentation": "Set this parameter for choosing an iterative linear solver type.",
                "pattern": "28",
                "pattern_description": "[Selection CG|GMRES ]",
                "actions": "28"
            },
            "preconditioner type":
            {
                "value": "Diagonal",
                "default_value": "Diagonal",
                "documentation": "Set this parameter for choosing a preconditioner type.",
                "pattern": "29",
                "pattern_description": "[Selection Identity|AMG|ILU|Diagonal ]",
                "actions": "29"
            },
            "max iterations":
            {
                "value": "10000",
                "default_value": "10000",
                "documentation": "Set the maximum number of iterations for solving the linear system of equations.",
                "pattern": "30",
                "pattern_description": "[Integer]",
                "actions": "30"
            },
            "rel tolerance":
            {
                "value": "1e-12",
                "default_value": "1e-12",
                "documentation": "Set the relative tolerance for a successful solution of the linear system of equations.",
                "pattern": "31",
                "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                "actions": "31"
            },
            "abs tolerance":
            {
                "value": "1e-20",
                "default_value": "1e-20",
                "documentation": "Set the absolute tolerance for a successful solution of the linear system of equations.",
                "pattern": "32",
                "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                "actions": "32"
            },
            "do matrix free":
            {
                "value": "true",
                "default_value": "true",
                "documentation": "Set this parameter if a matrix free solution procedure should be performed.",
                "pattern": "33",
                "pattern_description": "[Bool]",
                "actions": "33"
            },
            "monitor type":
            {
                "value": "none",
                "default_value": "none",
                "documentation": "Set the monitor type of the linear solver.",
                "pattern": "34",
                "pattern_description": "[Selection none|reduced|all ]",
                "actions": "34"
            }
        },
        "enable":
        {
            "value": "true",
            "default_value": "true",
            "documentation": "Set to true to activate reinitialization.",
            "pattern": "35",
            "pattern_description": "[Bool]",
            "actions": "35"
        },
        "type":
        {
            "value": "olsson2007",
            "default_value": "olsson2007",
            "documentation": "Sets the type of reinitialization model that should be used.",
            "pattern": "36",
            "pattern_description": "[Selection olsson2007|elliptic|geometric ]",
            "actions": "36"
        },
        "interface thickness parameter":
        {
            "type":
            {
                "value": "proportional_to_cell_size",
                "default_value": "proportional_to_cell_size",
                "documentation": "Choose the value type of the interface thickness parameter.",
                "pattern": "37",
                "pattern_description": "[Selection proportional_to_cell_size|absolute_value|number_of_cells_across_interface ]",
                "actions": "37"
            },
            "val":
            {
                "value": "0.5",
                "default_value": "0.5",
                "documentation": "Defines the value of the chosen interface thickness parameter type.",
                "pattern": "38",
                "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                "actions": "38"
            }
        },
        "elliptic":
        {
            "penalty parameter":
            {
                "value": "0",
                "default_value": "0",
                "documentation": "Penalty parameter for the enforcement of the initial position of the zero level-set iso-surface during the elliptic reinitialization.",
                "pattern": "39",
                "pattern_description": "[Double 0...MAX_DOUBLE (inclusive)]",
                "actions": "39"
            }
        },
        "geometric":
        {
            "verbosity":
            {
                "value": "0",
                "default_value": "0",
                "documentation": "Choose the verbosity level. 0 means silent, 1 means verbose.",
                "pattern": "40",
                "pattern_description": "[Integer]",
                "actions": "40"
            },
            "max distance":
            {
                "value": "1.61792e+308",
                "default_value": "1.61792e+308",
                "documentation": "Maximum distance from the zero-level-set where the signeddistance function is reconstructed.",
                "pattern": "41",
                "pattern_description": "[Double 0...MAX_DOUBLE (inclusive)]",
                "actions": "41"
            }
        },
        "hyperbolic":
        {
            "pseudo time stepping":
            {
                "n initial steps":
                {
                    "value": "-1",
                    "default_value": "-1",
                    "documentation": "Defines the number of initial reinitialization steps of the level set function. In the default case, the number is set equal to the number of max n steps.",
                    "pattern": "42",
                    "pattern_description": "[Integer range -2147483648...2147483647 (inclusive)]",
                    "actions": "42"
                },
                "pseudo time step size":
                {
                    "value": "-1",
                    "default_value": "-1",
                    "documentation": "Sets the reinitialization time step size. By default, it is computed from the cell size.",
                    "pattern": "43",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "43"
                },
                "pseudo time step factor":
                {
                    "value": "1",
                    "default_value": "1",
                    "documentation": "Factor on the reinitialization time step size that is computed from the cell size.",
                    "pattern": "44",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "44"
                },
                "max n steps":
                {
                    "value": "5",
                    "default_value": "5",
                    "documentation": "Sets the maximum number of reinitialization steps.",
                    "pattern": "45",
                    "pattern_description": "[Integer]",
                    "actions": "45"
                },
                "tolerance":
                {
                    "value": "2.22507e-308",
                    "default_value": "2.22507e-308",
                    "documentation": "Set the tolerance for reinitialization. If the maximum change of the level set field exceeds the tolerance, reinitialization steps will be performed.",
                    "pattern": "46",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "46"
                }
            },
            "Continuous Galerkin":
            {
                "implementation":
                {
                    "value": "meltpooldg",
                    "default_value": "meltpooldg",
                    "documentation": "Choose the corresponding implementation of the reinitialization operation.",
                    "pattern": "47",
                    "pattern_description": "[Selection meltpooldg|adaflo ]",
                    "actions": "47"
                },
                "tangential diffusion factor":
                {
                    "value": "0",
                    "default_value": "0",
                    "documentation": "Factor that multiplies the normal diffusion factor, i.e., the diffusion length, to obtain the diffusion factor in the tangential direction.",
                    "pattern": "48",
                    "pattern_description": "[Double 0...MAX_DOUBLE (inclusive)]",
                    "actions": "48"
                }
            },
            "Discontinuous Galerkin":
            {
                "factor diffusivity":
                {
                    "value": "0.25",
                    "default_value": "0.25",
                    "documentation": "Set the factor for diffusivity.",
                    "pattern": "49",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "49"
                },
                "IP diffusion":
                {
                    "value": "100",
                    "default_value": "100",
                    "documentation": "Set the internal penalty for diffusivity.",
                    "pattern": "50",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "50"
                },
                "use const gradient in RI":
                {
                    "value": "false",
                    "default_value": "false",
                    "documentation": "Set if the Godunov gradient should be updated every reinitialization step.",
                    "pattern": "51",
                    "pattern_description": "[Bool]",
                    "actions": "51"
                },
                "do CFL based time stepping":
                {
                    "value": "false",
                    "default_value": "false",
                    "documentation": "Sets a flag if the time stepping should be based on the CFL condition.",
                    "pattern": "52",
                    "pattern_description": "[Bool]",
                    "actions": "52"
                },
                "time integration scheme":
                {
                    "value": "LSRK_stage_5_order_4",
                    "default_value": "LSRK_stage_5_order_4",
                    "documentation": "Determines the general time integration scheme for the pseudo-time integration of the reinitialization equation.",
                    "pattern": "53",
                    "pattern_description": "[Selection not_initialized|LSRK_stage_1_order_1|LSRK_stage_3_order_3|LSRK_stage_5_order_4|LSRK_stage_7_order_4|LSRK_stage_9_order_5|implicit_euler|explicit_euler|crank_nicolson|bdf_1|bdf_2|bdf_3|bdf_4|bdf_5|bdf_6|imex ]",
                    "actions": "53"
                },
                "IMEX integration scheme":
                {
                    "value": "not_initialized",
                    "default_value": "not_initialized",
                    "documentation": "If an IMEX integration scheme is specified, the integration in pseudo time of the reinitialization is done with an implicit-explicit scheme. This means that the diffusion part is treated with the IMEX integration scheme and the Hamiltonian is treated with the general time integration scheme. When choosing an implicit scheme with A-stability, larger time steps can be chosen, only limited by the stability of the Hamiltonian part. This is done since the diffusion part is the most restrictive part for explicit time integration schemes. If a scheme is set, the time step calculation based on a CFL number assumes an A-stable scheme and only calculates the time step based on the Hamiltonian.",
                    "pattern": "54",
                    "pattern_description": "[Selection not_initialized|LSRK_stage_1_order_1|LSRK_stage_3_order_3|LSRK_stage_5_order_4|LSRK_stage_7_order_4|LSRK_stage_9_order_5|implicit_euler|explicit_euler|crank_nicolson|bdf_1|bdf_2|bdf_3|bdf_4|bdf_5|bdf_6|imex ]",
                    "actions": "54"
                },
                "CFL":
                {
                    "value": "1",
                    "default_value": "1",
                    "documentation": "Set a CFL number for the pseudo-time stepping in reinitialization.",
                    "pattern": "55",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "55"
                },
                "avoid zero division smoothed signum":
                {
                    "value": "1e-16",
                    "default_value": "1e-16",
                    "documentation": "Sets a constant to avoid zero division in the computation of the smoothed signum.",
                    "pattern": "56",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "56"
                },
                "signum smoothness paramater":
                {
                    "value": "2",
                    "default_value": "2",
                    "documentation": "Sets the smoothness parameter for the smoothed signum.",
                    "pattern": "57",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "57"
                },
                "use directed diffusion stabilization":
                {
                    "value": "false",
                    "default_value": "false",
                    "documentation": "Sets a flag if directed diffusion stabilization should be used for reinitialization.",
                    "pattern": "58",
                    "pattern_description": "[Bool]",
                    "actions": "58"
                },
                "hyperbolic weighting function_type":
                {
                    "value": "smoothed_signum",
                    "default_value": "smoothed_signum",
                    "documentation": "Sets the type of weighting function for the hyperbolic part of the reinitialization equation.",
                    "pattern": "59",
                    "pattern_description": "[Selection smoothed_signum|initial_levelset ]",
                    "actions": "59"
                },
                "use spatially constant diffusion":
                {
                    "value": "true",
                    "default_value": "true",
                    "documentation": "Sets a flag if a spatially constant diffusion should be used for reinitialization.",
                    "pattern": "60",
                    "pattern_description": "[Bool]",
                    "actions": "60"
                },
                "use interface movement penalization":
                {
                    "value": "false",
                    "default_value": "false",
                    "documentation": "Sets a flag if a penalization of the interface movement should be used.",
                    "pattern": "61",
                    "pattern_description": "[Bool]",
                    "actions": "61"
                },
                "gradient error time derivative threshold":
                {
                    "value": "1e-16",
                    "default_value": "1e-16",
                    "documentation": "Sets the threshold in the time derivative when a reinitialization procedure reaches a stationary point.",
                    "pattern": "62",
                    "pattern_description": "[Double -MAX_DOUBLE...MAX_DOUBLE (inclusive)]",
                    "actions": "62"
                }
            }
        }
    },
