#!/bin/bash

test()
  {
    result=$(find tests -type f -name "*.json" | xargs grep "$1" | grep -E "$2" | cut -d':' -f1)

    [ -z "$result" ] && return 0

    echo "Error in test .json-files: $3:"

    sorted=($(sort <<<"${result[*]}"));

    for i in "${sorted[@]}"
    do
       echo "  $i"
    done

    return 1
  }

# test 1: "paraview" -> "paraview do output"
test '\"paraview do output\"' 'true' 'output is enabled in following files' || return 1

# test 2: "base" -> "verbosity level"
test '\"verbosity level\"' '\"1\"|\"2\"|\"3\"|\"4\"|\"5\"' 'verbosity level is not correct in following files' || return 1

# test 3: "Navier-Stokes" -> "Output options" -> "output verbosity"
test '\"output verbosity\"' '\"1\"|\"2\"|\"3\"' 'output verbosity is not correct in following files' || return 1

# test 4: "Navier-Stokes" -> "Output options" -> "output verbosity"
test '\"monitor type\"' '\"none\"' 'monitor type is not correct in following files' || return 1

