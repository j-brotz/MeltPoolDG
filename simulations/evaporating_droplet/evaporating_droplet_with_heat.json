{
  "base": {
    "problem name": "melt_pool",
    "application name": "evaporating_droplet_with_heat",
    "global refinements": "3",
    "dimension": "2",
    "degree": "1",
    "gravity": "0.0",
    "verbosity level": "1",
    "do print parameters": "false"
  },
  "time stepping": {
    "start time": "0.0",
    "end time": "2.0",
    "time step size": "0.001"
  },
  "surface tension": {
    "surface tension coefficient": "0.1"
  },
  "material": {
    "material boiling temperature": "1.",
    "material two phase properties transition type": "consistent_with_evaporation",
    "material first capacity": "200",
    "material first conductivity": "1",
    "material first density": "5",
    "material first viscosity": "0.005",
    "material second capacity": "400",
    "material second conductivity": "40",
    "material second density": "200",
    "material second viscosity": "0.1",
    "material molar mass": "0.01801528",
    "material latent heat of evaporation": "1.e3"
  },
  "levelset": {
    "ls do reinitialization": "true",
    "ls time integration scheme": "crank_nicolson"
  },
  "reinitialization": {
    "reinit max n steps": "2",
    "reinit modeltype": "olsson2007",
    "reinit scale factor epsilon": "1.707",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "normal vector": {
    "normal vec implementation": "adaflo",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "curvature": {
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "heat": {
    "linear solver": {
      "rel tolerance": "1e-12",
      "preconditioner type": "AMG"
    },
    "nlsolve": {
      "max nonlinear iterations": "15",
      "field correction tolerance": "1e-7",
      "residual tolerance": "1e-6"
    }
  },
  "evaporation": {
    "evapor evaporation model": "hardt_wondra",
    "evapor evaporative mass flux": "0.000000",
    "evapor coefficient": "0.01"
  },
  "Navier-Stokes": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": "2",
        "global refinements": "0",
        "velocity degree": "2",
        "formulation convective term momentum balance": "convective",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": "10",
          "NL tolerance": "1.e-9",
          "lin max iterations": "30",
          "lin tolerance": "1.e-4",
          "lin velocity preconditioner": "ilu",
          "lin its before inner solvers": "50"
        }
      },
      "Output options": {
        "output verbosity": "1",
        "output walltimes": "0"
      },
      "Time stepping": {
        "scheme": "bdf_2"
      }
    }
  },
  "problem specific": {
    "do evaporative heat flux": "true",
    "do evaporative velocity jump": "true",
    "do heat transfer": "true"
  },
  "advection diffusion": {
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "output": {
    "do output": "true",
    "directory": "evaporating_droplet_test"
  }
}