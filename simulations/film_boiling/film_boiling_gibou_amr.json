{
  "base": {
    "problem name": "melt_pool",
    "application name": "film_boiling",
    "dimension": "2",
    "global refinements": "2",
    "gravity": "9.81",
    "degree": "1",
    "do print parameters": "false",
    "verbosity level": "1"
  },
  "time stepping": {
    "start time": "0.0",
    "end time": "2.0",
    "time step size": "0.001"
  },
  "surface tension": {
    "surface tension coefficient": "0.1"
  },
  "Navier-Stokes": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": "2",
        "global refinements": "0",
        "velocity degree": "2",
        "formulation convective term momentum balance": "convective",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": "20",
          "NL tolerance": "1.e-9",
          "lin max iterations": "30",
          "lin tolerance": "1.e-4",
          "lin velocity preconditioner": "ilu",
          "lin its before inner solvers": "50"
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": "3",
        "output walltimes": "0"
      }
    }
  },
  "levelset": {
    "ls do reinitialization": "true",
    "ls time integration scheme": "crank_nicolson",
    "ls n subdivisions": "2",
    "ls n initial reinit steps": "0"
  },
  "adaptive meshing": {
    "do amr": "true",
    "do not modify boundary cells": "false",
    "upper perc to refine": "     0.3",
    "lower perc to coarsen": "0.3",
    "n initial refinement cycles": "5",
    "max grid refinement level": "6",
    "every n step": "1"
  },
  "reinitialization": {
    "reinit max n steps": "3",
    "reinit modeltype": "olsson2007",
    "reinit constant epsilon": "0.00025",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "normal vector": {
    "normal vec implementation": "meltpooldg",
    "linear solver": {
      "do matrix free": "true"
    },
    "normal vec damping scale factor": "0.5"
  },
  "curvature": {
    "curv implementation": "meltpooldg",
    "linear solver": {
      "do matrix free": "true"
    },
    "curv damping scale factor": "2"
  },
  "evaporation": {
    "evapor evaporation model": "hardt_wondra",
    "evapor coefficient": "1.",
    "evapor level set source term type": "rhs",
    "evapor do level set pressure gradient interpolation": "true"
  },
  "heat": {
    "linear solver": {
      "rel tolerance": "1e-10",
      "preconditioner type": "AMG"
    },
    "nlsolve": {
      "field correction tolerance": "1e-9",
      "residual tolerance": "1e-6"
    }
  },
  "paraview": {
    "paraview directory": "output_film_boiling",
    "paraview do output": "true",
    "paraview write time step size": "0.01"
  },
  "material": {
    "material boiling temperature": "500.",
    "material first capacity": "200",
    "material first conductivity": "1",
    "material first density": "5",
    "material first viscosity": "0.005",
    "material second capacity": "400",
    "material second conductivity": "40",
    "material second density": "200",
    "material second viscosity": "0.1",
    "material two phase properties transition type": "consistent_with_evaporation",
    "material molar mass": "0.01801528",
    "material latent heat of evaporation": "1.e3"
  },
  "problem specific": {
    "do evaporative heat flux": "true",
    "do evaporative velocity jump": "true",
    "do heat transfer": "true",
    "amr": {
      "strategy": "adaflo",
      "do refine all interface cells": "true",
      "do auto detect frequency": "true",
      "automatic grid refinement type": "fixed_fraction"
    }
  },
  "advection diffusion": {
    "linear solver": {
      "do matrix free": "true"
    }
  }
}