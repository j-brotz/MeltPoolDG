{
  "base": {
    "application name": "melt_front_propagation",
    "degree": "1",
    "dimension": "2",
    "do print parameters": "false",
    "global refinements": "5",
    "problem name": "melt_pool",
    "verbosity level": "2"
  },
  "time stepping": {
    "start time": "0.0",
    "time step size": "1e-5",
    "end time": "0.015",
    "max n steps": "20"
  },
  "Navier-Stokes": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": "2",
        "global refinements": "0",
        "velocity degree": "2",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": "10",
          "NL tolerance": "1.e-9",
          "lin max iterations": "30",
          "lin tolerance": "1.e-4",
          "lin relative tolerance": "1",
          "lin velocity preconditioner": "ilu scalar",
          "lin pressure mass preconditioner": "ilu",
          "lin its before inner solvers": "50"
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": "0",
        "output walltimes": "0"
      }
    }
  },
  "laser": {
    "laser power": "10",
    "laser center": "0.0,0.0",
    "laser do move": "false",
    "laser heat source model": "Gauss",
    "laser impact type": "interface",
    "laser gauss laser beam radius": "0.06e-3",
    "laser gauss absorptivity gas": "0.5",
    "laser gauss absorptivity liquid": "0.5",
    "laser power end time": "1e-4"
  },
  "simulation specific parameters": {
    "domain x min": "0.0",
    "domain x max": "0.6e-3",
    "domain z min": "-0.2e-3",
    "domain z max": "0.2e-3",
    "initial temperature": "0.0"
  },
  "melt pool": {
    "mp set velocity to zero in solid": "false"
  },
  "material": {
    "material two phase properties transition type": "consistent_with_evaporation",
    "material first capacity": "0",
    "material first conductivity": "10",
    "material first density": "100",
    "material first viscosity": "1e-3",
    "material second capacity": "500.0",
    "material second conductivity": "50",
    "material second density": "1000.0",
    "material second viscosity": "1e-2",
    "material solid conductivity": "20.0",
    "material solid capacity": "700.0",
    "material solid density": "1100.0",
    "material solid viscosity": "1e-1",
    "material solidus temperature": "100.0",
    "material liquidus temperature": "200.0"
  },
  "levelset": {
    "ls do reinitialization": "true",
    "ls time integration scheme": "crank_nicolson"
  },
  "reinitialization": {
    "reinit max n steps": "2",
    "reinit modeltype": "olsson2007",
    "reinit scale factor epsilon": "1.5",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "normal vector": {
    "normal vec damping scale factor": "0.5",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "curvature": {
    "curv damping scale factor": "0.5",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "heat": {
    "heat nlsolve residual tolerance": "1e-8",
    "linear solver": {
      "rel tolerance": "1e-12",
      "preconditioner type": "ILU"
    }
  },
  "paraview": {
    "paraview do output": "true",
    "paraview directory": "output",
    "paraview filename": "melt_pool_tfi_static_interface_gauss_diff_param"
  },
  "problem specific": {
    "do heat transfer": "true",
    "do solidification": "true"
  },
  "advection diffusion": {
    "linear solver": {
      "do matrix free": "true"
    }
  }
}