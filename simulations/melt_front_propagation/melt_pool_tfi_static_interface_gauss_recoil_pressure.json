      "density": "7850.0",
      "dynamic viscosity": "0.006"
    },
    "solid": {
      "thermal conductivity": "17.0",
      "specific heat capacity": "700.0",
      "density": "7850.0",
      "dynamic viscosity": "1.0"
    },
    "solidus temperature": "1966.0",
    "liquidus temperature": "1974.0",
