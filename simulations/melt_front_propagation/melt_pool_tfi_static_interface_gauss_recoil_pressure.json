  "laser": {
    "starting position": "0.3e-3,0.0",
    "model": "interface_projection_regularized",
    "intensity profile": "Gauss",
    "power": "15.",
    "absorptivity gas": "0.5",
    "absorptivity liquid": "0.5",
    "do move": "false",
    "radius": "0.06e-3"
  },
  "simulation specific parameters": {
    "domain x min": "0.0",
    "domain x max": "0.6e-3",
