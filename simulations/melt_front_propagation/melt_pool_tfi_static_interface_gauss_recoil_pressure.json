{
  "base": {
    "application name": "melt_front_propagation",
    "degree": "1",
    "dimension": "2",
    "do print parameters": "false",
    "global refinements": "5",
    "problem name": "melt_pool",
    "verbosity level": "2",
    "gravity": "0.0"
  },
  "surface tension": {
    "surface tension coefficient": "1.8"
  },
  "time stepping": {
    "start time": "0.0",
    "time step size": "1e-5",
