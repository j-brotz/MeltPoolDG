{
  "base": {
    "problem name": "melt_pool",
    "application name": "stefans_problem1_with_flow_and_heat",
    "dimension": "2",
    "global refinements": "10",
    "gravity": "0.",
    "degree": "1",
    "do print parameters": "false",
    "verbosity level": "1"
  },
  "time stepping": {
    "start time": "0.0",
    "end time": "0.1",
    "time step size": "5.e-4"
  },
  "material": {
    "material boiling temperature": "373.15",
    "material two phase properties transition type": "consistent_with_evaporation",
    "material first density": "1.",
    "material first viscosity": "0.0001",
    "material first conductivity": "0.01",
    "material first capacity": "1000.",
    "material second density": "1.0",
    "material second viscosity": "0.01",
    "material second conductivity": "0.01",
    "material second capacity": "1000.",
    "material molar mass": "0.01801528",
    "material latent heat of evaporation": "1.e1"
  },
  "Navier-Stokes": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": "2",
        "global refinements": "0",
        "velocity degree": "2",
        "formulation convective term momentum balance": "convective",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": "10",
          "NL tolerance": "1.e-9",
          "lin max iterations": "30",
          "lin tolerance": "1.e-4",
          "lin velocity preconditioner": "ilu",
          "lin its before inner solvers": "50"
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": "0",
        "output walltimes": "0"
      }
    }
  },
  "levelset": {
    "ls do reinitialization": "true",
    "ls time integration scheme": "crank_nicolson"
  },
  "adaptive meshing": {
    "do amr": "false",
    "do not modify boundary cells": "false",
    "upper perc to refine": "     0.1",
    "lower perc to coarsen": "0.05",
    "n initial refinement cycles": "5",
    "max grid refinement level": "7",
    "every n step": "1"
  },
  "reinitialization": {
    "reinit max n steps": "5",
    "reinit modeltype": "olsson2007",
    "reinit constant epsilon": "4e-6",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "normal vector": {
    "normal vec implementation": "meltpooldg",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "curvature": {
    "curv implementation": "meltpooldg",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "evaporation": {
    "evapor evaporation model": "hardt_wondra",
    "evapor evaporative mass flux": "0.0",
    "evapor coefficient": "1.0"
  },
  "heat": {
    "heat two phase": "true",
    "linear solver": {
      "rel tolerance": "1e-12",
      "preconditioner type": "AMG"
    }
  },
  "paraview": {
    "paraview do output": "true",
    "paraview directory": "output_stefan_1/",
    "paraview filename": "solution"
  },
  "problem specific": {
    "do evaporative heat flux": "true",
    "do evaporative velocity jump": "true",
    "do heat transfer": "true"
  },
  "advection diffusion": {
    "linear solver": {
      "do matrix free": "true"
    }
  }
