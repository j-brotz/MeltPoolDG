{
  "base": {
    "application name": "thermo_capillary_droplet",
    "degree": "1",
    "dimension": "2",
    "do simplex": "false",
    "do print parameters": "false",
    "global refinements": "7",
    "problem name": "melt_pool",
    "gravity": "0.0",
    "verbosity level": "3"
  },
  "material": {
    "gas": {
      "thermal conductivity": "2.4e-6",
      "specific heat capacity": "1e-4",
      "density": "500",
      "dynamic viscosity": "0.024"
    },
    "liquid": {
      "thermal conductivity": "1.2e-6",
      "specific heat capacity": "5e-5",
      "density": "250",
      "dynamic viscosity": "0.012"
    }
  },
  "surface tension": {
    "surface tension coefficient": "0.01",
    "temperature dependent surface tension coefficient": "0.002",
    "reference temperature": "290"
  },
  "time stepping": {
    "start time": "0.0",
    "end time": "0.12",
    "time step size": "0.0001"
  },
  "Navier-Stokes": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": "2",
        "global refinements": "0",
        "velocity degree": "2",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": "10",
          "NL tolerance": "1.e-12",
          "lin max iterations": "30",
          "lin tolerance": "1.e-4",
          "lin relative tolerance": "1",
          "lin velocity preconditioner": "ilu scalar",
          "lin pressure mass preconditioner": "ilu",
          "lin its before inner solvers": "50"
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": "2",
        "output walltimes": "0"
      }
    }
  },
  "levelset": {
    "ls do reinitialization": "true",
    "ls time integration scheme": "crank_nicolson",
    "ls implementation": "meltpooldg",
    "ls n subdivisions": "2"
  },
  "reinitialization": {
    "reinit max n steps": "5",
    "reinit modeltype": "olsson2007",
    "reinit implementation": "meltpooldg",
    "reinit scale factor epsilon": "2",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "normal vector": {
    "normal vec implementation": "meltpooldg",
    "normal vec damping scale factor": "4",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "curvature": {
    "curv implementation": "meltpooldg",
    "curv damping scale factor": "0.5",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "problem specific": {
    "do heat transfer": "true"
  },
  "advection diffusion": {
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "output": {
    "directory": "output_thermo_capillary/",
    "paraview": {
      "enable": "true"
    }
  }
}