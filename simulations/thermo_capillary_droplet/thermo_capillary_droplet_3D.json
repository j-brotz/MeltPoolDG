{
  "base": {
    "application name": "thermo_capillary_droplet",
    "degree": "1",
    "dimension": "3",
    "do simplex": "false",
    "do print parameters": "false",
    "global refinements": "4",
    "problem name": "melt_pool",
    "gravity": "0.0"
  },
  "heat": {
    "heat two phase": "true",
    "heat variable properties over interface": "false",
    "heat solver rel tolerance": "1e-12",
    "heat solver preconditioner type": "AMG",
    "heat nlsolve residual tolerance": "1e-6"
  },
  "material": {
    "material first capacity": "1e-4",
    "material first conductivity": "2.4e-6",
    "material first density": "500",
    "material first viscosity": "0.024",
    "material second capacity": "5e-5",
    "material second conductivity": "1.2e-6",
    "material second density": "250",
    "material second viscosity": "0.012"
  },
  "flow": {
    "flow surface tension coefficient": "0.01",
    "flow temperature dependent surface tension coefficient": "0.002",
    "flow start time": "0.0",
    "flow end time": "1.0",
    "flow time step size": "0.05",
    "flow do heat transfer": "true"
  },
  "Navier-Stokes": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": "3",
        "global refinements": "0",
        "velocity degree": "2",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": "10",
          "NL tolerance": "1.e-9",
          "lin max iterations": "30",
          "lin tolerance": "1.e-4",
          "lin relative tolerance": "1",
          "lin velocity preconditioner": "ilu scalar",
          "lin pressure mass preconditioner": "ilu",
          "lin its before inner solvers": "50"
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": "2",
        "output walltimes": "0"
      }
    }
  },
  "levelset": {
    "ls do reinitialization": "true",
    "ls artificial diffusivity": "0.0",
    "ls time integration scheme": "crank_nicolson",
    "ls do matrix free": "true",
    "ls implementation": "meltpooldg"
  },
  "reinitialization": {
    "reinit max n steps": "5",
    "reinit modeltype": "olsson2007",
    "reinit do matrix free": "true",
    "reinit implementation": "meltpooldg",
    "reinit scale factor epsilon": "1"
  },
  "normal vector": {
    "normal vec do matrix free": "true",
    "normal vec implementation": "meltpooldg"
  },
  "curvature": {
    "curv do matrix free": "true",
    "curv implementation": "meltpooldg"
  },
  "adaptive meshing": {
    "do amr": "true",
    "do not modify boundary cells": "false",
    "upper perc to refine": "0.1",
    "lower perc to coarsen": "0.01",
    "n initial refinement cycles": "4",
    "max grid refinement level": "5",
    "every n step": "1"
  },
  "paraview": {
    "paraview directory": "output/",
    "paraview filename": "thermocapillary_droplet",
    "paraview do output": "true"
  }
}