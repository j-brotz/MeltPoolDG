{
  "base": {
    "problem name": "level_set",
    "application name": "vortex_bubble",
    "dimension": "2",
    "global refinements": "5",
    "degree": "1"
  },
  "time stepping": {
    "start time": "0.0",
    "end time": "2.0",
    "time step size": "0.01"
  },
  "levelset": {
    "ls do reinitialization": "true",
    "ls time integration scheme": "crank_nicolson"
  },
  "reinitialization": {
    "reinit max n steps": "5",
    "reinit modeltype": "olsson2007",
    "reinit eps scale factor": "0.5",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "normal vector": {
    "normal vec damping scale factor": "0.5",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "advection diffusion": {
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "output": {
    "do output": "true",
    "paraview": {
      "print boundary id": "true"
    }
  }
}