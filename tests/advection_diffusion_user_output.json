{
  "base": {
    "problem name": "advection_diffusion",
    "application name": "advection_diffusion_user_output",
    "dimension": "2",
    "global refinements": "5",
    "degree": "1",
    "do print parameters": "false"
  },
  "time stepping": {
    "start time": "0.0",
    "end time": "0.05",
    "time step size": "0.01"
  },
  "output": {
    "do user defined postprocessing": "true",
    "paraview": {
      "enable": "false"
    }
  },
  "level set": {
    "advection diffusion": {
      "advec diff integration scheme": "crank_nicolson",
      "linear solver": {
        "preconditioner type": "ILU",
        "do matrix free": "false"
      },
      "diffusivity": "0.000000",
      "implementation": "meltpooldg"
    }
  }
}