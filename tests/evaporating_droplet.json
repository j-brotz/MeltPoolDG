{
  "base": {
    "problem name": "melt_pool",
    "application name": "evaporating_droplet",
    "global refinements": "3",
    "dimension": "2",
    "degree": "1",
    "gravity": "0.00",
    "do print parameters": "false"
  },
  "surface tension": {
    "surface tension coefficient": "0.00"
  },
  "time stepping": {
    "start time": "0.0",
    "end time": "0.02",
    "time step size": "0.001"
  },
  "material": {
    "gas": {
      "thermal conductivity": "1e-16",
      "density": "0.001",
      "dynamic viscosity": "0.001"
    },
    "liquid": {
      "thermal conductivity": "1e-16",
      "density": "1",
      "dynamic viscosity": "0.01"
    },
    "two phase fluid properties transition type": "consistent_with_evaporation"
  },
  "levelset": {
    "ls do reinitialization": "true",
    "ls time integration scheme": "crank_nicolson"
  },
  "reinitialization": {
    "reinit max n steps": "2",
    "reinit modeltype": "olsson2007",
    "reinit scale factor epsilon": "1.0",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "normal vector": {
    "normal vec damping scale factor": "4",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "curvature": {
    "curv damping scale factor": "5",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "evaporation": {
    "evapor evaporative mass flux": "1.0e-3",
    "evapor ls value liquid": "1",
    "evapor ls value gas": "-1"
  },
  "Navier-Stokes": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": "2",
        "global refinements": "0",
        "velocity degree": "2",
        "formulation convective term momentum balance": "convective",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": "10",
          "NL tolerance": "1.e-9",
          "lin max iterations": "30",
          "lin tolerance": "1.e-4",
          "lin velocity preconditioner": "ilu",
          "lin its before inner solvers": "50"
        }
      },
      "Output options": {
        "output verbosity": "0",
        "output walltimes": "0"
      },
      "Time stepping": {
        "scheme": "bdf_2"
      }
    }
  },
  "problem specific": {
    "do evaporative heat flux": "false",
    "do heat transfer": "true",
    "do evaporative velocity jump": "true"
  },
  "advection diffusion": {
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "output": {
    "paraview": {
      "enable": "false"
    }
  }
}