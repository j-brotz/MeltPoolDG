{
  "base": {
    "problem name": "two_phase_flow_with_evaporation",
    "application name": "evaporating_droplet_with_heat",
    "global refinements": "3",
    "dimension": "2",
    "degree": "1",
    "gravity": "0.0",
    "verbosity level": "0",
    "do print parameters": "false"
  },
  "flow": {
    "flow surface tension coefficient": "0.1",
    "flow start time": "0.0",
    "flow end time": "0.03",
    "flow time step size": "0.001",
    "flow variable properties over interface": "consistent_with_evaporation"
  },
  "material": {
    "material first capacity": "200",
    "material first conductivity": "1",
    "material first density": "5",
    "material first viscosity": "0.005",
    "material second capacity": "400",
    "material second conductivity": "40",
    "material second density": "200",
    "material second viscosity": "0.1"
  },
  "levelset": {
    "ls do reinitialization": "true",
    "ls artificial diffusivity": "0.0",
    "ls time integration scheme": "crank_nicolson",
    "ls do matrix free": "true"
  },
  "reinitialization": {
    "reinit max n steps": "2",
    "reinit modeltype": "olsson2007",
    "reinit do matrix free": "true",
    "reinit do print l2norm": "true",
    "reinit scale factor epsilon": "1.707"
  },
  "normal vector": {
    "normal vec damping scale factor": "4",
    "normal vec do matrix free": "true"
  },
  "curvature": {
    "curv damping scale factor": "0.5",
    "curv do matrix free": "true"
  },
  "paraview": {
    "paraview directory": "evaporating_droplet_test",
    "paraview do output": "true"
  },
  "heat": {
    "heat two phase": "true",
    "heat variable properties over interface": "true",
    "heat solver preconditioner type": "AMG",
    "heat solver rel tolerance": "1e-12",
    "heat nlsolve residual tolerance": "1e-6",
    "heat nlsolve field correction tolerance": "1e-7",
    "heat nlsolve max nonlinear iterations": "15"
  },
  "evaporation": {
    "evapor evaporation model": "Hardt Wondra",
    "evapor evaporative mass flux": "0.000000",
    "evapor boiling temperature": "1.",
    "evapor molar mass": "0.01801528",
    "evapor latent heat of evaporation": "1.e3",
    "evapor coefficient": "0.01"
  },
  "Navier-Stokes": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": "2",
        "global refinements": "0",
        "velocity degree": "2",
        "formulation convective term momentum balance": "convective",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": "10",
          "NL tolerance": "1.e-9",
          "lin max iterations": "30",
          "lin tolerance": "1.e-4",
          "lin velocity preconditioner": "ilu",
          "lin its before inner solvers": "50"
        }
      },
      "Output options": {
        "output verbosity": "1",
        "output walltimes": "0"
      },
      "Time stepping": {
        "scheme": "bdf_2"
      }
    }
  }
}