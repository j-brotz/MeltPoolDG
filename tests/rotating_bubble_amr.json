{
  "base": {
    "problem name": "level_set",
    "application name": "rotating_bubble",
    "dimension": "2",
    "global refinements": "6",
    "degree": "1",
    "do print parameters": "false"
  },
  "time stepping": {
    "start time": "0.0",
    "end time": "0.05",
    "time step size": "0.01"
  },
  "adaptive meshing": {
    "do amr": "true",
    "upper perc to refine": "     0.1",
    "lower perc to coarsen": "    0.00",
    "max grid refinement level": "8"
  },
  "levelset": {
    "ls do reinitialization": "true",
    "ls time integration scheme": "crank_nicolson"
  },
  "reinitialization": {
    "reinit max n steps": "5",
    "reinit modeltype": "olsson2007",
    "reinit constant epsilon": "0.01",
    "linear solver": {
      "solver type": "CG",
      "preconditioner type": "Identity",
      "do matrix free": "false"
    }
  },
  "normal vector": {
    "normal vec damping scale factor": "0.5",
    "linear solver": {
      "do matrix free": "false"
    }
  },
  "curvature": {
    "curv damping scale factor": "4",
    "linear solver": {
      "do matrix free": "false"
    }
  },
  "advection diffusion": {
    "linear solver": {
      "preconditioner type": "ILU",
      "do matrix free": "false"
    }
  },
  "output": {
    "do output": "false",
    "paraview": {
      "filename": "solution_rotaitng_bubble"
    }
  }
}