{
  "base": {
    "problem name": "level_set",
    "application name": "rotating_bubble",
    "dimension": "2",
    "global refinements": "6",
    "degree": "1",
    "do print parameters": "false",
    "do simplex": "false"
  },
  "time stepping": {
    "start time": "0.0",
    "end time": "0.05",
    "time step size": "0.01"
  },
  "levelset": {
    "ls do reinitialization": "true",
    "ls time integration scheme": "crank_nicolson",
    "ls n subdivisions": "2"
  },
  "reinitialization": {
    "reinit max n steps": "2",
    "reinit modeltype": "olsson2007",
    "reinit scale factor epsilon": "2",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "normal vector": {
    "normal vec damping scale factor": "4",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "curvature": {
    "curv damping scale factor": "16",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "advection diffusion": {
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "output": {
    "paraview": {
      "enable": "false"
    }
  }
}