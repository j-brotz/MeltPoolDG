{
  "base": {
    "problem name": "level_set",
    "application name": "rotating_bubble",
    "dimension": "2",
    "global refinements": "6",
    "degree": "1",
    "do print parameters": "false",
    "do simplex": "false"
  },
  "time stepping": {
    "start time": "0.0",
    "end time": "0.05",
    "time step size": "0.01"
  },
  "output": {
    "paraview": {
      "enable": "false"
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": "true"
      },
      "enable": "true",
      "max n steps": "2",
      "type": "olsson2007",
      "interface thickness parameter": {
        "type": "proportional_to_cell_size",
        "val": "2"
      }
    },
    "curvature": {
      "linear solver": {
        "do matrix free": "true"
      },
      "filter parameter": "16"
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": "true"
      },
      "filter parameter": "4"
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": "true"
      }
    },
    "n subdivisions": "2"
  }
}