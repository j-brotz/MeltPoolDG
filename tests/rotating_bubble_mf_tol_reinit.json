{
  "base": {
    "problem name": "level_set",
    "application name": "rotating_bubble",
    "dimension": "2",
    "global refinements": "6",
    "degree": "1",
    "do print parameters": "false"
  },
  "time stepping": {
    "start time": "0.0",
    "end time": "0.05",
    "time step size": "0.01"
  },
  "output": {
    "paraview": {
      "enable": "false"
    }
  },
  "level set": {
    "reinitialization": {
      "linear solver": {
        "do matrix free": "true"
      },
      "enable": "true",
      "tolerance": "1e-2",
      "max n steps": "5",
      "type": "olsson2007"
    },
    "curvature": {
      "linear solver": {
        "do matrix free": "true"
      }
    },
    "normal vector": {
      "linear solver": {
        "do matrix free": "true"
      },
      "filter parameter": "0.5"
    },
    "advection diffusion": {
      "linear solver": {
        "do matrix free": "true"
      }
    }
  }
}