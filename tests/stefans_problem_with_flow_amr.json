{
  "base": {
    "problem name": "melt_pool",
    "application name": "stefans_problem_with_flow",
    "dimension": "2",
    "global refinements": "5",
    "gravity": "0.",
    "degree": "1",
    "do print parameters": "false"
  },
  "time stepping": {
    "start time": "0.0",
    "end time": "0.002",
    "time step size": "0.005"
  },
  "melt pool": {
    "mp do heat transfer": "true",
    "mp do evaporation": "true"
  },
  "flow": {
    "flow surface tension coefficient": "0."
  },
  "material": {
    "material two phase properties transition type": "consistent_with_evaporation",
    "material first density": "0.01",
    "material first viscosity": "0.001",
    "material first conductivity": "1e-16",
    "material second density": "1.0",
    "material second viscosity": "0.01",
    "material second conductivity": "1e-16"
  },
  "Navier-Stokes": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "dimension": "2",
        "global refinements": "0",
        "velocity degree": "2",
        "formulation convective term momentum balance": "convective",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": "10",
          "NL tolerance": "1.e-9",
          "lin max iterations": "30",
          "lin tolerance": "1.e-4",
          "lin velocity preconditioner": "ilu",
          "lin its before inner solvers": "50"
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": "0",
        "output walltimes": "0"
      }
    }
  },
  "levelset": {
    "ls do reinitialization": "true",
    "ls time integration scheme": "crank_nicolson",
    "ls do matrix free": "true"
  },
  "adaptive meshing": {
    "do amr": "true",
    "do not modify boundary cells": "false",
    "upper perc to refine": "     0.1",
    "lower perc to coarsen": "0.05",
    "n initial refinement cycles": "5",
    "max grid refinement level": "7",
    "every n step": "1"
  },
  "reinitialization": {
    "reinit max n steps": "5",
    "reinit modeltype": "olsson2007",
    "reinit do matrix free": "true",
    "reinit constant epsilon": "0.02"
  },
  "normal vector": {
    "normal vec do matrix free": "true",
    "normal vec implementation": "meltpooldg"
  },
  "curvature": {
    "curv do matrix free": "true",
    "curv implementation": "meltpooldg"
  },
  "evaporation": {
    "evapor evaporative mass flux": "1.e-3",
    "evapor ls value liquid": "1",
    "evapor ls value gas": "-1"
  },
  "paraview": {
    "paraview do output": "false"
  }
}