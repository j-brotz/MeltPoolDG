{
  "base": {
    "problem name": "melt_pool",
    "application name": "stefans_problem_with_flow",
    "dimension": "2",
    "global refinements": "5",
    "gravity": "0.",
    "degree": "1",
    "do print parameters": "false"
  },
  "time stepping": {
    "start time": "0.0",
    "end time": "0.002",
    "time step size": "0.0005"
  },
  "material": {
    "gas": {
      "thermal conductivity": "1e-16",
      "density": "0.01",
      "dynamic viscosity": "1e-3"
    },
    "liquid": {
      "thermal conductivity": "1e-16",
      "density": "1.0",
      "dynamic viscosity": "1e-3"
    },
    "two phase properties transition type": "consistent_with_evaporation"
  },
  "Navier-Stokes": {
    "adaflo": {
      "Navier-Stokes": {
        "physical type": "incompressible",
        "constitutive type": "user defined",
        "dimension": "2",
        "global refinements": "0",
        "velocity degree": "2",
        "formulation convective term momentum balance": "convective",
        "Solver": {
          "linearization scheme": "coupled implicit Newton",
          "NL max iterations": "10",
          "NL tolerance": "1.e-9",
          "lin max iterations": "30",
          "lin tolerance": "1.e-4",
          "lin velocity preconditioner": "ilu",
          "lin its before inner solvers": "50"
        }
      },
      "Time stepping": {
        "scheme": "bdf_2"
      },
      "Output options": {
        "output verbosity": "0",
        "output walltimes": "0"
      }
    }
  },
  "levelset": {
    "ls do reinitialization": "true",
    "ls time integration scheme": "crank_nicolson"
  },
  "reinitialization": {
    "reinit max n steps": "5",
    "reinit modeltype": "olsson2007",
    "reinit constant epsilon": "0.02",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "normal vector": {
    "normal vec implementation": "meltpooldg",
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "curvature": {
    "curv implementation": "meltpooldg",
    "linear solver": {
      "do matrix free": "true"
    },
    "curv verbosity level": "1"
  },
  "evaporation": {
    "evapor evaporative mass flux": "1.e-2"
  },
  "problem specific": {
    "do evaporative heat flux": "false",
    "do heat transfer": "true",
    "do evaporative velocity jump": "true"
  },
  "advection diffusion": {
    "linear solver": {
      "do matrix free": "true"
    }
  },
  "output": {
    "do user defined postprocessing": "true",
    "paraview": {
      "enable": "false"
    }
  }
}