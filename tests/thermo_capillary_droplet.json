{
  "base": {
    "application name": "thermo_capillary_droplet",
    "degree": "1",
    "dimension": "2",
    "do simplex": "false",
    "do print parameters": "false",
    "global refinements": "6",
    "problem name": "two_phase_flow_with_heat_transfer",
    "gravity": "0.0"
  },
  "heat": {
    "heat two phase": "true",
    "heat variable properties over interface": "false"
  },
  "material": {
    "material liquid capacity": "1e-4",
    "material liquid conductivity": "2.4e-6",
    "material liquid density": "500",
    "material gas capacity": "5e-5",
    "material gas conductivity": "1.2e-6",
    "material gas density": "250"
  },
    "flow" : {
    "flow density": "500",
    "flow viscosity": "0.024",
    "flow density difference": "-250.",
    "flow viscosity difference": "-0.012",
    "flow surface tension coefficient": "0.01",
    "flow temperature dependent surface tension coefficient": "0.002",
    "flow start time": "0.0",
    "flow end time": "0.002",
    "flow time step size": "0.0005"
  },
  "Navier-Stokes" : {
    "adaflo" : {
      "Navier-Stokes" : {
        "physical type"      : "incompressible",
        "dimension"         : "2",
        "global refinements" : "0",
        "velocity degree"    : "2",
        "Solver" : {
          "linearization scheme"         : "coupled implicit Newton",
          "NL max iterations"            : "10",
          "NL tolerance"                 : "1.e-9",
          "lin max iterations"           : "30",
          "lin tolerance"                : "1.e-4",
          "lin relative tolerance"       : "1",
          "lin velocity preconditioner"  : "ilu scalar",
          "lin pressure mass preconditioner" : "ilu",
          "lin its before inner solvers" : "50"
        }
      },
      "Time stepping" : {
        "scheme"           : "bdf_2"
      },
      "Output options" : 
      {
          "output verbosity" : "0",
          "output walltimes" : "0"
      }
    }
  },
  "levelset" : {
    "ls do reinitialization": "true",
    "ls artificial diffusivity": "0.0",
    "ls do print l2norm": "true",
    "ls time integration scheme" : "crank_nicolson",
    "ls do matrix free": "true",
    "ls implementation": "meltpooldg"
  },
  "adaptive meshing" : {
    "do amr":                    "false",
    "do not modify boundary cells": "false",
    "upper perc to refine": "     0.30",
    "lower perc to coarsen":     "0.30",
    "n initial refinement cycles": "3",
    "max grid refinement level": "7",
    "every n step": "1"
  },
  "reinitialization" : {
    "reinit max n steps": "5",
    "reinit modeltype": "olsson2007",
    "reinit do matrix free": "true",
    "reinit implementation": "meltpooldg",
    "reinit scale factor epsilon": "1"
  },
  "normal vector": { 
    "normal vec do matrix free": "true",
    "normal vec implementation": "meltpooldg"
  },
  "curvature":{ 
    "curv do matrix free": "true",
    "curv implementation": "meltpooldg"
  },
  "paraview": {
    "paraview do output": "false"
  }
}
